@using ChargePoint.CarManagement.Domain.Enums
@using ChargePoint.CarManagement.Domain.Models
@*
    Reusable Drag & Drop Image Upload Component
    Parameters:
    - Model: The MediaType for this uploader instance.
    - ViewData["Settings"]: The FileUploadSettings object.
*@
@model MediaType
@inject IOptions<FileUploadSettings> FileUploadSettings

@{
    var settings = FileUploadSettings.Value;
    var mediaType = Model;
    var dropZoneId = $"dropZone-{mediaType}";
    var inputId = $"input-{mediaType}";
    var previewId = $"preview-{mediaType}";
}

<div class="drop-zone compact-drop-zone d-flex align-items-center rounded mb-3 shadow-sm border border-secondary border-opacity-25" id="@dropZoneId" onclick="document.getElementById('@inputId').click()" tabindex="0" title="Click, Kéo thả hoặc Ctrl+V để tải ảnh">

    <!-- Icon Indicator -->
    <div class="flex-shrink-0 d-flex justify-content-center align-items-center text-primary" style="width: 45px;">
        <i class="fas fa-cloud-upload-alt fs-4"></i>
    </div>

    <!-- Text Information -->
    <div class="flex-grow-1 overflow-hidden" style="line-height: 1.3;">
        <div class="fw-bold text-truncate text-dark" style="font-size: 0.85rem;" title="@mediaType.GetDisplayName()">
            @mediaType.GetDisplayName()
        </div>
        <small class="text-muted d-block text-truncate mt-1" style="font-size: 0.70rem;">
            Click, Kéo thả, hoặc <kbd style="font-size:0.6rem">Ctrl+V</kbd>
        </small>
    </div>

    <!-- Image Preview Thumbnail Side -->
    <div class="flex-shrink-0 ms-2 p-1 border-start border-opacity-25" style="width: auto; min-width: 60px;">
        <div id="@previewId" class="image-preview-container d-flex flex-nowrap align-items-center gap-1 overflow-auto rounded bg-light" style="height: 50px; padding: 2px;">
            <div class="d-flex w-100 justify-content-center">
                <i class="fas fa-image text-muted" style="opacity: 0.2; font-size: 1.5rem;"></i>
            </div>
        </div>
    </div>

    <!-- Hidden Input -->
    <input type="file" multiple name="ImageFiles[@mediaType]" id="@inputId" class="d-none image-upload-input"
           accept="@string.Join(",", settings.AllowedImageExtensions.Select(e => "image/" + e.TrimStart('.')))" />
</div>
