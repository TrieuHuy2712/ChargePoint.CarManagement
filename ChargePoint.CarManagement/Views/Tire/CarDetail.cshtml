                                                                        +@(sauTraiRecord.DanhSachHinhAnhDOT.Count - 1)
                                                                    </span>
                                                                }
                                                            </div>
                                                        }
                                                        else
                                                        {
                                                            <div class="placeholder-img placeholder-dot" style="height: 80px;">
                                                                <i class="fas fa-image text-muted"></i>
                                                                <p class="mb-0" style="font-size: 9px;">Chưa có</p>
                                                            </div>
                                                        }
                                                    </div>
                                                </div>
                                            </div>
                                        </div>

                                        <div class="tire-info">
                                            <small class="d-block"><strong>@sauTraiRecord.HangLop @sauTraiRecord.ModelLop</strong></small>
                                            <small class="d-block text-muted">@sauTraiRecord.NgayThucHien.ToString("dd/MM/yyyy")</small>
                                            <small class="d-block text-info fw-bold">ODO thay lốp: @sauTraiRecord.OdoThayLop.ToString("N0") km</small>

