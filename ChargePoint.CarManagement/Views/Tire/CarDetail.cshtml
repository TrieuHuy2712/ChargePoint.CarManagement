@using ChargePoint.CarManagement.Domain.Entities
@using ChargePoint.CarManagement.Domain.ViewModels.TireViewModels
@model TireCareDetailVM
@{
    ViewData["Title"] = "Chi tiết lốp xe";
    var car = Model.Car;
    var tiresByPosition = Model.TireRecordsPosition;
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3">
            <i class="fas fa-circle-notch text-dark me-2"></i>
            Quản lý lốp xe
        </h1>
        <div>
            <a asp-action="History" asp-route-id="@car?.Id" class="btn btn-outline-info">
                <i class="fas fa-history"></i> Lịch sử
            </a>
            <a asp-action="Index" class="btn btn-secondary">
                <i class="fas fa-arrow-left"></i> Quay lại
            </a>
        </div>
    </div>

    @if (car != null)
    {
        <div class="alert alert-info">
            <i class="fas fa-car me-2"></i>
            <strong>Xe:</strong> @car.TenXe -
            <strong>Biển số:</strong>
            @if (car.MauBienSo == MauBienSo.Vang)
            {
                <span class="badge" style="background-color: #ffc107; color: #000; border: 1px solid #333;">@car.BienSo</span>
            }
            else
            {
                <span class="badge" style="background-color: #fff; color: #000; border: 1px solid #333;">@car.BienSo</span>
            }
            -
            <strong>ODO hiện tại:</strong> @car.OdoXe.ToString("N0") km
        </div>
    }

    <!-- Chú thích / Note -->
    <div class="row justify-content-center mb-4">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow-sm border-0">
                <div class="card-body py-2 px-3">
                    <div class="d-flex justify-content-around align-items-center flex-wrap" style="font-size: 13px;">
                        <span class="me-3 mb-1"><i class="fas fa-square text-success me-1"></i> Tốt (An toàn)</span>
                        <span class="me-3 mb-1"><i class="fas fa-square text-warning me-1"></i> Sắp đến hạn thay (≤ @TireRecord.WarningThresholdKm km)</span>
                        <span class="mb-1"><i class="fas fa-square text-danger me-1"></i> Quá hạn (Cần thay)</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Sơ đồ lốp xe -->
    <div class="card shadow mb-4">
        <div class="card-header bg-dark text-white">
            <h5 class="mb-0"><i class="fas fa-car me-2"></i>Sơ đồ lốp xe</h5>
        </div>
        <div class="card-body">
            <div class="row justify-content-center">
                <div class="col-md-8 col-lg-6">
                    <div class="car-diagram p-4" style="background: linear-gradient(135deg, #f5f7fa 0%, #e4e8ec 100%); border-radius: 20px;">
                        <!-- Hàng trước -->
                        <div class="row mb-4">
                            <div class="col-6 text-center">
                                @{
                                    var truocTrai = tiresByPosition?.FirstOrDefault(t => (ViTriLop)t.ViTri == ViTriLop.TruocTrai);
                                    var truocTraiRecord = truocTrai?.LastRecord as TireRecord;
                                    var truocTraiStatus = Model.GetTireStatus(truocTraiRecord);
                                }
                                <div class="tire-card @(truocTraiStatus != null ? $"has-data {truocTraiStatus.BorderClass}" : "")">
                                    <div class="tire-position">↖️ TRƯỚC TRÁI</div>
                                    @if (truocTraiRecord != null && truocTraiStatus != null)
                                    {
                                        @* Hình ảnh Chứng từ và DOT *@
                                        <div class="tire-images mb-2">
                                            <div class="row g-1">
                                                @* Hình ảnh Chứng từ *@
                                                <div class="col-6">
                                                    <div class="image-container">
                                                        <small class="d-block text-muted mb-1" style="font-size: 10px;">📄 Chứng từ</small>
                                                        @if (truocTraiRecord.DanhSachHinhAnh?.Any() == true)
                                                        {
                                                            <div class="position-relative">
                                                                <img src="@truocTraiRecord.DanhSachHinhAnh.First()" 
                                                                     class="img-thumbnail w-100" 
                                                                     style="height: 80px; object-fit: cover; cursor: pointer;"
                                                                     onclick="showImageModal('@truocTraiRecord.DanhSachHinhAnh.First()', 'Chứng từ - Lốp trước trái')"
                                                                     alt="Chứng từ lốp trước trái"
                                                                     title="Click để xem chi tiết" />
                                                                @if (truocTraiRecord.DanhSachHinhAnh.Count > 1)
                                                                {
                                                                    <span class="badge bg-info position-absolute top-0 end-0" style="font-size: 9px; padding: 2px 4px;">
                                                                        +@(truocTraiRecord.DanhSachHinhAnh.Count - 1)
                                                                    </span>
                                                                }
                                                            </div>
                                                        }
                                                        else
                                                        {
                                                            <div class="placeholder-img" style="height: 80px;">
                                                                <i class="fas fa-image text-muted"></i>
                                                                <p class="mb-0" style="font-size: 9px;">Chưa có</p>
                                                            </div>
                                                        }
                                                    </div>
                                                </div>

                                                @* Hình ảnh DOT *@
                                                <div class="col-6">
                                                    <div class="image-container">
                                                        <small class="d-block text-muted mb-1" style="font-size: 10px;">📅 DOT</small>

                                                        @* DEBUG: Kiểm tra xem có data không *@
                                                        @if (truocTraiRecord.DanhSachHinhAnhDOT != null)
                                                        {
                                                            @* <small class="text-danger">Count: @truocTraiRecord.DanhSachHinhAnhDOT.Count</small> *@
                                                        }

                                                        @if (truocTraiRecord.DanhSachHinhAnhDOT?.Any() == true)
                                                        {
                                                            <div class="position-relative">
                                                                <img src="@truocTraiRecord.DanhSachHinhAnhDOT.First()" 
                                                                     class="img-thumbnail w-100 border-warning" 
                                                                     style="height: 80px; object-fit: cover; cursor: pointer;"
                                                                     onclick="showImageModal('@truocTraiRecord.DanhSachHinhAnhDOT.First()', 'DOT - Lốp trước trái')"
                                                                     alt="DOT lốp trước trái"
                                                                     title="Click để xem chi tiết" />
                                                                @if (truocTraiRecord.DanhSachHinhAnhDOT.Count > 1)
                                                                {
                                                                    <span class="badge bg-warning text-dark position-absolute top-0 end-0" style="font-size: 9px; padding: 2px 4px;">
                                                                        +@(truocTraiRecord.DanhSachHinhAnhDOT.Count - 1)
                                                                    </span>
                                                                }
                                                            </div>
                                                        }
                                                        else
                                                        {
                                                            <div class="placeholder-img placeholder-dot" style="height: 80px;">
                                                                <i class="fas fa-image text-muted"></i>
                                                                <p class="mb-0" style="font-size: 9px;">Chưa có</p>
                                                            </div>
                                                        }
                                                    </div>
                                                </div>
                                            </div>
                                        </div>

                                        <div class="tire-info">
                                            <small class="d-block"><strong>@truocTraiRecord.HangLop @truocTraiRecord.ModelLop</strong></small>
                                            <small class="d-block text-muted">@truocTraiRecord.NgayThucHien.ToString("dd/MM/yyyy")</small>
                                            <small class="d-block text-info fw-bold">ODO thay lốp: @truocTraiRecord.OdoThayLop.ToString("N0") km</small>

                                            <small class="d-block @truocTraiStatus.TextClass" title="Thay tại: @truocTraiRecord.OdoThayLop.ToString("N0") km | Dự kiến thay tiếp: @truocTraiStatus.ExpectedNextOdo.ToString("N0") km">
                                                @if (truocTraiStatus.IsError) { <i class="fas fa-exclamation-triangle me-1"></i> <span>Lỗi: ODO thay lốp lớn hơn ODO xe</span> } 
                                                else { <i class="fas fa-road me-1"></i> <span>Đã chạy: @truocTraiStatus.DrivenKm.ToString("N0") km</span> }
                                                @if(truocTraiStatus.RemainingKm > 0 && !truocTraiStatus.IsError) { <span class="text-muted fw-normal">(@truocTraiStatus.RemainingKm.ToString("N0") km nữa)</span> }
                                            </small>
                                        </div>
                                        <div class="btn-group mt-2" role="group">
                                            <a asp-action="Details" asp-route-id="@truocTraiRecord.Id"
                                               class="btn btn-sm btn-info" title="Xem chi tiết">
                                                <i class="fas fa-eye"></i>
                                            </a>
                                            <a asp-action="Edit" asp-route-id="@truocTraiRecord.Id"
                                               class="btn btn-sm btn-warning" title="Sửa">
                                                <i class="fas fa-edit"></i>
                                            </a>
                                            <a asp-action="Create" asp-route-id="@car?.Id" asp-route-viTri="@((int)ViTriLop.TruocTrai)"
                                               class="btn btn-sm btn-success" title="Thêm mới">
                                                <i class="fas fa-plus"></i>
                                            </a>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="placeholder-img-empty mb-2" style="height: 100px;">
                                            <i class="fas fa-question-circle fa-2x text-muted mb-2"></i>
                                            <p class="mb-0 text-muted" style="font-size: 11px;">Chưa có dữ liệu lốp</p>
                                        </div>
                                        <div class="tire-info text-muted">
                                            <small>Chưa có dữ liệu</small>
                                        </div>
                                        <a asp-action="Create" asp-route-id="@car?.Id" asp-route-viTri="@((int)ViTriLop.TruocTrai)"
                                           class="btn btn-sm btn-success mt-2">
                                            <i class="fas fa-plus"></i> Thêm
                                        </a>
                                    }
                                </div>
                            </div>
                            <div class="col-6 text-center">
                                @{
                                    var truocPhai = tiresByPosition?.FirstOrDefault(t => (ViTriLop)t.ViTri == ViTriLop.TruocPhai);
                                    var truocPhaiRecord = truocPhai?.LastRecord as TireRecord;
                                    var truocPhaiStatus = Model.GetTireStatus(truocPhaiRecord);
                                }
                                <div class="tire-card @(truocPhaiStatus != null ? $"has-data {truocPhaiStatus.BorderClass}" : "")">
                                    <div class="tire-position">TRƯỚC PHẢI ↗️</div>
                                    @if (truocPhaiRecord != null && truocPhaiStatus != null)
                                    {
                                        @* Hình ảnh Chứng từ và DOT *@
                                        <div class="tire-images mb-2">
                                            <div class="row g-1">
                                                @* Hình ảnh Chứng từ *@
                                                <div class="col-6">
                                                    <div class="image-container">
                                                        <small class="d-block text-muted mb-1" style="font-size: 10px;">📄 Chứng từ</small>
                                                        @if (truocPhaiRecord.DanhSachHinhAnh?.Any() == true)
                                                        {
                                                            <div class="position-relative">
                                                                <img src="@truocPhaiRecord.DanhSachHinhAnh.First()" 
                                                                     class="img-thumbnail w-100" 
                                                                     style="height: 80px; object-fit: cover; cursor: pointer;"
                                                                     onclick="showImageModal('@truocPhaiRecord.DanhSachHinhAnh.First()', 'Chứng từ - Lốp trước phải')"
                                                                     alt="Chứng từ lốp trước phải"
                                                                     title="Click để xem chi tiết" />
                                                                @if (truocPhaiRecord.DanhSachHinhAnh.Count > 1)
                                                                {
                                                                    <span class="badge bg-info position-absolute top-0 end-0" style="font-size: 9px; padding: 2px 4px;">
                                                                        +@(truocPhaiRecord.DanhSachHinhAnh.Count - 1)
                                                                    </span>
                                                                }
                                                            </div>
                                                        }
                                                        else
                                                        {
                                                            <div class="placeholder-img" style="height: 80px;">
                                                                <i class="fas fa-image text-muted"></i>
                                                                <p class="mb-0" style="font-size: 9px;">Chưa có</p>
                                                            </div>
                                                        }
                                                    </div>
                                                </div>

                                                @* Hình ảnh DOT *@
                                                <div class="col-6">
                                                    <div class="image-container">
                                                        <small class="d-block text-muted mb-1" style="font-size: 10px;">📅 DOT</small>
                                                        @if (truocPhaiRecord.DanhSachHinhAnhDOT?.Any() == true)
                                                        {
                                                            <div class="position-relative">
                                                                <img src="@truocPhaiRecord.DanhSachHinhAnhDOT.First()" 
                                                                     class="img-thumbnail w-100 border-warning" 
                                                                     style="height: 80px; object-fit: cover; cursor: pointer;"
                                                                     onclick="showImageModal('@truocPhaiRecord.DanhSachHinhAnhDOT.First()', 'DOT - Lốp trước phải')"
                                                                     alt="DOT lốp trước phải"
                                                                     title="Click để xem chi tiết" />
                                                                @if (truocPhaiRecord.DanhSachHinhAnhDOT.Count > 1)
                                                                {
                                                                    <span class="badge bg-warning text-dark position-absolute top-0 end-0" style="font-size: 9px; padding: 2px 4px;">
                                                                        +@(truocPhaiRecord.DanhSachHinhAnhDOT.Count - 1)
                                                                    </span>
                                                                }
                                                            </div>
                                                        }
                                                        else
                                                        {
                                                            <div class="placeholder-img placeholder-dot" style="height: 80px;">
                                                                <i class="fas fa-image text-muted"></i>
                                                                <p class="mb-0" style="font-size: 9px;">Chưa có</p>
                                                            </div>
                                                        }
                                                    </div>
                                                </div>
                                            </div>
                                        </div>

                                        <div class="tire-info">
                                            <small class="d-block"><strong>@truocPhaiRecord.HangLop @truocPhaiRecord.ModelLop</strong></small>
                                            <small class="d-block text-muted">@truocPhaiRecord.NgayThucHien.ToString("dd/MM/yyyy")</small>
                                            <small class="d-block text-info fw-bold">ODO thay lốp: @truocPhaiRecord.OdoThayLop.ToString("N0") km</small>

                                            <small class="d-block @truocPhaiStatus.TextClass" title="Thay tại: @truocPhaiRecord.OdoThayLop.ToString("N0") km | Dự kiến thay tiếp: @truocPhaiStatus.ExpectedNextOdo.ToString("N0") km">
                                                @if (truocPhaiStatus.IsError) { <i class="fas fa-exclamation-triangle me-1"></i> <span>Lỗi: ODO thay lốp lớn hơn ODO xe</span> } 
                                                else { <i class="fas fa-road me-1"></i> <span>Đã chạy: @truocPhaiStatus.DrivenKm.ToString("N0") km</span> }
                                                @if(truocPhaiStatus.RemainingKm > 0 && !truocPhaiStatus.IsError) { <span class="text-muted fw-normal">(@truocPhaiStatus.RemainingKm.ToString("N0") km nữa)</span> }
                                            </small>
                                        </div>
                                        <div class="btn-group mt-2" role="group">
                                            <a asp-action="Details" asp-route-id="@truocPhaiRecord.Id"
                                               class="btn btn-sm btn-info" title="Xem chi tiết">
                                                <i class="fas fa-eye"></i>
                                            </a>
                                            <a asp-action="Edit" asp-route-id="@truocPhaiRecord.Id"
                                               class="btn btn-sm btn-warning" title="Sửa">
                                                <i class="fas fa-edit"></i>
                                            </a>
                                            <a asp-action="Create" asp-route-id="@car?.Id" asp-route-viTri="@((int)ViTriLop.TruocPhai)"
                                               class="btn btn-sm btn-success" title="Thêm mới">
                                                <i class="fas fa-plus"></i>
                                            </a>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="placeholder-img-empty mb-2" style="height: 100px;">
                                            <i class="fas fa-question-circle fa-2x text-muted mb-2"></i>
                                            <p class="mb-0 text-muted" style="font-size: 11px;">Chưa có dữ liệu lốp</p>
                                        </div>
                                        <div class="tire-info text-muted">
                                            <small>Chưa có dữ liệu</small>
                                        </div>
                                        <a asp-action="Create" asp-route-id="@car?.Id" asp-route-viTri="@((int)ViTriLop.TruocPhai)"
                                           class="btn btn-sm btn-success mt-2">
                                            <i class="fas fa-plus"></i> Thêm
                                        </a>
                                    }
                                </div>
                            </div>
                        </div>

                        <!-- Icon xe -->
                        <div class="text-center mb-4">
                            <div class="car-icon">
                                <i class="fas fa-car-side fa-4x text-secondary"></i>
                            </div>
                        </div>

                        <!-- Hàng sau -->
                        <div class="row">
                            <div class="col-6 text-center">
                                @{
                                    var sauTrai = tiresByPosition?.FirstOrDefault(t => (ViTriLop)t.ViTri == ViTriLop.SauTrai);
                                    var sauTraiRecord = sauTrai?.LastRecord as TireRecord;
                                    var sauTraiStatus = Model.GetTireStatus(sauTraiRecord);
                                }
                                <div class="tire-card @(sauTraiStatus != null ? $"has-data {sauTraiStatus.BorderClass}" : "")">
                                    <div class="tire-position">↙️ SAU TRÁI</div>
                                    @if (sauTraiRecord != null && sauTraiStatus != null)
                                    {
                                        @* Hình ảnh Chứng từ và DOT *@
                                        <div class="tire-images mb-2">
                                            <div class="row g-1">
                                                @* Hình ảnh Chứng từ *@
                                                <div class="col-6">
                                                    <div class="image-container">
                                                        <small class="d-block text-muted mb-1" style="font-size: 10px;">📄 Chứng từ</small>
                                                        @if (sauTraiRecord.DanhSachHinhAnh?.Any() == true)
                                                        {
                                                            <div class="position-relative">
                                                                <img src="@sauTraiRecord.DanhSachHinhAnh.First()" 
