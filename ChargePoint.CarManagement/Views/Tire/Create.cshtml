@using ChargePoint.CarManagement.Models.ViewModels.TireViewModels
@using ChargePoint.CarManagement.Models.Enums
@model TireCreateVM
@inject Microsoft.Extensions.Options.IOptions<ChargePoint.CarManagement.Models.FileUploadSettings> FileUploadSettings

@{
    ViewData["Title"] = "Thêm hồ sơ lốp";
    var settings = FileUploadSettings.Value;
    var car = Model.Car;
    var tireRecord = Model.TireRecord!;
    bool fromDraft = ViewBag.FromDraft == true;
}

<div class="container">
    <h1 class="mb-4">
        <i class="fas fa-plus-circle text-success"></i> Thêm hồ sơ lốp
    </h1>

    @if (car != null)
    {
        <div class="alert alert-info">
            <i class="fas fa-car me-2"></i>
            <strong>Xe:</strong> @car.TenXe -
            <strong>Biển số:</strong>
            @if (car.MauBienSo == MauBienSo.Vang)
            {
                <span class="license-plate license-plate-yellow">@car.BienSo</span>
            }
            else
            {
                <span class="license-plate license-plate-white">@car.BienSo</span>
            }
            -
            <strong>ODO hiện tại:</strong> @car.OdoXe.ToString("N0") km
        </div>
    }

    <div class="card shadow">
        <div class="card-body">
            <form asp-action="Create" method="post" enctype="multipart/form-data" id="tireForm">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
                <input type="hidden" asp-for="TireRecord.CarId" />
                <input type="hidden" name="fromDraft" value="@(fromDraft.ToString().ToLower())" />

                <div class="row">
                    <!-- Vị trí lốp -->
                    <div class="col-md-6">
                        <div class="form-group mb-3">
                            <label asp-for="TireRecord.ViTriLop" class="form-label"></label>
                            <div class="row g-2">
                                @foreach (ViTriLop viTri in Enum.GetValues(typeof(ViTriLop)))
                                {
                                    var icon = viTri switch
                                    {
                                        ViTriLop.TruocTrai => "↖️",
                                        ViTriLop.TruocPhai => "↗️",
                                        ViTriLop.SauTrai => "↙️",
                                        ViTriLop.SauPhai => "↘️",
                                        _ => "⚪"
                                    };
                                    var label = viTri switch
                                    {
                                        ViTriLop.TruocTrai => "Trước trái",
                                        ViTriLop.TruocPhai => "Trước phải",
                                        ViTriLop.SauTrai => "Sau trái",
                                        ViTriLop.SauPhai => "Sau phải",
                                        _ => ""
                                    };
                                    <div class="col-6">
                                        <div class="form-check tire-position-check">
                                            <input class="form-check-input" type="radio"
                                                   name="TireRecord.ViTriLop" id="viTri@((int)viTri)"
                                                   value="@((int)viTri)"
                                                   @(tireRecord.ViTriLop == viTri ? "checked" : "") />
                                            <label class="form-check-label w-100" for="viTri@((int)viTri)">
                                                <span class="tire-badge">
                                                    @icon @label
                                                </span>
                                            </label>
                                        </div>
                                    </div>
                                }
                            </div>
                            <span asp-validation-for="TireRecord.ViTriLop" class="text-danger"></span>
                        </div>
                    </div>

                    <!-- Loại thao tác -->
                    <div class="col-md-6">
                        <div class="form-group mb-3">
                            <label asp-for="TireRecord.LoaiThaoTac" class="form-label"></label>
                            <select asp-for="TireRecord.LoaiThaoTac" class="form-select"
                                    asp-items="Html.GetEnumSelectList<LoaiThaoTacLop>()">
                            </select>
                            <span asp-validation-for="TireRecord.LoaiThaoTac" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group mb-3">
                            <label asp-for="TireRecord.NgayThucHien" class="form-label"></label>
                            <input asp-for="TireRecord.NgayThucHien" class="form-control" type="date" />
                            <span asp-validation-for="TireRecord.NgayThucHien" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group mb-3">
                            <label asp-for="TireRecord.OdoThayLop" class="form-label"></label>
                            <div class="input-group">
                                <input asp-for="TireRecord.OdoThayLop" class="form-control" type="number" id="odoThayLop" />
                                <span class="input-group-text">km</span>
                            </div>
                            <small class="form-text text-info"><i class="fas fa-info-circle"></i> ODO hiện tại của lốp, hệ thống sẽ <strong>Ghi ĐÈ</strong>  lên ODO của xe.</small>
                            <span asp-validation-for="TireRecord.OdoThayLop" class="text-danger d-block mt-1"></span>
                        </div>
                    </div>
                </div>

                <h5 class="mt-4 mb-3 text-primary">
                    <i class="fas fa-circle-notch"></i> Thông tin lốp
                </h5>

                <div class="row">
                    <div class="col-md-4">
                        <div class="form-group mb-3">
                            <label asp-for="TireRecord.HangLop" class="form-label"></label>
                            <input asp-for="TireRecord.HangLop" class="form-control" placeholder="VD: Michelin, Bridgestone..." />
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group mb-3">
                            <label asp-for="TireRecord.ModelLop" class="form-label"></label>
                            <input asp-for="TireRecord.ModelLop" class="form-control" placeholder="VD: Pilot Sport 4..." />
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group mb-3">
                            <label asp-for="TireRecord.KichThuocLop" class="form-label"></label>
                            <input asp-for="TireRecord.KichThuocLop" class="form-control" placeholder="VD: 235/45R18" />
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-4">
                        <div class="form-group mb-3">
                            <label asp-for="TireRecord.OdoThayTiepTheo" class="form-label"></label>
                            <div class="input-group">
                                <input asp-for="TireRecord.OdoThayTiepTheo" class="form-control" type="number"
                                       id="odoThayTiepTheo"
                                       value="@((car?.OdoXe ?? 0) + 60000)"
                                       placeholder="VD: @((car?.OdoXe ?? 0) + 60000)" />
                                <span class="input-group-text">km</span>
                            </div>
                            <small class="form-text text-muted">Tự động tính = ODO hiện tại + 60,000 km</small>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group mb-3">
                            <label asp-for="TireRecord.ChiPhi" class="form-label"></label>
                            <div class="input-group">
                                <input asp-for="TireRecord.ChiPhi" class="form-control" type="number" />
                                <span class="input-group-text">VNĐ</span>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group mb-3">
                            <label asp-for="TireRecord.NoiThucHien" class="form-label"></label>
                            <input asp-for="TireRecord.NoiThucHien" class="form-control" placeholder="VD: Garage ABC..." />
                        </div>
                    </div>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="TireRecord.GhiChu" class="form-label"></label>
                    <textarea asp-for="TireRecord.GhiChu" class="form-control" rows="2"
                              placeholder="Ghi chú thêm..."></textarea>
                </div>

                @* Sử dụng shared partial view cho hình ảnh *@
                @await Html.PartialAsync("_TireSharedImage")

                @if (!fromDraft)
                {
                    <div class="form-check mt-3">
                        <input class="form-check-input" type="checkbox" value="true" id="AddMaintenanceInfo" />
                        <label class="form-check-label" for="AddMaintenanceInfo">
                            Sau khi lưu, chuyển sang thêm thông tin bảo dưỡng
                        </label>
                    </div>
                }

                <div class="form-group mt-4">
                    @if (fromDraft)
                    {
                        <button type="submit" name="action" value="Complete" class="btn btn-success" id="btnSubmit">
                            <i class="fas fa-save"></i> Lưu hồ sơ lốp + bảo dưỡng
                        </button>
                    }
                    else
                    {
                        <button type="submit" name="action" value="Save" class="btn btn-success" id="btnSubmit">
                            <i class="fas fa-save"></i> Lưu hồ sơ lốp
                        </button>
                    }
                    <a asp-action="CarDetail" asp-route-id="@tireRecord.CarId" class="btn btn-secondary">
                        <i class="fas fa-arrow-left"></i> Quay lại
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

    <script>
        // Tự động tính ODO thay tiếp theo = ODO thay lốp + 60,000
        const odoThayLopInput = document.getElementById('odoThayLop');
        const odoThayTiepTheoInput = document.getElementById('odoThayTiepTheo');

        if (odoThayLopInput && odoThayTiepTheoInput) {
            odoThayLopInput.addEventListener('input', function() {
                const odoThayLop = parseInt(this.value) || 0;
                if (odoThayLop > 0) {
                    odoThayTiepTheoInput.value = odoThayLop + 60000;
                }
            });
        }

        const actionInput = document.getElementById('actionValue');
        const addMaintenanceCheckbox = document.getElementById('AddMaintenanceInfo');

        if (actionInput) {
            if (@(fromDraft.ToString().ToLower())) {
                actionInput.value = 'Save';
            } else if (addMaintenanceCheckbox) {
                addMaintenanceCheckbox.addEventListener('change', function() {
                    actionInput.value = this.checked ? 'SaveMaintenance' : 'Save';
                });
            }
        }

        // Submit button loading state
        document.getElementById('tireForm').addEventListener('submit', function() {
            const btn = document.getElementById('btnSubmit');
            btn.disabled = true;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Đang lưu...';
        });
    </script>
}
