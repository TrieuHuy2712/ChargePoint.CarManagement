@using ChargePoint.CarManagement.Domain.Entities
@using ChargePoint.CarManagement.Domain.Models
@using ChargePoint.CarManagement.Domain.ViewModels.TireViewModels
@model TireCreateVM
@inject Microsoft.Extensions.Options.IOptions<FileUploadSettings> FileUploadSettings

@{
    ViewData["Title"] = "Thêm hồ sơ lốp";
    var settings = FileUploadSettings.Value;
    var car = Model.Car;
    var tireRecord = Model.TireRecord!;
    bool fromDraft = ViewBag.FromDraft == true;
}

<div class="container">
    <h1 class="mb-4">
        <i class="fas fa-plus-circle text-success"></i> Thêm hồ sơ lốp
    </h1>

    @if (car != null)
    {
        <div class="alert alert-info">
            <i class="fas fa-car me-2"></i>
            <strong>Xe:</strong> @car.TenXe -
            <strong>Biển số:</strong>
            @if (car.MauBienSo == MauBienSo.Vang)
            {
                <span class="license-plate license-plate-yellow">@car.BienSo</span>
            }
            else
            {
                <span class="license-plate license-plate-white">@car.BienSo</span>
            }
            -
            <strong>ODO hiện tại:</strong> @car.OdoXe.ToString("N0") km
        </div>
    }

    <div class="card shadow">
        <div class="card-body">
            <form asp-action="Create" method="post" enctype="multipart/form-data" id="tireForm">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
                <input type="hidden" asp-for="TireRecord.CarId" />
                <input type="hidden" name="fromDraft" value="@(fromDraft.ToString().ToLower())" />
                <input type="hidden" name="positionDraftsJson" id="positionDraftsJson" />

                <div class="row">
                    <!-- Vị trí lốp -->
                    <div class="col-md-6">
                        <div class="form-group mb-3">
                            <label asp-for="TireRecord.ViTriLop" class="form-label"></label>
                            <div class="row g-2">
                                @foreach (ViTriLop viTri in Enum.GetValues(typeof(ViTriLop)))
                                {
                                    var icon = viTri switch
                                    {
                                        ViTriLop.TruocTrai => "↖️",
                                        ViTriLop.TruocPhai => "↗️",
                                        ViTriLop.SauTrai => "↙️",
                                        ViTriLop.SauPhai => "↘️",
                                        _ => "⚪"
                                    };
                                    var label = viTri switch
                                    {
                                        ViTriLop.TruocTrai => "Trước trái",
                                        ViTriLop.TruocPhai => "Trước phải",
                                        ViTriLop.SauTrai => "Sau trái",
                                        ViTriLop.SauPhai => "Sau phải",
                                        _ => ""
                                    };
                                    <div class="col-6">
                                        <div class="form-check tire-position-check">
                                            <input class="form-check-input" type="radio"
                                                   name="TireRecord.ViTriLop" id="viTri@((int)viTri)"
                                                   value="@((int)viTri)"
                                                   @(tireRecord.ViTriLop == viTri ? "checked" : "") />
                                            <label class="form-check-label w-100" for="viTri@((int)viTri)">
                                                <span class="tire-badge">
                                                    @icon @label
                                                </span>
                                            </label>
                                        </div>
                                    </div>
                                }
                            </div>
                            <span asp-validation-for="TireRecord.ViTriLop" class="text-danger"></span>

                            <div class="mt-3 p-3 border rounded bg-light">
                                <div class="form-check mb-2">
                                    <input class="form-check-input" type="checkbox" id="applyForMultiTires" />
                                    <label class="form-check-label fw-semibold" for="applyForMultiTires">
                                        Áp dụng cùng thông tin cho nhiều lốp
                                    </label>
                                </div>
                                <small class="text-muted d-block mb-2">
                                    Ví dụ: nhập ở lốp trái và tick thêm các lốp khác để lưu cùng lúc.
                                </small>
                                <div class="row g-2 multi-tire-options d-none" id="multiTireOptions">
                                    @foreach (ViTriLop viTri in Enum.GetValues(typeof(ViTriLop)))
                                    {
                                        var multiLabel = viTri switch
                                        {
                                            ViTriLop.TruocTrai => "Trước trái",
                                            ViTriLop.TruocPhai => "Trước phải",
                                            ViTriLop.SauTrai => "Sau trái",
                                            ViTriLop.SauPhai => "Sau phải",
                                            _ => ""
                                        };
                                        <div class="col-6">
                                            <div class="form-check">
                                                <input class="form-check-input multi-tire-check"
                                                       type="checkbox"
                                                       name="selectedViTriLops"
                                                       id="multiViTri@((int)viTri)"
                                                       value="@((int)viTri)"
                                                       @(tireRecord.ViTriLop == viTri ? "checked" : "") />
                                                <label class="form-check-label" for="multiViTri@((int)viTri)">
                                                    @multiLabel
                                                </label>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Loại thao tác -->
                    <div class="col-md-6">
                        <div class="form-group mb-3">
                            <label asp-for="TireRecord.LoaiThaoTac" class="form-label"></label>
                            <select asp-for="TireRecord.LoaiThaoTac" class="form-select"
                                    asp-items="Html.GetEnumSelectList<LoaiThaoTacLop>()">
                            </select>
                            <span asp-validation-for="TireRecord.LoaiThaoTac" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group mb-3">
                            <label asp-for="TireRecord.NgayThucHien" class="form-label"></label>
                            <input asp-for="TireRecord.NgayThucHien" class="form-control" type="date" />
                            <span asp-validation-for="TireRecord.NgayThucHien" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group mb-3">
                            <label asp-for="TireRecord.OdoThayLop" class="form-label"></label>
                            <div class="input-group">
                                <input asp-for="TireRecord.OdoThayLop" class="form-control" type="number" id="odoThayLop" />
                                <span class="input-group-text">km</span>
                            </div>
                            <small class="form-text text-info"><i class="fas fa-info-circle"></i> ODO hiện tại của lốp, hệ thống sẽ <strong>Ghi ĐÈ</strong>  lên ODO của xe.</small>
                            <span asp-validation-for="TireRecord.OdoThayLop" class="text-danger d-block mt-1"></span>
                        </div>
                    </div>
                </div>

                <h5 class="mt-4 mb-3 text-primary">
                    <i class="fas fa-circle-notch"></i> Thông tin lốp
                </h5>

                <div class="row">
                    <div class="col-md-4">
                        <div class="form-group mb-3">
                            <label asp-for="TireRecord.HangLop" class="form-label"></label>
                            <input asp-for="TireRecord.HangLop" class="form-control" placeholder="VD: Michelin, Bridgestone..." />
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group mb-3">
                            <label asp-for="TireRecord.ModelLop" class="form-label"></label>
                            <input asp-for="TireRecord.ModelLop" class="form-control" placeholder="VD: Pilot Sport 4..." />
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group mb-3">
                            <label asp-for="TireRecord.KichThuocLop" class="form-label"></label>
                            <input asp-for="TireRecord.KichThuocLop" class="form-control" placeholder="VD: 235/45R18" />
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-4">
                        <div class="form-group mb-3">
                            <label asp-for="TireRecord.OdoThayTiepTheo" class="form-label"></label>
                            <div class="input-group">
                                <input asp-for="TireRecord.OdoThayTiepTheo" class="form-control" type="number"
                                       id="odoThayTiepTheo"
                                       value="@((car?.OdoXe ?? 0) + 60000)"
                                       placeholder="VD: @((car?.OdoXe ?? 0) + 60000)" />
                                <span class="input-group-text">km</span>
                            </div>
                            <small class="form-text text-muted">Tự động tính = ODO hiện tại + 60,000 km</small>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group mb-3">
                            <label asp-for="TireRecord.ChiPhi" class="form-label"></label>
                            <div class="input-group">
                                <input asp-for="TireRecord.ChiPhi" class="form-control" type="number" />
                                <span class="input-group-text">VNĐ</span>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group mb-3">
                            <label asp-for="TireRecord.NoiThucHien" class="form-label"></label>
                            <input asp-for="TireRecord.NoiThucHien" class="form-control" placeholder="VD: Garage ABC..." />
                        </div>
                    </div>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="TireRecord.GhiChu" class="form-label"></label>
                    <textarea asp-for="TireRecord.GhiChu" class="form-control" rows="2"
                              placeholder="Ghi chú thêm..."></textarea>
                </div>

                @* Sử dụng shared partial view cho hình ảnh *@
                @await Html.PartialAsync("_TireSharedImage")

                <div class="form-group mt-4">
                    @if (fromDraft)
                    {
                        <button type="submit" name="action" value="Complete" class="btn btn-success" id="btnSubmit">
                            <i class="fas fa-save"></i> Lưu hồ sơ lốp + bảo dưỡng
                        </button>
                    }
                    else
                    {
                        <button type="submit" name="action" value="Save" class="btn btn-success" id="btnSubmit">
                            <i class="fas fa-save"></i> Lưu hồ sơ lốp
                        </button>
                    }
                    <a asp-action="CarDetail" asp-route-id="@tireRecord.CarId" class="btn btn-secondary">
                        <i class="fas fa-arrow-left"></i> Quay lại
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

    <script>
        // Tự động tính ODO thay tiếp theo = ODO thay lốp + 60,000
        const odoThayLopInput = document.getElementById('odoThayLop');
        const odoThayTiepTheoInput = document.getElementById('odoThayTiepTheo');

        if (odoThayLopInput && odoThayTiepTheoInput) {
            odoThayLopInput.addEventListener('input', function() {
                const odoThayLop = parseInt(this.value) || 0;
                if (odoThayLop > 0) {
                    odoThayTiepTheoInput.value = odoThayLop + 60000;
                }
            });
        }

        const applyForMultiTiresCheckbox = document.getElementById('applyForMultiTires');
        const multiTireOptions = document.getElementById('multiTireOptions');
        const multiTireChecks = document.querySelectorAll('.multi-tire-check');
        const tirePositionRadios = document.querySelectorAll('input[name="TireRecord.ViTriLop"]');

        const draftFieldSelectors = [
            '[name="TireRecord.LoaiThaoTac"]',
            '[name="TireRecord.NgayThucHien"]',
            '[name="TireRecord.OdoThayLop"]',
            '[name="TireRecord.HangLop"]',
            '[name="TireRecord.ModelLop"]',
            '[name="TireRecord.KichThuocLop"]',
            '[name="TireRecord.OdoThayTiepTheo"]',
            '[name="TireRecord.ChiPhi"]',
            '[name="TireRecord.NoiThucHien"]',
            '[name="TireRecord.GhiChu"]'
        ];

        const positionDrafts = {};
        let activePosition = getCurrentPositionValue();
        const createDraftStorageKey = `tire-create-drafts-${document.querySelector('[name="TireRecord.CarId"]')?.value ?? 'unknown'}`;

        function loadDraftsFromStorage() {
            try {
                const raw = sessionStorage.getItem(createDraftStorageKey);
                if (!raw) return;
                const saved = JSON.parse(raw);
                if (saved && typeof saved === 'object') {
                    Object.assign(positionDrafts, saved);
                }
            } catch {
                // ignore invalid storage
            }
        }

        function persistDraftsToStorage() {
            try {
                sessionStorage.setItem(createDraftStorageKey, JSON.stringify(positionDrafts));
            } catch {
                // ignore storage errors
            }
        }

        function buildSubmitDraftPayload() {
            const payload = {};
            Object.keys(positionDrafts).forEach(position => {
                const values = positionDrafts[position] ?? {};
                payload[position] = {
                    loaiThaoTac: parseInt(values['[name="TireRecord.LoaiThaoTac"]'] ?? '1') || 1,
                    ngayThucHien: values['[name="TireRecord.NgayThucHien"]'] || new Date().toISOString().substring(0, 10),
                    odoThayLop: parseInt(values['[name="TireRecord.OdoThayLop"]'] ?? '0') || 0,
                    hangLop: values['[name="TireRecord.HangLop"]'] || null,
                    modelLop: values['[name="TireRecord.ModelLop"]'] || null,
                    kichThuocLop: values['[name="TireRecord.KichThuocLop"]'] || null,
                    odoThayTiepTheo: values['[name="TireRecord.OdoThayTiepTheo"]'] ? parseInt(values['[name="TireRecord.OdoThayTiepTheo"]']) : null,
                    chiPhi: parseFloat(values['[name="TireRecord.ChiPhi"]'] ?? '0') || 0,
                    noiThucHien: values['[name="TireRecord.NoiThucHien"]'] || null,
                    ghiChu: values['[name="TireRecord.GhiChu"]'] || null
                };
            });
            return payload;
        }

        function getCurrentPositionValue() {
            return document.querySelector('input[name="TireRecord.ViTriLop"]:checked')?.value;
        }

        function captureFormValues() {
            const values = {};
            draftFieldSelectors.forEach(selector => {
                const el = document.querySelector(selector);
                if (el) {
                    values[selector] = el.value;
                }
            });
            return values;
        }

        function applyFormValues(values) {
            if (!values) return;
            draftFieldSelectors.forEach(selector => {
                const el = document.querySelector(selector);
                if (el && Object.prototype.hasOwnProperty.call(values, selector)) {
                    el.value = values[selector] ?? '';
                }
            });
        }

        function saveDraftForPosition(positionValue) {
            if (!positionValue) return;
            positionDrafts[positionValue] = captureFormValues();
            persistDraftsToStorage();
        }

        function saveDraftForCurrentPosition() {
            saveDraftForPosition(activePosition);
        }

        function restoreDraftForPosition(positionValue) {
            if (!positionValue) return;
            if (!positionDrafts[positionValue]) {
                // Lần đầu chuyển sang vị trí này: lấy snapshot hiện tại làm mốc khởi tạo.
                positionDrafts[positionValue] = captureFormValues();
                persistDraftsToStorage();
            }
            applyFormValues(positionDrafts[positionValue]);
        }

        function syncPrimaryPositionToMultiChecks() {
            const selectedRadio = document.querySelector('input[name="TireRecord.ViTriLop"]:checked');
            if (!selectedRadio) return;

            const selectedValue = selectedRadio.value;
            multiTireChecks.forEach(cb => {
                if (cb.value === selectedValue) {
                    cb.checked = true;
                    cb.disabled = true;
                } else {
                    cb.disabled = !applyForMultiTiresCheckbox?.checked;
                }
            });
        }

        if (applyForMultiTiresCheckbox && multiTireOptions) {
            applyForMultiTiresCheckbox.addEventListener('change', function() {
                multiTireOptions.classList.toggle('d-none', !this.checked);
                multiTireChecks.forEach(cb => {
                    if (!this.checked) {
                        cb.checked = false;
                    }
                });

                // Khi tắt chế độ áp dụng nhiều lốp, chụp trạng thái hiện tại để lưu theo vị trí.
                if (!this.checked) {
                    saveDraftForCurrentPosition();
                }

                syncPrimaryPositionToMultiChecks();
            });

            tirePositionRadios.forEach(radio => {
                radio.addEventListener('change', function() {
                    // Chỉ dùng cơ chế giữ dữ liệu theo vị trí khi KHÔNG bật apply nhiều lốp.
                    if (!applyForMultiTiresCheckbox.checked) {
                        saveDraftForPosition(activePosition);
                        activePosition = this.value;
                        restoreDraftForPosition(activePosition);
                    }
                    else {
                        activePosition = this.value;
                    }

                    syncPrimaryPositionToMultiChecks();
                });
            });

            loadDraftsFromStorage();

            // Khởi tạo snapshot cho vị trí mặc định lúc load trang.
            restoreDraftForPosition(activePosition);
            saveDraftForCurrentPosition();
            syncPrimaryPositionToMultiChecks();
        }

        // Khi người dùng nhập liệu và chưa bật apply nhiều lốp, luôn cập nhật draft của vị trí hiện tại.
        draftFieldSelectors.forEach(selector => {
            const el = document.querySelector(selector);
            if (el) {
                el.addEventListener('input', () => {
                    if (!applyForMultiTiresCheckbox?.checked) {
                        saveDraftForCurrentPosition();
                    }
                });
                el.addEventListener('change', () => {
                    if (!applyForMultiTiresCheckbox?.checked) {
                        saveDraftForCurrentPosition();
                    }
                });
            }
        });

        // Submit button loading state
        document.getElementById('tireForm').addEventListener('submit', function() {
            saveDraftForCurrentPosition();
            const hiddenDraftInput = document.getElementById('positionDraftsJson');
            if (hiddenDraftInput) {
                hiddenDraftInput.value = JSON.stringify(buildSubmitDraftPayload());
            }

            try {
                sessionStorage.removeItem(createDraftStorageKey);
            } catch {
                // ignore storage errors
            }
            const btn = document.getElementById('btnSubmit');
            btn.disabled = true;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Đang lưu...';
        });
    </script>
}
