@using ChargePoint.CarManagement.Models.ViewModels.TireViewModels
@model TireCreateVM
@inject IOptions<ChargePoint.CarManagement.Models.FileUploadSettings> FileUploadSettings

@{
    ViewData["Title"] = "Thêm hồ sơ lốp";
    var settings = FileUploadSettings.Value;
    var car = Model.Car;
    var tireRecord = Model.TireRecord!;
}

<div class="container">
    <h1 class="mb-4">
        <i class="fas fa-plus-circle text-success"></i> Thêm hồ sơ lốp
    </h1>

    @if (car != null)
    {
        <div class="alert alert-info">
            <i class="fas fa-car me-2"></i>
            <strong>Xe:</strong> @car.TenXe -
            <strong>Biển số:</strong>
            @if (car.MauBienSo == MauBienSo.Vang)
            {
                <span class="badge" style="background-color: #ffc107; color: #000; border: 1px solid #333;">@car.BienSo</span>
            }
            else
            {
                <span class="badge" style="background-color: #fff; color: #000; border: 1px solid #333;">@car.BienSo</span>
            }
            -
            <strong>ODO hiện tại:</strong> @car.OdoXe.ToString("N0") km
        </div>
    }

    <div class="card shadow">
        <div class="card-body">
            <form asp-action="Create" enctype="multipart/form-data" id="tireForm">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
                <input type="hidden" asp-for="@tireRecord.CarId" />

                <div class="row">
                    <!-- Vị trí lốp -->
                    <div class="col-md-6">
                        <div class="form-group mb-3">
                            <label asp-for="@tireRecord.ViTriLop" class="form-label"></label>
                            <div class="row g-2">
                                @foreach (ViTriLop viTri in Enum.GetValues(typeof(ViTriLop)))
                                {
                                    var icon = viTri switch
                                    {
                                        ViTriLop.TruocTrai => "↖️",
                                        ViTriLop.TruocPhai => "↗️",
                                        ViTriLop.SauTrai => "↙️",
                                        ViTriLop.SauPhai => "↘️",
                                        _ => "⚪"
                                    };
                                    var label = viTri switch
                                    {
                                        ViTriLop.TruocTrai => "Trước trái",
                                        ViTriLop.TruocPhai => "Trước phải",
                                        ViTriLop.SauTrai => "Sau trái",
                                        ViTriLop.SauPhai => "Sau phải",
                                        _ => ""
                                    };
                                    <div class="col-6">
                                        <div class="form-check tire-position-check">
                                            <input class="form-check-input" type="radio"
                                                   name="ViTriLop" id="viTri@((int)viTri)"
                                                   value="@((int)viTri)"
                                                   @(@tireRecord.ViTriLop == viTri ? "checked" : "") />
                                            <label class="form-check-label w-100" for="viTri@((int)viTri)">
                                                <span class="tire-badge">
                                                    @icon @label
                                                </span>
                                            </label>
                                        </div>
                                    </div>
                                }
                            </div>
                            <span asp-validation-for="@tireRecord.ViTriLop" class="text-danger"></span>
                        </div>
                    </div>

                    <!-- Loại thao tác -->
                    <div class="col-md-6">
                        <div class="form-group mb-3">
                            <label asp-for="@tireRecord.LoaiThaoTac" class="form-label"></label>
                            <select asp-for="@tireRecord.LoaiThaoTac" class="form-select"
                                    asp-items="Html.GetEnumSelectList<LoaiThaoTacLop>()">
                            </select>
                            <span asp-validation-for="@tireRecord.LoaiThaoTac" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group mb-3">
                            <label asp-for="@tireRecord.NgayThucHien" class="form-label"></label>
                            <input asp-for="@tireRecord.NgayThucHien" class="form-control" type="date" />
                            <span asp-validation-for="@tireRecord.NgayThucHien" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group mb-3">
                            <label asp-for="@tireRecord.OdoThayLop" class="form-label"></label>
                            <div class="input-group">
                                <input asp-for="@tireRecord.OdoThayLop" class="form-control" type="number" />
                                <span class="input-group-text">km</span>
                            </div>
                            <span asp-validation-for="@tireRecord.OdoThayLop" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <h5 class="mt-4 mb-3 text-primary">
                    <i class="fas fa-circle-notch"></i> Thông tin lốp
                </h5>

                <div class="row">
                    <div class="col-md-4">
                        <div class="form-group mb-3">
                            <label asp-for="@tireRecord.HangLop" class="form-label"></label>
                            <input asp-for="@tireRecord.HangLop" class="form-control" placeholder="VD: Michelin, Bridgestone..." />
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group mb-3">
                            <label asp-for="@tireRecord.ModelLop" class="form-label"></label>
                            <input asp-for="@tireRecord.ModelLop" class="form-control" placeholder="VD: Pilot Sport 4..." />
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group mb-3">
                            <label asp-for="@tireRecord.KichThuocLop" class="form-label"></label>
                            <input asp-for="@tireRecord.KichThuocLop" class="form-control" placeholder="VD: 235/45R18" />
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-4">
                        <div class="form-group mb-3">
                            <label asp-for="@tireRecord.OdoThayTiepTheo" class="form-label"></label>
                            <div class="input-group">
                                <input asp-for="@tireRecord.OdoThayTiepTheo" class="form-control" type="number"
                                       placeholder="VD: @((car?.OdoXe ?? 0) + 40000)" />
                                <span class="input-group-text">km</span>
                            </div>
                            <small class="form-text text-muted">Thường thay sau 40,000 - 60,000 km</small>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group mb-3">
                            <label asp-for="@tireRecord.ChiPhi" class="form-label"></label>
                            <div class="input-group">
                                <input asp-for="@tireRecord.ChiPhi" class="form-control" type="number" />
                                <span class="input-group-text">VNĐ</span>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group mb-3">
                            <label asp-for="@tireRecord.NoiThucHien" class="form-label"></label>
                            <input asp-for="@tireRecord.NoiThucHien" class="form-control" placeholder="VD: Garage ABC..." />
                        </div>
                    </div>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="@tireRecord.GhiChu" class="form-label"></label>
                    <textarea asp-for="@tireRecord.GhiChu" class="form-control" rows="2"
                              placeholder="Ghi chú thêm..."></textarea>
                </div>

                <!-- Hình ảnh chứng từ -->
                <h5 class="mt-4 mb-3 text-primary">
                    <i class="fas fa-images"></i> Hình ảnh chứng từ
                </h5>
                <div class="form-group mb-3">
                    <label class="form-label">
                        <i class="fas fa-file-image"></i> Tải lên hình ảnh (hóa đơn, lốp mới...)
                    </label>
                    <input type="file" name="HinhAnhChungTuFiles" class="form-control" multiple
                           accept="@string.Join(",", settings.AllowedImageExtensions.Select(e => "image/" + e.TrimStart('.')))"
                           id="imageInput" />
                    <small class="form-text text-muted">
                        Có thể chọn nhiều ảnh. Tối đa @settings.MaxImageSizeMB MB mỗi ảnh.
                    </small>
                    <div id="imagePreview" class="mt-3 d-flex flex-wrap gap-2"></div>
                </div>

                <div class="form-group mt-4">
                    <button type="submit" class="btn btn-success" id="btnSubmit">
                        <i class="fas fa-save"></i> Lưu hồ sơ
                    </button>
                    <a asp-action="CarDetail" asp-route-id="@tireRecord.CarId" class="btn btn-secondary">
                        <i class="fas fa-arrow-left"></i> Quay lại
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

    <script>
        document.getElementById('imageInput').addEventListener('change', function(e) {
            const preview = document.getElementById('imagePreview');
            preview.innerHTML = '';

            Array.from(e.target.files).forEach((file, index) => {
                if (file.type.startsWith('image/')) {
                    const reader = new FileReader();
                    reader.onload = function(e) {
                        const div = document.createElement('div');
                        div.className = 'position-relative';
                        div.innerHTML = `
                            <img src="${e.target.result}" class="img-thumbnail" style="width: 100px; height: 100px; object-fit: cover;">
                        `;
                        preview.appendChild(div);
                    };
                    reader.readAsDataURL(file);
                }
            });
        });

        document.getElementById('tireForm').addEventListener('submit', function() {
            const btn = document.getElementById('btnSubmit');
            btn.disabled = true;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Đang lưu...';
        });
    </script>

    <style>
        .tire-position-check {
            margin-bottom: 0;
        }
        .tire-position-check .form-check-input {
            display: none;
        }
        .tire-position-check .tire-badge {
            display: block;
            padding: 12px;
            border: 2px solid #dee2e6;
            border-radius: 10px;
            text-align: center;
            cursor: pointer;
            transition: all 0.2s;
            font-weight: 500;
        }
        .tire-position-check .form-check-input:checked + .form-check-label .tire-badge {
            border-color: #198754;
            background: linear-gradient(135deg, #ecfdf5, #d1fae5);
            color: #166534;
        }
        .tire-position-check .tire-badge:hover {
            border-color: #198754;
            transform: translateY(-2px);
        }
    </style>
}
