@using ChargePoint.CarManagement.Domain.Entities
@using ChargePoint.CarManagement.Domain.ViewModels
@using ChargePoint.CarManagement.Domain.ViewModels.TireViewModels
@model PagedResult<TireIndexViewModel>
@{
    ViewData["Title"] = "Quản lý lốp xe";
    var searchQuery = Model.SearchQuery ?? "";
    var page = Model.PageNumber;
    var pageSize = Model.PageSize;
    var totalCount = Model.TotalCount;
    var totalPages = Model.TotalPages;
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3">
            <i class="fas fa-circle-notch text-primary me-2"></i>
            Quản lý lốp xe
        </h1>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle me-2"></i>
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row mb-3">
        <div class="col-md-10">
            <form asp-action="Index" method="get" class="d-flex" role="search">
                <input name="q" value="@searchQuery" class="form-control me-2" placeholder="Tìm theo biển số, tên xe, VIN, tên khách hàng, màu xe..." aria-label="Search" />
                <button class="btn btn-primary" type="submit">
                    <i class="fas fa-search"></i> Tìm kiếm
                </button>
                @if (!string.IsNullOrWhiteSpace(searchQuery))
                {
                    <a asp-action="Index" class="btn btn-outline-secondary ms-2">
                        <i class="fas fa-times"></i> Xóa lọc
                    </a>
                }
            </form>
        </div>
    </div>

    <div class="card shadow">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <div>
                    @if (!string.IsNullOrWhiteSpace(searchQuery))
                    {
                        <p class="mb-0">
                            <i class="fas fa-filter text-primary me-2"></i>
                            <small class="text-muted">Kết quả tìm kiếm cho: <strong>"@searchQuery"</strong> — <span class="badge bg-info">@totalCount xe</span></small>
                        </p>
                    }
                    else
                    {
                        <p class="mb-0">
                            <i class="fas fa-car text-primary me-2"></i>
                            <small class="text-muted">Tổng số: <span class="badge bg-primary">@totalCount xe</span></small>
                        </p>
                    }
                </div>
                <div class="d-flex align-items-center">
                    <form asp-action="Index" method="get" class="d-inline">
                        <input type="hidden" name="q" value="@searchQuery" />
                        <label class="me-2 mb-0"><small>Hiển thị:</small></label>
                        <select name="pageSize" class="form-select form-select-sm d-inline-block" style="width: auto;"
                                onchange="this.form.submit()">
                            <option value="5" selected="@(pageSize == 5 ? "selected" : null)">5</option>
                            <option value="10" selected="@(pageSize == 10 ? "selected" : null)">10</option>
                            <option value="25" selected="@(pageSize == 25 ? "selected" : null)">25</option>
                            <option value="50" selected="@(pageSize == 50 ? "selected" : null)">50</option>
                        </select>
                    </form>
                </div>
            </div>
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th style="width: 60px;">
                                <i class="fas fa-hashtag text-secondary me-1"></i>
                                STT
                            </th>
                            <th style="width: 150px;">
                                <i class="fas fa-id-card text-warning me-1"></i>
                                Biển số
                            </th>
                            <th style="width: 200px;">
                                <i class="fas fa-car text-primary me-1"></i>
                                Tên xe
                            </th>
                            <th style="width: 120px;">
                                <i class="fas fa-tachometer-alt text-info me-1"></i>
                                ODO (km)
                            </th>
                            <th class="text-center" style="width: 100px;">
                                <i class="fas fa-circle-notch text-dark me-1"></i>
                                Trạng thái lốp
                            </th>
                            <th class="text-center" style="width: 120px;">
                                <i class="fas fa-history text-success me-1"></i>
                                Số lần thay
                            </th>
                            <th class="text-center" style="width: 240px;">
                                <i class="fas fa-tools text-danger me-1"></i>
                                Thao tác
                            </th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Items.Any())
                        {
                            @foreach (var item in Model.Items)
                            {
                                var car = item.Car;
                                var tireRecords = item.TireRecords;
                                var totalRecords = item.TotalRecords;

                                <tr>
                                    <td>
                                        <span class="badge bg-secondary">@car.Stt</span>
                                    </td>
                                    <td>
                                        @if (car.MauBienSo == MauBienSo.Vang)
                                        {
                                            <span class="license-plate license-plate-yellow">
                                                @car.BienSo
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="license-plate license-plate-white">
                                                @car.BienSo
                                            </span>
                                        }
                                    </td>
                                    <td>
                                        <strong>@car.TenXe</strong>
                                        @if (!string.IsNullOrEmpty(car.TenKhachHang))
                                        {
                                            <br />
                                            <small class="text-muted">
                                                <i class="fas fa-user me-1"></i>@car.TenKhachHang
                                            </small>
                                        }
                                    </td>
                                    <td>
                                        <strong class="text-primary">@car.OdoXe.ToString("N0")</strong>
                                    </td>
                                    <td>
                                        <!-- Sơ đồ 4 bánh xe -->
                                        <div class="tire-diagram mx-auto" style="width: 100px;">
                                            <div class="d-flex justify-content-between mb-1">
                                                @{
                                                    var truocTrai = tireRecords?.FirstOrDefault(t => t.ViTri == ViTriLop.TruocTrai);
                                                    var truocPhai = tireRecords?.FirstOrDefault(t => t.ViTri == ViTriLop.TruocPhai);
                                                }
                                                <span class="tire-icon @(truocTrai != null ? "tire-ok" : "tire-empty")" 
                                                      title="Trước trái @(truocTrai != null ? "✓" : "- Chưa có dữ liệu")"
                                                      data-bs-toggle="tooltip">
                                                    <i class="fas fa-circle"></i>
                                                </span>
                                                <span class="tire-icon @(truocPhai != null ? "tire-ok" : "tire-empty")"
                                                      title="Trước phải @(truocPhai != null ? "✓" : "- Chưa có dữ liệu")"
                                                      data-bs-toggle="tooltip">
                                                    <i class="fas fa-circle"></i>
                                                </span>
                                            </div>
                                            <div class="text-center" style="line-height: 1;">
                                                <small class="text-muted" style="font-size: 0.9rem;">🚗</small>
                                            </div>
                                            <div class="d-flex justify-content-between">
                                                @{
                                                    var sauTrai = tireRecords?.FirstOrDefault(t => t.ViTri == ViTriLop.SauTrai);
                                                    var sauPhai = tireRecords?.FirstOrDefault(t => t.ViTri == ViTriLop.SauPhai);
                                                }
                                                <span class="tire-icon @(sauTrai != null ? "tire-ok" : "tire-empty")"
                                                      title="Sau trái @(sauTrai != null ? "✓" : "- Chưa có dữ liệu")"
                                                      data-bs-toggle="tooltip">
                                                    <i class="fas fa-circle"></i>
                                                </span>
                                                <span class="tire-icon @(sauPhai != null ? "tire-ok" : "tire-empty")"
                                                      title="Sau phải @(sauPhai != null ? "✓" : "- Chưa có dữ liệu")"
                                                      data-bs-toggle="tooltip">
                                                    <i class="fas fa-circle"></i>
                                                </span>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="text-center">
                                        @if (totalRecords > 0)
                                        {
                                            <span class="badge bg-info">@totalRecords lần</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Chưa có</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        <div class="btn-group" role="group">
                                            <a asp-action="CarDetail" asp-route-id="@car.Id"
                                               class="btn btn-info" title="Xem chi tiết">
                                                <i class="fas fa-eye"></i> Chi tiết
                                            </a>
                                            <a asp-action="Create" asp-route-id="@car.Id"
                                               class="btn btn-success" title="Thêm hồ sơ lốp">
                                                <i class="fas fa-plus"></i> Thêm
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="7" class="text-center py-4">
                                    <i class="fas fa-inbox fa-3x text-muted mb-3"></i>
                                    <p class="text-muted mb-0">
                                        @if (!string.IsNullOrWhiteSpace(searchQuery))
                                        {
                                            <span>Không tìm thấy xe nào phù hợp với từ khóa "<strong>@searchQuery</strong>"</span>
                                        }
                                        else
                                        {
                                            <span>Chưa có dữ liệu xe</span>
                                        }
                                    </p>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Pagination -->
        @* Debug info *@
        <div class="card-footer bg-light">
            @if (totalPages > 1)
            {
                <nav aria-label="Page navigation">
                    <ul class="pagination justify-content-center mb-0">
                        <!-- Previous -->
                        <li class="page-item @(page <= 1 ? "disabled" : "")">
                            <a class="page-link" asp-action="Index" asp-route-q="@searchQuery" 
                               asp-route-page="@(page - 1)" asp-route-pageSize="@pageSize">
                                <i class="fas fa-chevron-left"></i> Trước
                            </a>
                        </li>

                        @{
                            var startPage = Math.Max(1, page - 2);
                            var endPage = Math.Min(totalPages, page + 2);

                            if (startPage > 1)
                            {
                                <li class="page-item">
                                    <a class="page-link" asp-action="Index" asp-route-q="@searchQuery" 
                                       asp-route-page="1" asp-route-pageSize="@pageSize">1</a>
                                </li>
                                if (startPage > 2)
                                {
                                    <li class="page-item disabled">
                                        <span class="page-link">...</span>
                                    </li>
                                }
                            }

                            for (var i = startPage; i <= endPage; i++)
                            {
                                <li class="page-item @(i == page ? "active" : "")">
                                    <a class="page-link" asp-action="Index" asp-route-q="@searchQuery" 
                                       asp-route-page="@i" asp-route-pageSize="@pageSize">@i</a>
                                </li>
                            }

                            if (endPage < totalPages)
                            {
                                if (endPage < totalPages - 1)
                                {
                                    <li class="page-item disabled">
                                        <span class="page-link">...</span>
                                    </li>
                                }
                                <li class="page-item">
                                    <a class="page-link" asp-action="Index" asp-route-q="@searchQuery" 
                                       asp-route-page="@totalPages" asp-route-pageSize="@pageSize">@totalPages</a>
                                </li>
                            }
                        }

                        <!-- Next -->
                        <li class="page-item @(page >= totalPages ? "disabled" : "")">
                            <a class="page-link" asp-action="Index" asp-route-q="@searchQuery" 
                               asp-route-page="@(page + 1)" asp-route-pageSize="@pageSize">
                                Sau <i class="fas fa-chevron-right"></i>
                            </a>
                        </li>
                    </ul>
                </nav>
            }

            @* Thông tin phân trang - luôn hiển thị *@
            <div class="text-center mt-2">
                <small class="text-muted">
                    @if (totalPages > 1)
                    {
                        <span>Trang <strong>@(page)</strong> / @(totalPages)</span>
                        <span class="mx-2">|</span>
                    }
                    <span>Hiển thị @((page - 1) * pageSize + 1) - @Math.Min(page * pageSize, totalCount) trong tổng số <strong>@(totalCount)</strong> xe</span>
                </small>
            </div>
        </div>
    </div>

    <!-- Chú thích -->
    <div class="card mt-3">
        <div class="card-body py-2">
            <div class="d-flex justify-content-center align-items-center gap-4">
                <small class="text-muted">
                    <strong>Trạng thái lốp:</strong>
                </small>
                <small class="text-muted">
                    <span class="tire-icon tire-ok d-inline"><i class="fas fa-circle"></i></span> Đã có dữ liệu
                </small>
                <small class="text-muted">
                    <span class="tire-icon tire-empty d-inline"><i class="fas fa-circle"></i></span> Chưa có dữ liệu
                </small>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <script>
        // Initialize tooltips
        document.addEventListener('DOMContentLoaded', function() {
            var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
            var tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
                return new bootstrap.Tooltip(tooltipTriggerEl);
            });
        });
    </script>
    <style>
        .tire-icon {
            width: 28px;
            height: 28px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 50%;
            font-size: 20px;
            transition: all 0.2s;
        }
        .tire-icon:hover {
            transform: scale(1.1);
        }
        .tire-ok {
            color: #198754;
        }
        .tire-empty {
            color: #dee2e6;
        }
        .tire-warning {
            color: #ffc107;
        }
        .tire-danger {
            color: #dc3545;
        }
        .tire-diagram {
            padding: 8px;
            border: 1px solid #dee2e6;
            border-radius: 8px;
            background: #f8f9fa;
        }
        .btn-group .btn {
            white-space: nowrap;
        }
        .table th {
            font-weight: 600;
            text-transform: uppercase;
            font-size: 0.85rem;
            background-color: #f8f9fa;
            border-bottom: 2px solid #dee2e6;
        }
        .pagination .page-link {
            border-radius: 4px;
            margin: 0 2px;
        }
        .pagination .page-item.active .page-link {
            background-color: #0d6efd;
            border-color: #0d6efd;
        }
        .table thead th {
            font-weight: 700 !important;
            font-size:      0.9rem !important;
            background-color: #f8f9fa !important;
            border-bottom: 3px solid #dee2e6 !important;
            vertical-align: middle !important;
            padding: 12px 8px !important;
            white-space: nowrap !important;
            color: #212529 !important;
            line-height: 1.5 !important;
        }

        .table thead th i {
            font-size: 0.95rem !important;
            display: inline-block !important;
            margin-right: 6px !important;
            vertical-align: middle !important;
        }
    </style>
}
