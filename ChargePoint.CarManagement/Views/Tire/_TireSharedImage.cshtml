@using ChargePoint.CarManagement.Domain.Models
@inject IOptions<FileUploadSettings> FileUploadSettings

@{
    var settings = FileUploadSettings.Value;
}

<!-- Hình ảnh chứng từ -->
<h5 class="mt-4 mb-3 text-primary">
    <i class="fas fa-images"></i> Hình ảnh chứng từ
</h5>
<div class="form-group mb-3">
    <label class="form-label">
        <i class="fas fa-file-image"></i> Kéo thả, Copy/Paste (Ctrl+V) hoặc click để tải ảnh
    </label>

    <!-- Drag & Drop Zone -->
    <div class="drop-zone" id="dropZone" onclick="document.getElementById('imageInput').click()" title="Click để chọn file hoặc nhấn Ctrl+V để paste">
        <div class="drop-zone-content">
            <i class="fas fa-cloud-upload-alt fa-3x text-primary mb-3"></i>
            <p class="mb-2"><strong>Kéo thả ảnh vào đây</strong></p>
            <p class="text-muted mb-2">hoặc click để chọn file</p>
            <p class="text-muted mb-0"><small>💡 Mẹo: Click vào đây và nhấn <kbd>Ctrl+V</kbd> để paste ảnh</small></p>
        </div>
    </div>

    <input type="file" name="HinhAnhChungTuFiles" class="form-control d-none" multiple
           accept="@string.Join(",", settings.AllowedImageExtensions.Select(e => e))"
           id="imageInput" />
    <small class="form-text text-muted">
        <i class="fas fa-info-circle"></i>
        Có thể chọn nhiều ảnh, kéo thả hoặc paste từ clipboard. Tối đa @settings.MaxImageSizeMB MB mỗi ảnh.
    </small>
    <div id="imagePreview" class="mt-3 d-flex flex-wrap gap-2"></div>
</div>

<!-- Hình ảnh DOT lốp -->
<h5 class="mt-4 mb-3 text-warning">
    <i class="fas fa-calendar-check"></i> Hình ảnh DOT lốp xe
</h5>
<div class="form-group mb-3">
    <label class="form-label">
        <i class="fas fa-barcode"></i> Kéo thả, Copy/Paste (Ctrl+V) hoặc click để tải ảnh DOT
    </label>

    <!-- Drag & Drop Zone for DOT -->
    <div class="drop-zone drop-zone-dot" id="dropZoneDOT" onclick="document.getElementById('dotImageInput').click()" title="Click để chọn file hoặc nhấn Ctrl+V để paste">
        <div class="drop-zone-content">
            <i class="fas fa-calendar-check fa-3x text-warning mb-3"></i>
            <p class="mb-2"><strong>Kéo thả ảnh DOT vào đây</strong></p>
            <p class="text-muted mb-2">hoặc click để chọn file</p>
            <p class="text-muted mb-0"><small>💡 Mẹo: Click vào đây và nhấn <kbd>Ctrl+V</kbd> để paste ảnh DOT</small></p>
        </div>
    </div>

    <input type="file" name="HinhAnhDOTFiles" class="form-control d-none" multiple
           accept="@string.Join(",", settings.AllowedImageExtensions.Select(e => e))"
           id="dotImageInput" />
    <small class="form-text text-muted">
        <i class="fas fa-info-circle me-1"></i>
        Chụp rõ mã DOT 4 số cuối trên thành lốp để kiểm tra tuổi lốp. Tối đa @settings.MaxImageSizeMB MB mỗi ảnh.
    </small>
    <div id="dotImagePreview" class="mt-3 d-flex flex-wrap gap-2"></div>
</div>

<script>
    // DataTransfer để quản lý files
    let imageFilesDataTransfer = new DataTransfer();
    let dotImageFilesDataTransfer = new DataTransfer();

    // Hàm xử lý preview chung
    function previewFiles(files, previewElement, isDOT = false) {
        Array.from(files).forEach((file) => {
            if (file.type.startsWith('image/')) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    const div = document.createElement('div');
                    div.className = 'position-relative preview-item';
                    div.setAttribute('data-filename', file.name);
                    const borderClass = isDOT ? 'border border-warning' : '';
                    const badge = isDOT ? '<span class="badge bg-warning text-dark position-absolute top-0 start-0 m-1">DOT</span>' : '';

                    div.innerHTML = `
                        <img src="${e.target.result}" class="img-thumbnail ${borderClass}" 
                             style="width: 100px; height: 100px; object-fit: cover;">
                        ${badge}
                        <button type="button" class="btn btn-danger btn-sm position-absolute top-0 end-0 m-1 remove-preview-btn" 
                                onclick="removePreview(this, '${file.name}', ${isDOT})" title="Xóa">
                            <i class="fas fa-times"></i>
                        </button>
                    `;
                    previewElement.appendChild(div);
                };
                reader.readAsDataURL(file);
            }
        });
    }

    // Hàm xóa preview
    function removePreview(btn, filename, isDOT) {
        const previewItem = btn.closest('.preview-item');
        previewItem.remove();

        // Xóa file khỏi DataTransfer
        const dataTransfer = isDOT ? dotImageFilesDataTransfer : imageFilesDataTransfer;
        const input = isDOT ? dotImageInput : imageInput;

        const newDataTransfer = new DataTransfer();
        for (let i = 0; i < dataTransfer.files.length; i++) {
            if (dataTransfer.files[i].name !== filename) {
                newDataTransfer.items.add(dataTransfer.files[i]);
            }
        }

        if (isDOT) {
            dotImageFilesDataTransfer = newDataTransfer;
            dotImageInput.files = newDataTransfer.files;
        } else {
            imageFilesDataTransfer = newDataTransfer;
            imageInput.files = newDataTransfer.files;
        }
    }

    // Drag & Drop for Hình ảnh chứng từ
    const dropZone = document.getElementById('dropZone');
    const imageInput = document.getElementById('imageInput');
    const imagePreview = document.getElementById('imagePreview');

    ['dragenter', 'dragover', 'dragleave', 'drop'].forEach(eventName => {
        dropZone.addEventListener(eventName, preventDefaults, false);
    });

    function preventDefaults(e) {
        e.preventDefault();
        e.stopPropagation();
    }

    ['dragenter', 'dragover'].forEach(eventName => {
        dropZone.addEventListener(eventName, () => {
            dropZone.classList.add('drop-zone-active');
        });
    });

    ['dragleave', 'drop'].forEach(eventName => {
        dropZone.addEventListener(eventName, () => {
            dropZone.classList.remove('drop-zone-active');
        });
    });

    dropZone.addEventListener('drop', (e) => {
        const dt = e.dataTransfer;
        const newFiles = dt.files;

        // Thêm files mới vào DataTransfer
        Array.from(newFiles).forEach(file => {
            if (file.type.startsWith('image/')) {
                imageFilesDataTransfer.items.add(file);
            }
        });

        imageInput.files = imageFilesDataTransfer.files;
        previewFiles(newFiles, imagePreview, false);

        // Prevent click event after drop
        setTimeout(() => dropZone.classList.add('drop-processed'), 10);
        setTimeout(() => dropZone.classList.remove('drop-processed'), 100);
    });

    // Prevent click when dropping
    dropZone.addEventListener('click', (e) => {
        if (dropZone.classList.contains('drop-processed')) {
            e.stopPropagation();
            e.preventDefault();
        }
    });

    imageInput.addEventListener('change', function(e) {
        const newFiles = this.files;

        // Thêm files mới vào DataTransfer
        Array.from(newFiles).forEach(file => {
            if (file.type.startsWith('image/')) {
                imageFilesDataTransfer.items.add(file);
            }
        });

        imageInput.files = imageFilesDataTransfer.files;
        previewFiles(newFiles, imagePreview, false);
    });

    // Drag & Drop for Hình ảnh DOT
    const dropZoneDOT = document.getElementById('dropZoneDOT');
    const dotImageInput = document.getElementById('dotImageInput');
    const dotImagePreview = document.getElementById('dotImagePreview');

    ['dragenter', 'dragover', 'dragleave', 'drop'].forEach(eventName => {
        dropZoneDOT.addEventListener(eventName, preventDefaults, false);
    });

    ['dragenter', 'dragover'].forEach(eventName => {
        dropZoneDOT.addEventListener(eventName, () => {
            dropZoneDOT.classList.add('drop-zone-active');
        });
    });

    ['dragleave', 'drop'].forEach(eventName => {
        dropZoneDOT.addEventListener(eventName, () => {
            dropZoneDOT.classList.remove('drop-zone-active');
        });
    });

    dropZoneDOT.addEventListener('drop', (e) => {
        const dt = e.dataTransfer;
        const newFiles = dt.files;

        // Thêm files mới vào DataTransfer
        Array.from(newFiles).forEach(file => {
            if (file.type.startsWith('image/')) {
                dotImageFilesDataTransfer.items.add(file);
            }
        });

        dotImageInput.files = dotImageFilesDataTransfer.files;
        previewFiles(newFiles, dotImagePreview, true);

        // Prevent click event after drop
        setTimeout(() => dropZoneDOT.classList.add('drop-processed'), 10);
        setTimeout(() => dropZoneDOT.classList.remove('drop-processed'), 100);
    });

    // Prevent click when dropping
    dropZoneDOT.addEventListener('click', (e) => {
        if (dropZoneDOT.classList.contains('drop-processed')) {
            e.stopPropagation();
            e.preventDefault();
        }
    });

    dotImageInput.addEventListener('change', function(e) {
        const newFiles = this.files;

        // Thêm files mới vào DataTransfer
        Array.from(newFiles).forEach(file => {
            if (file.type.startsWith('image/')) {
                dotImageFilesDataTransfer.items.add(file);
            }
        });

        dotImageInput.files = dotImageFilesDataTransfer.files;
        previewFiles(newFiles, dotImagePreview, true);
    });

    // ===== PASTE FUNCTIONALITY =====
    // Hàm xử lý paste từ clipboard
    function handlePaste(e, isDOT = false) {
        const items = (e.clipboardData || e.originalEvent.clipboardData).items;
        const dataTransfer = isDOT ? dotImageFilesDataTransfer : imageFilesDataTransfer;
        const input = isDOT ? dotImageInput : imageInput;
        const preview = isDOT ? dotImagePreview : imagePreview;

        for (let i = 0; i < items.length; i++) {
            if (items[i].type.indexOf('image') !== -1) {
                const blob = items[i].getAsFile();

                // Tạo tên file với timestamp
                const timestamp = new Date().getTime();
                const fileName = `pasted-image-${timestamp}.png`;

                // Tạo File object mới với tên
                const file = new File([blob], fileName, { type: blob.type });

                // Thêm vào DataTransfer
                dataTransfer.items.add(file);

                // Cập nhật input files
                input.files = dataTransfer.files;

                // Preview file
                previewFiles([file], preview, isDOT);

                e.preventDefault();
            }
        }
    }

    // Paste listener cho toàn bộ trang (để paste ảnh chứng từ)
    document.addEventListener('paste', function(e) {
        // Kiểm tra xem có đang focus vào input text nào không
        const activeElement = document.activeElement;
        if (activeElement.tagName === 'INPUT' && activeElement.type === 'text' ||
            activeElement.tagName === 'TEXTAREA') {
            return; // Không xử lý paste nếu đang ở input text
        }

        // Kiểm tra xem có đang paste vào DOT zone không
        if (activeElement === dropZoneDOT || dropZoneDOT.contains(activeElement)) {
            return; // Không xử lý ở đây, để DOT zone tự xử lý
        }

        // Nếu đang focus vào dropZone chứng từ, cũng bỏ qua (để nó tự xử lý)
        if (activeElement === dropZone || dropZone.contains(activeElement)) {
            return;
        }

        // Paste vào bất kỳ đâu khác trên trang -> paste vào chứng từ
        handlePaste(e, false);
    });

    // Paste listener riêng cho dropZone chứng từ
    dropZone.addEventListener('paste', function(e) {
        e.stopPropagation(); // Ngăn sự kiện bubble lên document
        handlePaste(e, false);
    });

    // Paste listener riêng cho DOT zone
    dropZoneDOT.addEventListener('paste', function(e) {
        e.stopPropagation(); // Ngăn sự kiện bubble lên document
        handlePaste(e, true);
    });

    // Cho phép focus vào dropZone
    dropZone.setAttribute('tabindex', '0');

    // Cho phép focus vào dropZoneDOT
    dropZoneDOT.setAttribute('tabindex', '0');

    // Hiển thị hint khi focus vào dropZone chứng từ
    dropZone.addEventListener('focus', function() {
        this.style.borderColor = '#0d6efd';
        this.style.boxShadow = '0 0 0 0.25rem rgba(13, 110, 253, 0.25)';
    });

    dropZone.addEventListener('blur', function() {
        this.style.borderColor = '';
        this.style.boxShadow = '';
    });

    // Hiển thị hint khi focus vào DOT zone
    dropZoneDOT.addEventListener('focus', function() {
        this.style.borderColor = '#ffc107';
        this.style.boxShadow = '0 0 0 0.25rem rgba(255, 193, 7, 0.25)';
    });

    dropZoneDOT.addEventListener('blur', function() {
        this.style.borderColor = '';
        this.style.boxShadow = '';
    });
</script>

<style>
    /* Drop Zone Styles */
    .drop-zone {
        border: 3px dashed #0d6efd;
        border-radius: 12px;
        padding: 40px;
        text-align: center;
        cursor: pointer;
        transition: all 0.3s ease;
        background-color: #f8f9fa;
        margin-bottom: 15px;
        outline: none;
    }

    .drop-zone:hover {
        border-color: #0b5ed7;
        background-color: #e7f1ff;
        transform: scale(1.01);
    }

    .drop-zone:focus {
        border-color: #0d6efd;
        background-color: #e7f1ff;
    }

    .drop-zone-active {
        border-color: #198754;
        background-color: #d1e7dd;
        transform: scale(1.02);
    }

    .drop-zone-dot {
        border-color: #ffc107;
    }

    .drop-zone-dot:hover {
        border-color: #ffca2c;
        background-color: #fff3cd;
    }

    .drop-zone-dot:focus {
        border-color: #ffc107;
        background-color: #fff3cd;
    }

    .drop-zone-dot.drop-zone-active {
        border-color: #fd7e14;
        background-color: #ffe5d0;
    }

    /* Preview Item Styles */
    .preview-item {
        position: relative;
        transition: all 0.2s;
    }

    .preview-item:hover {
        transform: scale(1.05);
    }

    .preview-item .remove-preview-btn {
        padding: 0.25rem 0.5rem;
        font-size: 0.75rem;
        border-radius: 50%;
        width: 24px;
        height: 24px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .preview-item .remove-preview-btn:hover {
        transform: scale(1.1);
    }

    /* Tire position badges */
    .tire-position-check {
        margin-bottom: 10px;
    }

    .tire-badge {
        display: inline-block;
        padding: 10px 15px;
        border: 2px solid #dee2e6;
        border-radius: 8px;
        background-color: #f8f9fa;
        transition: all 0.2s;
        cursor: pointer;
        width: 100%;
        text-align: center;
    }

    .form-check-input:checked ~ .form-check-label .tire-badge {
        background-color: #0d6efd;
        color: white;
        border-color: #0d6efd;
        font-weight: bold;
    }

    .tire-badge:hover {
        background-color: #e9ecef;
        border-color: #adb5bd;
    }

    kbd {
        background-color: #212529;
        color: #fff;
        padding: 2px 6px;
        border-radius: 3px;
        font-size: 0.85em;
        font-family: monospace;
    }
</style>
