@model ChargePoint.CarManagement.Models.ViewModels.SystemSettingIndexVM

@{
    ViewData["Title"] = "Cài đặt hệ thống";
}

<div class="container pb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3">
            <i class="fas fa-cogs text-primary me-2"></i> Thiết lập hệ thống
        </h1>
    </div>

    <div class="card shadow border-0">
        <div class="card-header bg-dark text-white">
            <h5 class="mb-0"><i class="fas fa-sliders-h me-2"></i>Cấu hình nâng cao</h5>
        </div>
        <div class="card-body">
            <form asp-controller="Settings" asp-action="Save" method="post">
                @foreach (var setting in Model.Settings)
                {
                    <div class="row align-items-center mb-3 p-3 bg-light rounded shadow-sm mx-0">
                        <div class="col-md-9 mb-2 mb-md-0">
                            <strong>@setting.Description</strong>
                            <small class="d-block text-muted mt-1">
                                <code>Mã: @setting.Key</code>
                            </small>
                        </div>
                        <div class="col-md-3 text-md-end text-start">
                            @if (setting.Type == "boolean")
                            {
                                <div class="form-check form-switch form-switch-lg d-inline-block"
                                     title="@setting.DisabledReason">
                                    <input type="hidden" name="settings[@setting.Key]" value="false" />
                                    <!-- Using value="true" to send "true" if checked -->
                                    <input class="form-check-input" type="checkbox" role="switch"
                                           id="switch_@setting.Key" 
                                           name="settings[@setting.Key]" 
                                           value="true"
                                           @(setting.Value == "true" ? "checked" : "") 
                                           @(setting.IsDisabled ? "disabled" : "")
                                           style="cursor:@(setting.IsDisabled ? "not-allowed" : "pointer");" />
                                </div>
                            }
                            else if (setting.Type == "number")
                            {
                                <input type="number" class="form-control" name="settings[@setting.Key]" value="@setting.Value" />
                            }
                            else
                            {
                                <input type="text" class="form-control" name="settings[@setting.Key]" value="@setting.Value" />
                            }
                        </div>
                    </div>
                }

                <div class="text-end mt-4">
                    <button type="submit" class="btn btn-primary px-4 py-2">
                        <i class="fas fa-save me-2"></i> Lưu thay đổi
                    </button>
                    <a asp-controller="Home" asp-action="Index" class="btn btn-secondary px-4 py-2">
                        <i class="fas fa-times me-2"></i> Hủy
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <style>
        .form-switch-lg .form-check-input {
            width: 3em;
            height: 1.5em;
        }
    </style>
}
