@model ChargePoint.CarManagement.Models.SystemLogIndexViewModel
@{
    ViewData["Title"] = "System Logs";
    var levels = new[] { "", "Information", "Warning", "Error" };
    const int sourceMaxLength = 20;
    const int messageMaxLength = 100;
    const int userMaxLength = 18;
    const int traceIdMaxLength = 16;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0"><i class="fas fa-file-lines me-2"></i>System Logs</h2>
    <span class="badge bg-primary">@Model.TotalCount bản ghi</span>
</div>

<div class="card mb-3">
    <div class="card-body">
        <form method="get" class="row g-2">
            <div class="col-md-3">
                <input type="text" name="q" value="@Model.Q" class="form-control" placeholder="Tìm theo message, user, detail..." />
            </div>
            <div class="col-md-2">
                <select name="level" class="form-select">
                    @foreach (var level in levels)
                    {
                        if (Model.Level == level)
                        {
                            <option value="@level" selected>@(string.IsNullOrEmpty(level) ? "All Levels" : level)</option>
                        }
                        else
                        {
                            <option value="@level">@(string.IsNullOrEmpty(level) ? "All Levels" : level)</option>
                        }
                    }
                </select>
            </div>
            <div class="col-md-2">
                <input type="date" name="fromDate" value="@(Model.FromDate?.ToString("yyyy-MM-dd"))" class="form-control" />
            </div>
            <div class="col-md-2">
                <input type="date" name="toDate" value="@(Model.ToDate?.ToString("yyyy-MM-dd"))" class="form-control" />
            </div>
            <div class="col-md-1">
                <select name="pageSize" class="form-select">
                    @foreach (var size in new[] { 20, 50, 100, 200 })
                    {
                        if (Model.PageSize == size)
                        {
                            <option value="@size" selected>@size / trang</option>
                        }
                        else
                        {
                            <option value="@size">@size / trang</option>
                        }
                    }
                </select>
            </div>
            <div class="col-md-2 d-grid">
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-search me-1"></i>Tìm
                </button>
            </div>
        </form>
    </div>
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0 align-middle">
                <thead>
                    <tr>
                        <th style="width: 180px;">Thời gian (UTC)</th>
                        <th style="width: 120px;">Level</th>
                        <th style="width: 140px;">Nguồn</th>
                        <th>Nội dung</th>
                        <th style="width: 140px;">User</th>
                        <th style="width: 180px;">TraceId</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Items.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center py-4 text-muted">Không có log phù hợp.</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var item in Model.Items)
                        {
                            var levelText = string.IsNullOrWhiteSpace(item.Level) ? "Information" : item.Level;
                            var badgeClass = levelText.ToLowerInvariant() switch
                            {
                                "error" => "bg-danger",
                                "warning" => "bg-warning text-dark",
                                _ => "bg-info text-dark"
                            };

                            <tr>
                                <td>@item.TimestampUtc.ToString("yyyy-MM-dd HH:mm:ss")</td>
                                <td><span class="badge @badgeClass">@levelText</span></td>
                                <td>
                                    @if (!string.IsNullOrWhiteSpace(item.Source) && item.Source.Length > sourceMaxLength)
                                    {
                                        <span title="@item.Source" data-bs-toggle="tooltip">
                                            @item.Source.Substring(0, sourceMaxLength)...
                                        </span>
                                    }
                                    else
                                    {
                                        @item.Source
                                    }
                                </td>
                                <td>
                                    @if (!string.IsNullOrWhiteSpace(item.Message) && item.Message.Length > messageMaxLength)
                                    {
                                        <div class="fw-semibold" title="@item.Message" data-bs-toggle="tooltip">
                                            @item.Message.Substring(0, messageMaxLength)...
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="fw-semibold">@item.Message</div>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(item.Detail))
                                    {
                                        <details>
                                            <summary class="text-danger small">Chi tiết lỗi</summary>
                                            <pre class="small mb-0 text-danger">@item.Detail</pre>
                                        </details>
                                    }
                                </td>
                                <td>
                                    @if (!string.IsNullOrWhiteSpace(item.UserName) && item.UserName.Length > userMaxLength)
                                    {
                                        <span title="@item.UserName" data-bs-toggle="tooltip">
                                            @item.UserName.Substring(0, userMaxLength)...
                                        </span>
                                    }
                                    else
                                    {
                                        @item.UserName
                                    }
                                </td>
                                <td>
                                    @if (!string.IsNullOrWhiteSpace(item.TraceId) && item.TraceId.Length > traceIdMaxLength)
                                    {
                                        <code title="@item.TraceId" data-bs-toggle="tooltip">@item.TraceId.Substring(0, traceIdMaxLength)...</code>
                                    }
                                    else
                                    {
                                        <code>@item.TraceId</code>
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@if (Model.TotalPages > 1)
{
    <nav class="mt-3" aria-label="Log pagination">
        <ul class="pagination">
            <li class="page-item @(Model.Page <= 1 ? "disabled" : "")">
                <a class="page-link" asp-action="Index" asp-route-q="@Model.Q" asp-route-level="@Model.Level" asp-route-fromDate="@(Model.FromDate?.ToString("yyyy-MM-dd"))" asp-route-toDate="@(Model.ToDate?.ToString("yyyy-MM-dd"))" asp-route-page="@(Model.Page - 1)" asp-route-pageSize="@Model.PageSize">Trước</a>
            </li>
            <li class="page-item disabled">
                <span class="page-link">Trang @Model.Page / @Model.TotalPages</span>
            </li>
            <li class="page-item @(Model.Page >= Model.TotalPages ? "disabled" : "")">
                <a class="page-link" asp-action="Index" asp-route-q="@Model.Q" asp-route-level="@Model.Level" asp-route-fromDate="@(Model.FromDate?.ToString("yyyy-MM-dd"))" asp-route-toDate="@(Model.ToDate?.ToString("yyyy-MM-dd"))" asp-route-page="@(Model.Page + 1)" asp-route-pageSize="@Model.PageSize">Sau</a>
            </li>
        </ul>
    </nav>
}
