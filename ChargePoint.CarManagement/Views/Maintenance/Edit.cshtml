@model ChargePoint.CarManagement.Models.ViewModels.MaintenanceViewModels.MaintenanceEditVM
@inject IOptions<ChargePoint.CarManagement.Models.FileUploadSettings> FileUploadSettings

@{
    ViewData["Title"] = "Chỉnh sửa hồ sơ bảo dưỡng";
    var car = Model.Car;
    var maintenance = Model.Record!;
}


<div class="container">
    <h1 class="mb-4">
        <i class="fas fa-edit text-warning"></i> Chỉnh sửa hồ sơ bảo dưỡng
    </h1>

    @if (car != null)
    {
        <div class="alert alert-info">
            <i class="fas fa-car me-2"></i>
            <strong>Xe:</strong> @car.TenXe -
            <strong>Biển số:</strong>
            @if (car.MauBienSo == MauBienSo.Vang)
            {
                <span class="badge" style="background-color: #ffc107; color: #000; border: 1px solid #333;">@car.BienSo</span>
            }
            else
            {
                <span class="badge" style="background-color: #fff; color: #000; border: 1px solid #333;">@car.BienSo</span>
            }
            - <strong>ODO hiện tại:</strong> @car.OdoXe.ToString("N0") km
        </div>
    }

    <div class="card shadow">
        <div class="card-body">
            <form asp-action="Edit" method="post" enctype="multipart/form-data" id="maintenanceEditForm">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
                <input type="hidden" asp-for="@maintenance.Id" />
                <input type="hidden" asp-for="@maintenance.CarId" />
                <input type="hidden" asp-for="@maintenance.NgayTao" />
                <input type="hidden" asp-for="@maintenance.NguoiTao" />
                <input type="hidden" asp-for="@maintenance.HinhAnhChungTu" />

                 <!-- Dropdown chọn loại hồ sơ: label, icon, select ngang hàng đẹp -->
                @await Html.PartialAsync("_LoaiHoSoDropdown", Model.Record.LoaiHoSo
                , new ViewDataDictionary(ViewData) {
                    { "DropdownId", "LoaiHoSoEdit" },
                                { "DropdownName", "maintenance.LoaiHoSo" },
                    { "IconId", "LoaiHoSoIconEdit" }
                })

                <!-- Thêm lại hai trường Ngày bảo dưỡng và Số KM lúc bảo dưỡng -->
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="@maintenance.NgayBaoDuong" class="form-label" id="labelNgayBaoDuongEdit"></label>
                        <input asp-for="@maintenance.NgayBaoDuong" class="form-control" type="date" />
                        <span asp-validation-for="@maintenance.NgayBaoDuong" class="text-danger"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="@maintenance.SoKmBaoDuong" class="form-label" id="labelSoKmBaoDuongEdit"></label>
                        <div class="input-group">
                            <input asp-for="@maintenance.SoKmBaoDuong" class="form-control" type="number" id="soKmBaoDuongEdit" />
                            <span class="input-group-text">km</span>
                        </div>
                        <span asp-validation-for="@maintenance.SoKmBaoDuong" class="text-danger"></span>
                    </div>
                </div>

                <div class="row" id="capBaoDuongRow">
                    <div class="col-md-6 mb-3">
                        <label asp-for="@maintenance.CapBaoDuong" class="form-label" id="labelCapBaoDuong"></label>
                        <div class="d-flex gap-3 mt-2">
                            @foreach (CapBaoDuong cap in Enum.GetValues(typeof(CapBaoDuong)))
                            {
                                var badgeClass = cap switch
                                {
                                    CapBaoDuong.Cap1 => "bg-info",
                                    CapBaoDuong.Cap2 => "bg-primary",
                                    CapBaoDuong.Cap3 => "bg-success",
                                    _ => "bg-secondary"
                                };
                                <div class="form-check">
                                    <input class="form-check-input" type="radio"
                                           name="maintenance.CapBaoDuong" id="cap@((int)cap)"
                                           value="@((int)cap)"
                                           @(maintenance.CapBaoDuong == cap ? "checked" : "") />
                                    <label class="form-check-label" for="cap@((int)cap)">
                                        <span class="badge @badgeClass fs-6 py-2 px-3">
                                            Cấp @((int)cap)
                                        </span>
                                    </label>
                                </div>
                            }
                        </div>
                        <small class="form-text text-muted mt-2 d-block">
                            <strong>Cấp 1:</strong> Thay dầu, lọc gió |
                            <strong>Cấp 2:</strong> + Phanh, lốp |
                            <strong>Cấp 3:</strong> + Toàn diện
                        </small>
                        <span asp-validation-for="@maintenance.CapBaoDuong" class="text-danger"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="@maintenance.ChiPhi" class="form-label"></label>
                        <div class="input-group">
                            <input asp-for="@maintenance.ChiPhi" class="form-control" type="number" />
                            <span class="input-group-text">VNĐ</span>
                        </div>
                        <span asp-validation-for="@maintenance.ChiPhi" class="text-danger"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="@maintenance.SoKmBaoDuongTiepTheo" class="form-label"></label>
                        <div class="input-group">
                            <input asp-for="@maintenance.SoKmBaoDuongTiepTheo" class="form-control" id="soKmBaoDuongTiepTheo" />
                            <span class="input-group-text">km</span>
                        </div>
                        <small class="form-text text-muted"><i class="fas fa-lightbulb"></i> Gợi ý: Số KM bảo dưỡng + 15,000 km (có thể chỉnh sửa)</small>
                        <span asp-validation-for="@maintenance.SoKmBaoDuongTiepTheo" class="text-danger"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="@maintenance.NoiBaoDuong" class="form-label"></label>
                        <input asp-for="@maintenance.NoiBaoDuong" class="form-control" />
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="@maintenance.NoiDungBaoDuong" class="form-label" id="labelNoiDungEdit"></label>
                    <textarea asp-for="@maintenance.NoiDungBaoDuong" class="form-control" rows="3"></textarea>
                </div>

                <div class="mb-3">
                    <label asp-for="@maintenance.GhiChu" class="form-label"></label>
                    <textarea asp-for="@maintenance.GhiChu" class="form-control" rows="2"></textarea>
                </div>

                <!-- Shared Image Upload Partial -->
                <partial name="_MaintenanceImagePartial" model='new { Record = Model.Record }' />

                <div class="d-flex justify-content-between mt-4">
                    <a asp-action="History" asp-route-id="@maintenance.CarId" class="btn btn-secondary">
                        <i class="fas fa-arrow-left"></i> Quay lại
                    </a>
                    <button type="submit" class="btn btn-success" id="btnSubmit">
                        <i class="fas fa-save"></i> Lưu thay đổi
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        // Submit button loading state
        document.getElementById('maintenanceEditForm').addEventListener('submit', function() {
            const btn = document.getElementById('btnSubmit');
            btn.disabled = true;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Đang lưu...';
        });
    </script>
}
