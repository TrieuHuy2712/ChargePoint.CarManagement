@model List<ChargePoint.CarManagement.Models.ViewModels.MaintenanceViewModels.MaintenanceIndexViewModel>
@{
    ViewData["Title"] = "Quản lý bảo dưỡng";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3">
            <i class="fas fa-tools text-warning me-2"></i>
            Quản lý bảo dưỡng xe
        </h1>
    </div>

    <div class="card shadow">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-dark">
                        <tr>
                            <th>STT</th>
                            <th>Biển số</th>
                            <th>Tên xe</th>
                            <th>ODO hiện tại</th>
                            <th>Bảo dưỡng gần nhất</th>
                            <th>Cấp bảo dưỡng</th>
                            <th>Kỳ tiếp theo</th>
                            <th>Số lần BD</th>
                            <th class="text-center">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            var car = item.Car;
                            var lastMaintenance = item.LastMaintenance;
                            var totalMaintenances = item.TotalMaintenances;

                            // Kiểm tra sắp đến hạn bảo dưỡng
                            var isOverdue = lastMaintenance?.NgayBaoDuongTiepTheo != null
                                && ((DateTime)lastMaintenance.NgayBaoDuongTiepTheo) < DateTime.Now;
                            var isNearDue = lastMaintenance?.NgayBaoDuongTiepTheo != null
                                && ((DateTime)lastMaintenance.NgayBaoDuongTiepTheo) <= DateTime.Now.AddDays(7)
                                && ((DateTime)lastMaintenance.NgayBaoDuongTiepTheo) >= DateTime.Now;

                            <tr class="@(isOverdue ? "table-danger" : isNearDue ? "table-warning" : "")">
                                <td>@car.Stt</td>
                                <td>
                                    @if (car.MauBienSo == MauBienSo.Vang)
                                    {
                                        <span class="badge" style="background-color: #ffc107; color: #000; border: 1px solid #333; padding: 6px 12px;">
                                            @car.BienSo
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge" style="background-color: #fff; color: #000; border: 1px solid #333; padding: 6px 12px;">
                                            @car.BienSo
                                        </span>
                                    }
                                </td>
                                <td>@car.TenXe</td>
                                <td><strong>@car.OdoXe.ToString("N0")</strong> km</td>
                                <td>
                                    @if (lastMaintenance != null)
                                    {
                                        <span>@(((DateTime)lastMaintenance.NgayBaoDuong).ToString("dd/MM/yyyy"))</span>
                                        <br />
                                        <small class="text-muted">@(((int)lastMaintenance.SoKmBaoDuong).ToString("N0")) km</small>
                                    }
                                    else
                                    {
                                        <span class="text-muted">Chưa bảo dưỡng</span>
                                    }
                                </td>
                                <td>
                                    @if (lastMaintenance != null)
                                    {
                                        var cap = (CapBaoDuong)lastMaintenance.CapBaoDuong;
                                        var badgeClass = cap switch
                                        {
                                            CapBaoDuong.Cap1 => "bg-info",
                                            CapBaoDuong.Cap2 => "bg-primary",
                                            CapBaoDuong.Cap3 => "bg-success",
                                            _ => "bg-secondary"
                                        };
                                        <span class="badge @badgeClass">Cấp @((int)cap)</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">-</span>
                                    }
                                </td>
                                <td>
                                    @if (lastMaintenance?.NgayBaoDuongTiepTheo != null)
                                    {
                                        var nextDate = (DateTime)lastMaintenance.NgayBaoDuongTiepTheo;
                                        <span class="@(isOverdue ? "text-danger fw-bold" : isNearDue ? "text-warning fw-bold" : "")">
                                            @nextDate.ToString("dd/MM/yyyy")
                                        </span>
                                        @if (isOverdue)
                                        {
                                            <br /><small class="text-danger"><i class="fas fa-exclamation-triangle"></i> Quá hạn!</small>
                                        }
                                        else if (isNearDue)
                                        {
                                            <br /><small class="text-warning"><i class="fas fa-clock"></i> Sắp đến hạn</small>
                                        }
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                <td>
                                    <span class="badge bg-secondary">@totalMaintenances</span>
                                </td>
                                <td class="text-center">
                                    <div class="btn-group" role="group">
                                        <a asp-action="Create" asp-route-id="@car.Id"
                                           class="btn btn-success btn-sm" title="Thêm bảo dưỡng">
                                            <i class="fas fa-plus"></i> Thêm
                                        </a>
                                        <a asp-action="History" asp-route-id="@car.Id"
                                           class="btn btn-info btn-sm" title="Xem lịch sử">
                                            <i class="fas fa-history"></i> Lịch sử
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Chú thích màu -->
    <div class="mt-3">
        <small class="text-muted me-4">
            <span class="badge bg-danger">&nbsp;</span> Quá hạn bảo dưỡng
        </small>
        <small class="text-muted">
            <span class="badge bg-warning">&nbsp;</span> Sắp đến hạn (trong 7 ngày)
        </small>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
}
