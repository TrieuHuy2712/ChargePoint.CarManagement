@using ChargePoint.CarManagement.Domain.Entities
@using ChargePoint.CarManagement.Domain.Enums
@using ChargePoint.CarManagement.Domain.ViewModels
@using ChargePoint.CarManagement.Domain.ViewModels.MaintenanceViewModels
@model PagedResult<MaintenanceIndexViewModel>
@{
    ViewData["Title"] = "Quản lý bảo dưỡng";
    var searchQuery = Model.SearchQuery ?? "";
    var page = Model.PageNumber;
    var pageSize = Model.PageSize;
    var totalCount = Model.TotalCount;
    var totalPages = Model.TotalPages;
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3">
            <i class="fas fa-tools text-warning me-2"></i>
            Quản lý bảo dưỡng xe
        </h1>
    </div>
    <div class="row mb-3">
        <div class="col-md-8">
            <form asp-action="Index" method="get" class="d-flex" role="search">
                <input name="q" value="@searchQuery" class="form-control me-2" placeholder="Tìm theo biển số, tên xe, VIN, khách hàng, màu..." aria-label="Search" />
                <button class="btn btn-outline-primary" type="submit">
                    <i class="fas fa-search"></i> Tìm
                </button>
                @if (!string.IsNullOrWhiteSpace(searchQuery))
                {
                    <a asp-action="Index" class="btn btn-outline-secondary ms-2">
                        <i class="fas fa-times"></i> Xóa
                    </a>
                }
            </form>
        </div>
    </div>

    <div class="card shadow">
        <div class="card-body">
            <div class="d-flex justify-content-between mb-2">
                <div>
                    @if (!string.IsNullOrWhiteSpace(searchQuery))
                    {
                        <small class="text-muted">Kết quả tìm kiếm cho: <strong>@searchQuery</strong> — @totalCount kết quả</small>
                    }
                    else
                    {
                        <small class="text-muted">@totalCount xe</small>
                    }
                </div>
                <div>
                    <form asp-action="Index" method="get" class="d-inline">
                        <input type="hidden" name="q" value="@searchQuery" />
                        <label class="me-2">Hiển thị</label>
                        <select name="pageSize" class="form-select d-inline-block" style="width: auto;"
                                onchange="this.form.submit()">
                            <option value="5" selected="@(pageSize == 5 ? "selected" : null)">5</option>
                            <option value="10" selected="@(pageSize == 10 ? "selected" : null)">10</option>
                            <option value="25" selected="@(pageSize == 25 ? "selected" : null)">25</option>
                            <option value="50" selected="@(pageSize == 50 ? "selected" : null)">50</option>
                        </select>
                    </form>
                </div>
            </div>
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-dark">
                        <tr>
                            <th>STT</th>
                            <th>Biển số</th>
                            <th>Tên xe</th>
                            <th>ODO hiện tại</th>
                            <th>Bảo dưỡng gần nhất</th>
                            <th>Cấp bảo dưỡng</th>
                            <th>ODO BD tiếp theo</th>
                            <th>Trạng thái</th>
                            <th>Số lần BD</th>
                            <th class="text-center">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            var car = item.Car;
                            var lastMaintenance = item.LastMaintenance;
                            var totalMaintenances = item.TotalMaintenances;

                            // Lấy ODO BD tiếp theo từ record đã lưu
                            int? nextMaintenanceOdo = lastMaintenance?.SoKmBaoDuongTiepTheo;

                            var kmRemaining = nextMaintenanceOdo.HasValue 
                                ? nextMaintenanceOdo.Value - car.OdoXe 
                                : (int?)null;

                            var isOverdue = kmRemaining.HasValue && kmRemaining.Value <= 0;
                            var isUrgent = kmRemaining.HasValue && kmRemaining.Value > 0 && kmRemaining.Value <= 1000;
                            var isWarning = kmRemaining.HasValue && kmRemaining.Value > 1000 && kmRemaining.Value <= 2000;

                            var rowClass = isOverdue ? "table-danger" : isUrgent ? "table-danger" : isWarning ? "table-warning" : "";

                            <tr class="@rowClass">
                                <td>@car.Stt</td>
                                <td>
                                    @if (car.MauBienSo == MauBienSo.Vang)
                                    {
                                        <span class="license-plate license-plate-yellow">
                                            @car.BienSo
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="license-plate license-plate-white">
                                            @car.BienSo
                                        </span>
                                    }
                                </td>
                                <td>@car.TenXe</td>
                                <td><strong>@car.OdoXe.ToString("N0")</strong></td>
                                <td>
                                    @if (lastMaintenance != null)
                                    {
                                        <span>@(((DateTime)lastMaintenance.NgayBaoDuong).ToString("dd/MM/yyyy"))</span>
                                        <br />
                                        <small class="text-muted">@(((int)lastMaintenance.SoKmBaoDuong).ToString("N0")) km</small>
                                    }
                                    else
                                    {
                                        <span class="text-muted">Chưa bảo dưỡng</span>
                                    }
                                </td>
                                <td>
                                    @if (lastMaintenance != null && lastMaintenance.CapBaoDuong.HasValue)
                                    {
                                        var cap = (MaintenanceLevel)lastMaintenance.CapBaoDuong;
                                        var badgeClass = cap switch
                                        {
                                            MaintenanceLevel.Cap1 => "bg-info",
                                            MaintenanceLevel.Cap2 => "bg-primary",
                                            MaintenanceLevel.Cap3 => "bg-success",
                                            _ => "bg-secondary"
                                        };
                                        <span class="badge @badgeClass">Cấp @((int)cap)</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">-</span>
                                    }
                                </td>
                                <td>
                                    @if (nextMaintenanceOdo.HasValue)
                                    {
                                        <strong>@nextMaintenanceOdo.Value.ToString("N0")</strong>
                                        <span class="text-muted"> km</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                <td>
                                    @if (kmRemaining.HasValue)
                                    {
                                        if (isOverdue)
                                        {
                                            <span class="badge bg-danger">
                                                <i class="fas fa-exclamation-triangle"></i> Quá hạn @Math.Abs(kmRemaining.Value).ToString("N0") km
                                            </span>
                                        }
                                        else if (isUrgent)
                                        {
                                            <span class="badge bg-danger">
                                                <i class="fas fa-exclamation-circle"></i> Còn @kmRemaining.Value.ToString("N0") km
                                            </span>
                                        }
                                        else if (isWarning)
                                        {
                                            <span class="badge bg-warning text-dark">
                                                <i class="fas fa-clock"></i> Còn @kmRemaining.Value.ToString("N0") km
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success">
                                                <i class="fas fa-check-circle"></i> Còn @kmRemaining.Value.ToString("N0") km
                                            </span>
                                        }
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Chưa bảo dưỡng</span>
                                    }
                                </td>
                                <td>
                                    <span class="badge bg-secondary">@totalMaintenances</span>
                                </td>
                                <td class="text-center">
                                    <div class="d-flex gap-2" role="group">
                                        <a asp-action="Create" asp-route-id="@car.Id"
                                           class="btn btn-success" title="Thêm bảo dưỡng">
                                            <i class="fas fa-plus"></i> Thêm
                                        </a>
                                        <a asp-action="History" asp-route-id="@car.Id"
                                           class="btn btn-info" title="Xem lịch sử">
                                            <i class="fas fa-history"></i> Lịch sử
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @* Empty state *@
            @if (!Model.Items.Any())
            {
                <div class="alert alert-info text-center mt-3">
                    <i class="fas fa-info-circle"></i>
                    @if (!string.IsNullOrWhiteSpace(searchQuery))
                    {
                        <span>Không tìm thấy xe phù hợp với từ khóa "<strong>@searchQuery</strong>".</span>
                    }
                    else
                    {
                        <span>Chưa có xe nào trong hệ thống.</span>
                    }
                </div>
            }
        </div>

        @* Pagination *@
        @if (totalPages > 1)
        {
            <div class="card-footer bg-light">
                <nav aria-label="Page navigation">
                    <ul class="pagination justify-content-center mb-0">
                        <!-- Previous -->
                        <li class="page-item @(page <= 1 ? "disabled" : "")">
                            <a class="page-link" asp-action="Index" asp-route-q="@searchQuery"
                               asp-route-page="@(page - 1)" asp-route-pageSize="@pageSize"
                               aria-label="Previous">
                                <span aria-hidden="true">&laquo;</span> Trước
                            </a>
                        </li>

                        @{
                            var startPage = Math.Max(1, page - 2);
                            var endPage = Math.Min(totalPages, page + 2);

                            // Show first page if not in range
                            if (startPage > 1)
                            {
                                <li class="page-item">
                                    <a class="page-link" asp-action="Index" asp-route-q="@searchQuery"
                                       asp-route-page="1" asp-route-pageSize="@pageSize">1</a>
                                </li>
                                if (startPage > 2)
                                {
                                    <li class="page-item disabled">
                                        <span class="page-link">…</span>
                                    </li>
                                }
                            }

                            // Page numbers
                            for (var p = startPage; p <= endPage; p++)
                            {
                                <li class="page-item @(p == page ? "active" : "")">
                                    <a class="page-link" asp-action="Index" asp-route-q="@searchQuery"
                                       asp-route-page="@p" asp-route-pageSize="@pageSize">
                                        @p
                                        @if (p == page)
                                        {
                                            <span class="visually-hidden">(current)</span>
                                        }
                                    </a>
                                </li>
                            }

                            // Show last page if not in range
                            if (endPage < totalPages)
                            {
                                if (endPage < totalPages - 1)
                                {
                                    <li class="page-item disabled">
                                        <span class="page-link">…</span>
                                    </li>
                                }
                                <li class="page-item">
                                    <a class="page-link" asp-action="Index" asp-route-q="@searchQuery"
                                       asp-route-page="@totalPages" asp-route-pageSize="@pageSize">@totalPages</a>
                                </li>
                            }
                        }

                        <!-- Next -->
                        <li class="page-item @(page >= totalPages ? "disabled" : "")">
                            <a class="page-link" asp-action="Index" asp-route-q="@searchQuery"
                               asp-route-page="@(page + 1)" asp-route-pageSize="@pageSize"
                               aria-label="Next">
                                Sau <span aria-hidden="true">&raquo;</span>
                            </a>
                        </li>
                    </ul>
                </nav>

                @* Page info *@
                <div class="text-center mt-2">
                    <small class="text-muted">
                        @if (totalPages > 1)
                        {
                            <span>Trang <strong>@(page)</strong> / @totalPages</span>
                            <span class="mx-2">|</span>
                        }
                        <span>Hiển thị @((page - 1) * pageSize + 1) - @Math.Min(page * pageSize, totalCount) trong tổng số <strong>@(totalCount)</strong> xe</span>
                    </small>
                </div>
            </div>
        }
        else if (totalCount > 0)
        {
            <div class="card-footer bg-light">
                <div class="text-center">
                    <small class="text-muted">
                        <i class="fas fa-info-circle"></i>
                        Hiển thị tất cả <strong>@totalCount</strong> xe
                    </small>
                </div>
            </div>
        }
    </div>

    <!-- Chú thích màu -->
    <div class="mt-3">
        <small class="text-muted me-4">
            <span class="badge bg-danger">&nbsp;</span> Quá hạn hoặc còn ≤ 1,000 km
        </small>
        <small class="text-muted me-4">
            <span class="badge bg-warning">&nbsp;</span> Còn 1,001 - 2,000 km
        </small>
        <small class="text-muted">
            <span class="badge bg-success">&nbsp;</span> Còn > 2,000 km
        </small>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
}
