@using ChargePoint.CarManagement.Models.ViewModels
@using ChargePoint.CarManagement.Models.ViewModels.MaintenanceViewModels
@model PagedResult<MaintenanceIndexViewModel>
@{
    ViewData["Title"] = "Quản lý bảo dưỡng";
    var searchQuery = Model.SearchQuery ?? "";
    var page = Model.PageNumber;
    var pageSize = Model.PageSize;
    var totalCount = Model.TotalCount;
    var totalPages = Model.TotalPages;
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3">
            <i class="fas fa-tools text-warning me-2"></i>
            Quản lý bảo dưỡng xe
        </h1>
    </div>
    <div class="row mb-3">
        <div class="col-md-8">
            <form asp-action="Index" method="get" class="d-flex" role="search">
                <input name="q" value="@searchQuery" class="form-control me-2" placeholder="Tìm theo biển số, tên xe, VIN, khách hàng, màu..." aria-label="Search" />
                <button class="btn btn-outline-primary" type="submit">
                    <i class="fas fa-search"></i> Tìm
                </button>
                @if (!string.IsNullOrWhiteSpace(searchQuery))
                {
                    <a asp-action="Index" class="btn btn-outline-secondary ms-2">
                        <i class="fas fa-times"></i> Xóa
                    </a>
                }
            </form>
        </div>
    </div>

    <div class="card shadow">
        <div class="card-body">
            <div class="d-flex justify-content-between mb-2">
                <div>
                    @if (!string.IsNullOrWhiteSpace(searchQuery))
                    {
                        <small class="text-muted">Kết quả tìm kiếm cho: <strong>@searchQuery</strong> — @totalCount kết quả</small>
                    }
                    else
                    {
                        <small class="text-muted">@totalCount xe</small>
                    }
                </div>
                <div>
                    <form asp-action="Index" method="get" class="d-inline">
                        <input type="hidden" name="q" value="@searchQuery" />
                        <label class="me-2">Hiển thị</label>
                        <select name="pageSize" class="form-select d-inline-block" style="width: auto;"
                                onchange="this.form.submit()">
                            <option value="5" selected="@(pageSize == 5 ? "selected" : null)">5</option>
                            <option value="10" selected="@(pageSize == 10 ? "selected" : null)">10</option>
                            <option value="25" selected="@(pageSize == 25 ? "selected" : null)">25</option>
                            <option value="50" selected="@(pageSize == 50 ? "selected" : null)">50</option>
                        </select>
                    </form>
                </div>
            </div>
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-dark">
                        <tr>
                            <th>STT</th>
                            <th>Biển số</th>
                            <th>Tên xe</th>
                            <th>ODO hiện tại</th>
                            <th>Bảo dưỡng gần nhất</th>
                            <th>Cấp bảo dưỡng</th>
                            <th>Kỳ tiếp theo</th>
                            <th>Số lần BD</th>
                            <th class="text-center">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            var car = item.Car;
                            var lastMaintenance = item.LastMaintenance;
                            var totalMaintenances = item.TotalMaintenances;

                            // Kiểm tra sắp đến hạn bảo dưỡng
                            var isOverdue = lastMaintenance?.NgayBaoDuongTiepTheo != null
                                && ((DateTime)lastMaintenance.NgayBaoDuongTiepTheo) < DateTime.Now;
                            var isNearDue = lastMaintenance?.NgayBaoDuongTiepTheo != null
                                && ((DateTime)lastMaintenance.NgayBaoDuongTiepTheo) <= DateTime.Now.AddDays(7)
                                && ((DateTime)lastMaintenance.NgayBaoDuongTiepTheo) >= DateTime.Now;

                            <tr class="@(isOverdue ? "table-danger" : isNearDue ? "table-warning" : "")">
                                <td>@car.Stt</td>
                                <td>
                                    @if (car.MauBienSo == MauBienSo.Vang)
                                    {
                                        <span class="license-plate license-plate-yellow">
                                            @car.BienSo
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="license-plate license-plate-white">
                                            @car.BienSo
                                        </span>
                                    }
                                </td>
                                <td>@car.TenXe</td>
                                <td><strong>@car.OdoXe.ToString("N0")</strong> km</td>
                                <td>
                                    @if (lastMaintenance != null)
                                    {
                                        <span>@(((DateTime)lastMaintenance.NgayBaoDuong).ToString("dd/MM/yyyy"))</span>
                                        <br />
                                        <small class="text-muted">@(((int)lastMaintenance.SoKmBaoDuong).ToString("N0")) km</small>
                                    }
                                    else
                                    {
                                        <span class="text-muted">Chưa bảo dưỡng</span>
                                    }
                                </td>
                                <td>
                                    @if (lastMaintenance != null)
                                    {
                                        var cap = (CapBaoDuong)lastMaintenance.CapBaoDuong;
                                        var badgeClass = cap switch
                                        {
                                            CapBaoDuong.Cap1 => "bg-info",
                                            CapBaoDuong.Cap2 => "bg-primary",
                                            CapBaoDuong.Cap3 => "bg-success",
                                            _ => "bg-secondary"
                                        };
                                        <span class="badge @badgeClass">Cấp @((int)cap)</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">-</span>
                                    }
                                </td>
                                <td>
                                    @if (lastMaintenance?.NgayBaoDuongTiepTheo != null)
                                    {
                                        var nextDate = (DateTime)lastMaintenance.NgayBaoDuongTiepTheo;
                                        <span class="@(isOverdue ? "text-danger fw-bold" : isNearDue ? "text-warning fw-bold" : "")">
                                            @nextDate.ToString("dd/MM/yyyy")
                                        </span>
                                        @if (isOverdue)
                                        {
                                            <br /><small class="text-danger"><i class="fas fa-exclamation-triangle"></i> Quá hạn!</small>
                                        }
                                        else if (isNearDue)
                                        {
                                            <br /><small class="text-warning"><i class="fas fa-clock"></i> Sắp đến hạn</small>
                                        }
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                <td>
                                    <span class="badge bg-secondary">@totalMaintenances</span>
                                </td>
                                <td class="text-center">
                                    <div class="d-flex gap-2" role="group">
                                        <a asp-action="Create" asp-route-id="@car.Id"
                                           class="btn btn-success" title="Thêm bảo dưỡng">
                                            <i class="fas fa-plus"></i> Thêm
                                        </a>
                                        <a asp-action="History" asp-route-id="@car.Id"
                                           class="btn btn-info" title="Xem lịch sử">
                                            <i class="fas fa-history"></i> Lịch sử
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Chú thích màu -->
    <div class="mt-3">
        <small class="text-muted me-4">
            <span class="badge bg-danger">&nbsp;</span> Quá hạn bảo dưỡng
        </small>
        <small class="text-muted">
            <span class="badge bg-warning">&nbsp;</span> Sắp đến hạn (trong 7 ngày)
        </small>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
}
