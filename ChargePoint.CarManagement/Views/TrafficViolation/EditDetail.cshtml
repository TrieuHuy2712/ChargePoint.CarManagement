@using ChargePoint.CarManagement.Domain.Entities
@using ChargePoint.CarManagement.Domain.Enums
@using ChargePoint.CarManagement.Extensions
@model ChargePoint.CarManagement.Domain.ViewModels.TrafficViolationViewModels.TrafficViolationCheckVM
@{
    ViewData["Title"] = "Chỉnh sửa chi tiết kiểm tra";
    var car = Model.Car;
    var check = Model.TrafficViolationCheck;
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3">
            <i class="fas fa-edit text-primary me-2"></i>
            Chỉnh sửa chi tiết kiểm tra
        </h1>
        <a asp-action="History" asp-route-id="@car.Id" class="btn btn-secondary">
            <i class="fas fa-arrow-left"></i> Quay lại
        </a>
    </div>

    <div class="row">
        <div class="col-md-12">
            <div class="card shadow mb-4">
                <div class="card-header bg-info text-white">
                    <h5 class="mb-0">
                        <i class="fas fa-car me-2"></i>Thông tin xe
                    </h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-3">
                            <strong>Biển số:</strong>
                            @if (car.MauBienSo == MauBienSo.Vang)
                            {
                                <span class="license-plate license-plate-yellow">@car.BienSo</span>
                            }
                            else
                            {
                                <span class="license-plate license-plate-white">@car.BienSo</span>
                            }
                        </div>
                        <div class="col-md-3">
                            <strong>Tên xe:</strong> @car.TenXe
                        </div>
                        <div class="col-md-3">
                            <strong>VIN:</strong> @car.SoVIN
                        </div>
                        <div class="col-md-3">
                            <strong>Khách hàng:</strong> @car.TenKhachHang
                        </div>
                    </div>
                </div>
            </div>

            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">
                        <i class="fas fa-clipboard-check me-2"></i>Chi tiết kiểm tra
                    </h5>
                </div>
                <div class="card-body">
                    <form asp-action="EditDetail" method="post">
                        <input type="hidden" asp-for="TrafficViolationCheck.Id" />
                        <input type="hidden" asp-for="TrafficViolationCheck.CarId" />
                        <input type="hidden" asp-for="TrafficViolationCheck.NgayKiemTra" />
                        <input type="hidden" asp-for="TrafficViolationCheck.NguoiTao" />

                        <div class="alert alert-info">
                            <i class="fas fa-info-circle me-2"></i>
                            <strong>Ngày kiểm tra:</strong> @check.NgayKiemTra.ToString("dd/MM/yyyy HH:mm") 
                            | <strong>Người kiểm tra:</strong> @check.NguoiTao
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="TrafficViolationCheck.SoLuongViPham" class="form-label">
                                        Số lượng vi phạm <span class="text-danger">*</span>
                                    </label>
                                    <input asp-for="TrafficViolationCheck.SoLuongViPham" class="form-control" 
                                           type="number" min="0" id="soLuongViPham" />
                                    <span asp-validation-for="TrafficViolationCheck.SoLuongViPham" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="TrafficViolationCheck.NgayGioViPham" class="form-label">
                                        Ngày giờ vi phạm
                                    </label>
                                    <input asp-for="TrafficViolationCheck.NgayGioViPham" class="form-control" 
                                           type="datetime-local" />
                                    <span asp-validation-for="TrafficViolationCheck.NgayGioViPham" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-12">
                                <div class="mb-3">
                                    <label asp-for="TrafficViolationCheck.NoiDungViPham" class="form-label">
                                        Nội dung vi phạm
                                    </label>
                                    <textarea asp-for="TrafficViolationCheck.NoiDungViPham" class="form-control" 
                                              rows="3" placeholder="Nhập nội dung hành vi vi phạm..."></textarea>
                                    <span asp-validation-for="TrafficViolationCheck.NoiDungViPham" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-12">
                                <div class="mb-3">
                                    <label asp-for="TrafficViolationCheck.DiaDiemViPham" class="form-label">
                                        Địa điểm vi phạm
                                    </label>
                                    <textarea asp-for="TrafficViolationCheck.DiaDiemViPham" class="form-control" 
                                              rows="2" placeholder="Nhập địa điểm vi phạm..."></textarea>
                                    <span asp-validation-for="TrafficViolationCheck.DiaDiemViPham" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="TrafficViolationCheck.TrangThaiXuLy" class="form-label">
                                        Trạng thái xử lý <span class="text-danger">*</span>
                                    </label>
                                    <select asp-for="TrafficViolationCheck.TrangThaiXuLy" class="form-select" required>
                                        <option value="">-- Chọn trạng thái --</option>
                                        @foreach (ViolationStatus status in Enum.GetValues(typeof(ViolationStatus)))
                                        {
                                            <option value="@((int)status)">@status.GetDisplayName()</option>
                                        }
                                    </select>
                                    <span asp-validation-for="TrafficViolationCheck.TrangThaiXuLy" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="TrafficViolationCheck.NguoiXuLy" class="form-label">
                                        Người xử lý
                                    </label>
                                    <input asp-for="TrafficViolationCheck.NguoiXuLy" class="form-control" 
                                           placeholder="Nhập tên người xử lý..." />
                                    <span asp-validation-for="TrafficViolationCheck.NguoiXuLy" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-12">
                                <div class="mb-3">
                                    <label asp-for="TrafficViolationCheck.GhiChu" class="form-label">
                                        Ghi chú
                                    </label>
                                    <textarea asp-for="TrafficViolationCheck.GhiChu" class="form-control" 
                                              rows="3" placeholder="Nhập ghi chú khác..."></textarea>
                                    <span asp-validation-for="TrafficViolationCheck.GhiChu" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="alert alert-warning">
                            <i class="fas fa-exclamation-triangle me-2"></i>
                            <strong>Lưu ý:</strong> Khi bạn thay đổi số lượng vi phạm, trạng thái "Có vi phạm" sẽ được tự động cập nhật.
                            <br/>
                            <small>Ngày cập nhật trạng thái sẽ được tự động lưu khi bạn lưu thay đổi.</small>
                        </div>

                        <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                            <a asp-action="History" asp-route-id="@car.Id" class="btn btn-secondary">
                                <i class="fas fa-times"></i> Hủy
                            </a>
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-save"></i> Lưu thay đổi
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}

    <script>
        // Auto-update violation status hint based on count
        document.getElementById('soLuongViPham').addEventListener('change', function() {
            const count = parseInt(this.value) || 0;
            const statusHint = count > 0 
                ? '<span class="text-danger"><i class="fas fa-exclamation-circle"></i> Có vi phạm</span>'
                : '<span class="text-success"><i class="fas fa-check-circle"></i> Không vi phạm</span>';

            // Add/update hint element
            let hintElement = document.getElementById('violationStatusHint');
            if (!hintElement) {
                hintElement = document.createElement('div');
                hintElement.id = 'violationStatusHint';
                hintElement.className = 'mt-2';
                this.parentElement.appendChild(hintElement);
            }
            hintElement.innerHTML = '<small>' + statusHint + '</small>';
        });

        // Trigger on load
        document.getElementById('soLuongViPham').dispatchEvent(new Event('change'));
    </script>
}
