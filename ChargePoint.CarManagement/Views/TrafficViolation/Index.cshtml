@using ChargePoint.CarManagement.Domain.Entities
@using ChargePoint.CarManagement.Domain.Enums
@using ChargePoint.CarManagement.Domain.ViewModels
@using ChargePoint.CarManagement.Domain.ViewModels.TrafficViolationViewModels
@using ChargePoint.CarManagement.Extensions
@model PagedResult<TrafficViolationIndexVM>
@{
    ViewData["Title"] = "Kiểm tra phạt nguội";
    var searchQuery = Model.SearchQuery ?? "";
    var page = Model.PageNumber;
    var pageSize = Model.PageSize;
    var totalCount = Model.TotalCount;
    var totalPages = Model.TotalPages;
    var currentStatus = ViewBag.CurrentStatus as ViolationStatus?;
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3">
            <i class="fas fa-gavel text-danger me-2"></i>
            Kiểm tra phạt nguội
        </h1>
        <a asp-controller="BulkTrafficViolation" asp-action="Index" class="btn btn-success">
            <i class="fas fa-tasks"></i> Tra cứu hàng loạt
        </a>
    </div>

    <div class="row mb-3">
        <div class="col-md-6">
            <form asp-action="Index" method="get" class="d-flex" role="search">
                <input name="q" value="@searchQuery" class="form-control me-2" placeholder="Tìm theo biển số, tên xe, VIN, khách hàng, màu..." aria-label="Search" />
                <input type="hidden" name="status" value="@currentStatus" />
                <button class="btn btn-outline-primary" type="submit">
                    <i class="fas fa-search"></i> Tìm
                </button>
                @if (!string.IsNullOrWhiteSpace(searchQuery))
                {
                    <a asp-action="Index" class="btn btn-outline-secondary ms-2">
                        <i class="fas fa-times"></i> Xóa
                    </a>
                }
            </form>
        </div>
        <div class="col-md-6">
            <form asp-action="Index" method="get" class="d-flex justify-content-end">
                <input type="hidden" name="q" value="@searchQuery" />
                <label class="me-2 align-self-center">Lọc theo trạng thái:</label>
                <select name="status" class="form-select" style="width: auto;" onchange="this.form.submit()">
                    <option value="">Tất cả</option>
                    <option value="0" selected="@(currentStatus == ViolationStatus.DaBao ? "selected" : null)">Đã báo</option>
                    <option value="1" selected="@(currentStatus == ViolationStatus.DangChoXuLy ? "selected" : null)">Đang chờ xử lý</option>
                    <option value="2" selected="@(currentStatus == ViolationStatus.DangXuLy ? "selected" : null)">Đang xử lý</option>
                    <option value="3" selected="@(currentStatus == ViolationStatus.DaXuLy ? "selected" : null)">Đã xử lý</option>
                </select>
                @if (currentStatus.HasValue)
                {
                    <a asp-action="Index" asp-route-q="@searchQuery" class="btn btn-outline-secondary ms-2">
                        <i class="fas fa-times"></i>
                    </a>
                }
            </form>
        </div>
    </div>

    <!-- Modal hiển thị kết quả tra cứu -->
    <div class="modal fade" id="resultModal" tabindex="-1" aria-labelledby="resultModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title" id="resultModalLabel">
                        <i class="fas fa-search me-2"></i>Kết quả tra cứu phạt nguội
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div id="modalLoading" class="text-center py-5">
                        <div class="spinner-border text-primary" style="width: 3rem; height: 3rem;" role="status">
                            <span class="visually-hidden">Đang tra cứu...</span>
                        </div>
                        <p class="mt-3 mb-0 fs-5">Đang tra cứu thông tin vi phạm...</p>
                        <p class="text-muted">Vui lòng chờ trong giây lát</p>
                    </div>
                    <div id="modalContent" style="display: none;">
                        <div class="alert alert-info mb-3">
                            <strong>Biển số:</strong> <span id="modalBienSo" class="badge bg-dark fs-6"></span>
                        </div>
                        <div id="modalStatus" class="alert mb-3"></div>
                        <div id="modalViolationList"></div>
                    </div>
                    <div id="modalError" style="display: none;">
                        <div class="alert alert-danger">
                            <i class="fas fa-exclamation-circle me-2"></i>
                            <span id="modalErrorMessage"></span>
                        </div>
                        <div class="text-center">
                            <a id="modalFallbackLink" href="#" target="_blank" class="btn btn-warning">
                                <i class="fas fa-external-link-alt me-2"></i>Tra cứu thủ công tại CSGT.vn
                            </a>
                        </div>
                    </div>
                </div>
                <div class="modal-footer" id="modalFooter" style="display: none;">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                        <i class="fas fa-times"></i> Đóng
                    </button>
                    <button type="button" id="btnGhiNhan" class="btn btn-success">
                        <i class="fas fa-plus"></i> Ghi nhận kết quả
                    </button>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow">
        <div class="card-body">
            <div class="d-flex justify-content-between mb-2">
                <div>
                    @if (!string.IsNullOrWhiteSpace(searchQuery))
                    {
                        <small class="text-muted">Kết quả tìm kiếm cho: <strong>@searchQuery</strong> — @totalCount kết quả</small>
                    }
                    else
                    {
                        <small class="text-muted">@totalCount xe</small>
                    }
                </div>
                <div>
                    <form asp-action="Index" method="get" class="d-inline">
                        <input type="hidden" name="q" value="@searchQuery" />
                        <input type="hidden" name="status" value="@currentStatus" />
                        <label class="me-2">Hiển thị</label>
                        <select name="pageSize" class="form-select d-inline-block" style="width: auto;"
                                onchange="this.form.submit()">
                            <option value="5" selected="@(pageSize == 5 ? "selected" : null)">5</option>
                            <option value="10" selected="@(pageSize == 10 ? "selected" : null)">10</option>
                            <option value="25" selected="@(pageSize == 25 ? "selected" : null)">25</option>
                            <option value="50" selected="@(pageSize == 50 ? "selected" : null)">50</option>
                        </select>
                    </form>
                </div>
            </div>
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-dark">
                        <tr>
                            <th>STT</th>
                            <th>Biển số</th>
                            <th>Tên xe</th>
                            <th>Khách hàng</th>
                            <th>Lần check cuối</th>
                            <th>Trạng thái vi phạm</th>
                            <th>Trạng thái xử lý</th>
                            <th class="text-center">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            var car = item.Car;
                            var lastCheck = item.LastCheck;
                            var bienSoFormatted = !string.IsNullOrEmpty(car.BienSo)
                            ? ((string)car.BienSo).Replace("-", "").Replace(".", "").Replace(" ", "").ToUpper()
                            : "";
                            <tr>
                                <td>@car.Stt</td>
                                <td>
                                    @if (car.MauBienSo == MauBienSo.Vang)
                                    {
                                        <span class="license-plate license-plate-yellow">
                                            @car.BienSo
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="license-plate license-plate-white">
                                            @car.BienSo
                                        </span>
                                    }
                                </td>
                                <td>@car.TenXe</td>
                                <td>@car.TenKhachHang</td>
                                <td>
                                    @if (lastCheck != null)
                                    {
                                        @(((DateTime)lastCheck.NgayKiemTra).ToString("dd/MM/yyyy HH:mm"))
                                    }
                                    else
                                    {
                                        <span class="text-muted">Chưa kiểm tra</span>
                                    }
                                </td>
                                <td>
                                    @if (lastCheck != null)
                                    {
                                        if ((bool)lastCheck.CoViPham)
                                        {
                                            <span class="badge bg-danger">
                                                <i class="fas fa-exclamation-triangle me-1"></i>
                                                Có @lastCheck.SoLuongViPham vi phạm
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success">
                                                <i class="fas fa-check-circle me-1"></i>
                                                Không vi phạm
                                            </span>
                                        }
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Chưa kiểm tra</span>
                                    }
                                </td>
                                <td>
                                    @if (lastCheck != null)
                                    {
                                        var statusClass = lastCheck.TrangThaiXuLy switch
                                        {
                                            ViolationStatus.DaBao => "bg-info",
                                            ViolationStatus.DangChoXuLy => "bg-warning text-dark",
                                            ViolationStatus.DangXuLy => "bg-primary",
                                            ViolationStatus.DaXuLy => "bg-success",
                                            _ => "bg-secondary"
                                        };
                                        <span class="badge @statusClass">
                                            @lastCheck.TrangThaiXuLy.GetDisplayName()
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                <td class="text-center">
                                    <div class="btn-group d-flex gap-2" role="group">
                                        @if (!string.IsNullOrEmpty(bienSoFormatted))
                                        {
                                            <button type="button"
                                                    class="btn btn-outline-secondary btn-check-online"
                                                    data-car-id="@car.Id"
                                                    data-bien-so="@bienSoFormatted"
                                                    data-bien-so-display="@car.BienSo"
                                                    title="Tra cứu online">
                                                <i class="fas fa-search"></i> Tra cứu
                                            </button>
                                        }
                                        <a asp-action="Check" asp-route-id="@car.Id"
                                           class="btn btn-success"
                                           title="Ghi nhận kết quả">
                                            <i class="fas fa-plus"></i> Ghi nhận
                                        </a>
                                        <a asp-action="History" asp-route-id="@car.Id"
                                           class="btn btn-info"
                                           title="Xem lịch sử">
                                            <i class="fas fa-history"></i> Lịch sử
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @* Empty state *@
            @if (!Model.Items.Any())
            {
                <div class="alert alert-info text-center mt-3">
                    <i class="fas fa-info-circle"></i>
                    @if (!string.IsNullOrWhiteSpace(searchQuery))
                    {
                        <span>Không tìm thấy xe phù hợp với từ khóa "<strong>@searchQuery</strong>".</span>
                    }
                    else if (currentStatus.HasValue)
                    {
                        <span>Không có xe nào với trạng thái <strong>@currentStatus.Value.GetDisplayName()</strong>.</span>
                    }
                    else
                    {
                        <span>Chưa có xe nào trong hệ thống.</span>
                    }
                </div>
            }
        </div>

        @* Pagination *@
        @if (totalPages > 1)
        {
            <div class="card-footer bg-light">
                <nav aria-label="Page navigation">
                    <ul class="pagination justify-content-center mb-0">
                        <!-- Previous -->
                        <li class="page-item @(page <= 1 ? "disabled" : "")">
                            <a class="page-link" asp-action="Index" asp-route-q="@searchQuery"
                               asp-route-status="@currentStatus"
                               asp-route-page="@(page - 1)" asp-route-pageSize="@pageSize"
                               aria-label="Previous">
                                <span aria-hidden="true">&laquo;</span> Trước
                            </a>
                        </li>

                        @{
                            var startPage = Math.Max(1, page - 2);
                            var endPage = Math.Min(totalPages, page + 2);

                            // Show first page if not in range
                            if (startPage > 1)
                            {
                                <li class="page-item">
                                    <a class="page-link" asp-action="Index" asp-route-q="@searchQuery"
                                       asp-route-status="@currentStatus"
                                       asp-route-page="1" asp-route-pageSize="@pageSize">1</a>
                                </li>
                                if (startPage > 2)
                                {
                                    <li class="page-item disabled">
                                        <span class="page-link">…</span>
                                    </li>
                                }
                            }

                            // Page numbers
                            for (var p = startPage; p <= endPage; p++)
                            {
                                <li class="page-item @(p == page ? "active" : "")">
                                    <a class="page-link" asp-action="Index" asp-route-q="@searchQuery"
                                       asp-route-status="@currentStatus"
                                       asp-route-page="@p" asp-route-pageSize="@pageSize">
                                        @p
                                        @if (p == page)
                                        {
                                            <span class="visually-hidden">(current)</span>
                                        }
                                    </a>
                                </li>
                            }

                            // Show last page if not in range
                            if (endPage < totalPages)
                            {
                                if (endPage < totalPages - 1)
                                {
                                    <li class="page-item disabled">
                                        <span class="page-link">…</span>
                                    </li>
                                }
                                <li class="page-item">
                                    <a class="page-link" asp-action="Index" asp-route-q="@searchQuery"
                                       asp-route-status="@currentStatus"
                                       asp-route-page="@totalPages" asp-route-pageSize="@pageSize">@totalPages</a>
                                </li>
                            }
                        }

                        <!-- Next -->
                        <li class="page-item @(page >= totalPages ? "disabled" : "")">
                            <a class="page-link" asp-action="Index" asp-route-q="@searchQuery"
                               asp-route-status="@currentStatus"
                               asp-route-page="@(page + 1)" asp-route-pageSize="@pageSize"
                               aria-label="Next">
                                Sau <span aria-hidden="true">&raquo;</span>
                            </a>
                        </li>
                    </ul>
                </nav>

                @* Page info *@
                <div class="text-center mt-2">
                    <small class="text-muted">
                        @if (totalPages > 1)
                        {
                            <span>Trang <strong>@(page)</strong> / @totalPages</span>
                            <span class="mx-2">|</span>
                        }
                        <span>Hiển thị @((page - 1) * pageSize + 1) - @Math.Min(page * pageSize, totalCount) trong tổng số <strong>@(totalCount)</strong> xe</span>
                    </small>
                </div>
            </div>
        }
        else if (totalCount > 0)
        {
            <div class="card-footer bg-light">
                <div class="text-center">
                    <small class="text-muted">
                        <i class="fas fa-info-circle"></i>
                        Hiển thị tất cả <strong>@totalCount</strong> xe
                    </small>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <script>
        let currentCarId = null;
        let lastModalResult = null;

        // Xử lý click nút tra cứu
        document.querySelectorAll('.btn-check-online').forEach(btn => {
            btn.addEventListener('click', async function() {
                const carId = this.dataset.carId;
                const bienSo = this.dataset.bienSo;
                const bienSoDisplay = this.dataset.bienSoDisplay;
                currentCarId = carId;
                lastModalResult = null;

                // Hiển thị modal
                const modal = new bootstrap.Modal(document.getElementById('resultModal'));
                modal.show();

                // Reset modal state
                document.getElementById('modalLoading').style.display = 'block';
                document.getElementById('modalContent').style.display = 'none';
                document.getElementById('modalError').style.display = 'none';
                document.getElementById('modalFooter').style.display = 'none';

                try {
                    // Gọi Controller CheckOnline
                    const response = await fetch('@Url.Action("CheckOnline", "TrafficViolation")', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/x-www-form-urlencoded'
                        },
                        body: `carId=${carId}`
                    });

                    const data = await response.json();
                    lastModalResult = data;

                    document.getElementById('modalLoading').style.display = 'none';

                    if (data.success) {
                        displayModalResult(bienSoDisplay, data);
                    } else {
                        showError(data.message || 'Không thể tra cứu', bienSo);
                    }
                } catch (error) {
                    console.error('Lỗi tra cứu:', error);
                    document.getElementById('modalLoading').style.display = 'none';
                    showError(`Lỗi kết nối: ${error.message}`, bienSo);
                }
            });
        });

        // Nút "Ghi nhận kết quả" — redirect sang Check với data pre-fill
        document.getElementById('btnGhiNhan').addEventListener('click', function() {
            if (!currentCarId) return;

            const baseUrl = '@Url.Action("Check", "TrafficViolation")/' + currentCarId;
            const params = new URLSearchParams();

            if (lastModalResult && lastModalResult.success) {
                params.set('soLuongViPham', lastModalResult.soLuongViPham || 0);

                if (lastModalResult.danhSachViPham && lastModalResult.danhSachViPham.length > 0) {
                    // Gộp tất cả vi phạm vào nội dung + địa điểm
                    const noiDungArr = [];
                    const diaDiemArr = [];
                    let firstDate = null;

                    lastModalResult.danhSachViPham.forEach((v, i) => {
                        const prefix = lastModalResult.danhSachViPham.length > 1 ? `[${i + 1}] ` : '';
                        if (v.hanhVi) noiDungArr.push(prefix + v.hanhVi);
                        if (v.diaDiem) diaDiemArr.push(prefix + v.diaDiem);
                        if (!firstDate && v.ngayViPham) firstDate = v.ngayViPham;
                    });

                    if (noiDungArr.length > 0) params.set('noiDungViPham', noiDungArr.join('\n'));
                    if (diaDiemArr.length > 0) params.set('diaDiemViPham', diaDiemArr.join('\n'));

                    // Parse ngày vi phạm đầu tiên
                    if (firstDate) {
                        const parts = firstDate.match(/(\d{2}):(\d{2}),?\s*(\d{2})\/(\d{2})\/(\d{4})/);
                        if (parts) {
                            params.set('ngayGioViPham', `${parts[5]}-${parts[4]}-${parts[3]}T${parts[1]}:${parts[2]}`);
                        } else {
                            const parts2 = firstDate.match(/(\d{2})\/(\d{2})\/(\d{4})\s*(\d{2}):(\d{2})/);
                            if (parts2) {
                                params.set('ngayGioViPham', `${parts2[3]}-${parts2[2]}-${parts2[1]}T${parts2[4]}:${parts2[5]}`);
                            }
                        }
                    }
                }

                // Tạo ghi chú tự động
                let ghiChu = `Tra cứu tự động lúc ${new Date().toLocaleString('vi-VN')}\n`;
                if (lastModalResult.coViPham && lastModalResult.danhSachViPham) {
                    ghiChu += `Phát hiện ${lastModalResult.soLuongViPham} vi phạm:\n`;
                    lastModalResult.danhSachViPham.forEach((v, i) => {
                        ghiChu += `${i + 1}. ${v.ngayViPham || ''} - ${v.hanhVi || ''} tại ${v.diaDiem || ''}\n`;
                    });
                } else {
                    ghiChu += 'Không có vi phạm';
                }
                params.set('ghiChu', ghiChu);
            }

            const separator = params.toString() ? '?' : '';
            window.location.href = baseUrl + separator + params.toString();
        });

        // Hiển thị lỗi
        function showError(message, bienSo) {
            document.getElementById('modalError').style.display = 'block';
            document.getElementById('modalErrorMessage').textContent = message;
            document.getElementById('modalFallbackLink').href =
                `https://csgt.vn/tra-cuu-phat-nguoi.html?bienso=${bienSo}`;
        }

        // Hiển thị kết quả trong modal
        function displayModalResult(bienSoDisplay, data) {
            document.getElementById('modalContent').style.display = 'block';
            document.getElementById('modalFooter').style.display = 'flex';
            document.getElementById('modalBienSo').textContent = bienSoDisplay;

            const statusDiv = document.getElementById('modalStatus');
            const listDiv = document.getElementById('modalViolationList');

            if (data.coViPham) {
                statusDiv.className = 'alert alert-danger';
                statusDiv.innerHTML = `
                    <i class="fas fa-exclamation-triangle me-2"></i>
                    <strong>Phát hiện ${data.soLuongViPham} vi phạm!</strong>
                `;
            } else {
                statusDiv.className = 'alert alert-success';
                statusDiv.innerHTML = `
                    <i class="fas fa-check-circle me-2"></i>
                    <strong>Không có vi phạm!</strong> Xe sạch phạt nguội.
                `;
            }

            if (data.danhSachViPham && data.danhSachViPham.length > 0) {
                let html = '<div class="table-responsive"><table class="table table-sm table-bordered table-striped">';
                html += '<thead class="table-dark"><tr>';
                html += '<th>#</th><th>Ngày vi phạm</th><th>Hành vi</th><th>Địa điểm</th><th>Tiền phạt</th><th>Trạng thái</th>';
                html += '</tr></thead><tbody>';

                let tongTien = 0;
                data.danhSachViPham.forEach((v, index) => {
                    const tien = v.soTienPhat || 0;
                    tongTien += tien;
                    html += `<tr>
                        <td>${index + 1}</td>
                        <td>${v.ngayViPham || '-'}</td>
                        <td>${v.hanhVi || '-'}</td>
                        <td>${v.diaDiem || '-'}</td>
                        <td class="text-end text-danger fw-bold">${tien.toLocaleString('vi-VN')} đ</td>
                        <td><span class="badge bg-warning text-dark">${v.trangThai || 'Chưa xử lý'}</span></td>
                    </tr>`;
                });

                html += `<tr class="table-warning">
                    <td colspan="4" class="text-end"><strong>Tổng cộng:</strong></td>
                    <td class="text-end text-danger"><strong>${tongTien.toLocaleString('vi-VN')} đ</strong></td>
                    <td></td>
                </tr>`;
                html += '</tbody></table></div>';
                listDiv.innerHTML = html;
            } else {
                listDiv.innerHTML = '';
            }
        }
    </script>
}
