@model ChargePoint.CarManagement.Models.Car
@inject IOptions<ChargePoint.CarManagement.Models.FileUploadSettings> FileUploadSettings
@using ChargePoint.CarManagement.Models

@{
    ViewData["Title"] = "Thêm xe mới";
    var settings = FileUploadSettings.Value;
}

<div class="container">
    <h1 class="mb-4">
        <i class="fas fa-plus-circle"></i> Thêm xe mới
    </h1>

    <div class="card shadow">
        <div class="card-body">
            <form asp-action="Create" enctype="multipart/form-data" id="createCarForm">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group mb-3">
                            <label asp-for="Stt" class="form-label"></label>
                            <input asp-for="Stt" class="form-control" readonly />
                            <span asp-validation-for="Stt" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="form-group mb-3">
                            <label asp-for="TenXe" class="form-label"></label>
                            <input asp-for="TenXe" class="form-control" />
                            <span asp-validation-for="TenXe" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group mb-3">
                            <label asp-for="SoLuong" class="form-label"></label>
                            <input asp-for="SoLuong" class="form-control" type="number" />
                            <span asp-validation-for="SoLuong" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="form-group mb-3">
                            <label asp-for="MauXe" class="form-label"></label>
                            <input asp-for="MauXe" class="form-control" />
                            <span asp-validation-for="MauXe" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group mb-3">
                            <label asp-for="SoVIN" class="form-label"></label>
                            <input asp-for="SoVIN" class="form-control" maxlength="17" />
                            <span asp-validation-for="SoVIN" class="text-danger"></span>
                            <small class="form-text text-muted">Số VIN phải có 17 ký tự</small>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="form-group mb-3">
                            <label asp-for="BienSo" class="form-label"></label>
                            <input asp-for="BienSo" class="form-control" />
                            <span asp-validation-for="BienSo" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group mb-3">
                            <label asp-for="MauBienSo" class="form-label"></label>
                            <div class="d-flex gap-4 mt-2">
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" asp-for="MauBienSo"
                                           value="@((int)MauBienSo.Trang)" id="bienTrang" checked />
                                    <label class="form-check-label" for="bienTrang">
                                        <span class="badge text-dark" style="background-color: #fff; border: 2px solid #333; padding: 8px 16px; font-size: 14px;">
                                            <i class="fas fa-car"></i> Biển trắng
                                        </span>
                                    </label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" asp-for="MauBienSo"
                                           value="@((int)MauBienSo.Vang)" id="bienVang" />
                                    <label class="form-check-label" for="bienVang">
                                        <span class="badge text-dark" style="background-color: #ffc107; border: 2px solid #333; padding: 8px 16px; font-size: 14px;">
                                            <i class="fas fa-taxi"></i> Biển vàng
                                        </span>
                                    </label>
                                </div>
                            </div>
                            <span asp-validation-for="MauBienSo" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="form-group mb-3">
                            <label asp-for="TenKhachHang" class="form-label"></label>
                            <input asp-for="TenKhachHang" class="form-control" />
                            <span asp-validation-for="TenKhachHang" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group mb-3">
                            <label asp-for="OdoXe" class="form-label"></label>
                            <input asp-for="OdoXe" class="form-control" type="number" />
                            <span asp-validation-for="OdoXe" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="ThongTinChoThue" class="form-label"></label>
                    <textarea asp-for="ThongTinChoThue" class="form-control" rows="3"></textarea>
                    <span asp-validation-for="ThongTinChoThue" class="text-danger"></span>
                </div>

                <!-- Hình ảnh & Video (multiple) -->
                <h5 class="mt-4 mb-3 text-primary">
                    <i class="fas fa-images"></i> Hình ảnh & Video bàn giao
                </h5>

                @* Hidden bound to Car.PrimaryImageUrl so Create POST receives the primary URL *@
                <input type="hidden" asp-for="PrimaryImageUrl" />

                @* Single primary image upload (no radio selection) *@
                <div class="row mb-3">
                    <div class="col-md-12">
                        <label class="form-label"><i class="fas fa-star"></i> Ảnh chính (upload cùng form)</label>
                        <div class="d-flex gap-2 align-items-center">
                            <input type="file" name="PrimaryImageFile" id="PrimaryImageFile" accept="@string.Join(",", settings.AllowedImageExtensions.Select(e => "image/" + e.TrimStart('.')))" class="form-control" />
                            <span id="primaryUploadStatus" class="text-muted ms-2"></span>
                        </div>
                        <small class="form-text text-muted">Ảnh chính sẽ được upload cùng lúc khi bạn nhấn `Lưu`. Nếu không upload, hệ thống sẽ tự chọn ảnh GSM đầu tiên.</small>
                        <div id="primaryPreview" class="mt-2"></div>
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-md-6">
                        <label class="form-label"><i class="fas fa-image"></i> Hình ảnh nhận bàn giao từ GSM (GF) - multiple</label>
                        <input type="file" name="HinhAnhNhanBanGiaoFiles" id="HinhAnhNhanBanGiaoFiles" multiple accept="@string.Join(",", settings.AllowedImageExtensions.Select(e => "image/" + e.TrimStart('.')))" class="form-control file-upload-multi" data-max-size="@settings.MaxImageSizeMB" data-type="image" />
                        <small class="form-text text-muted">Tối đa @settings.MaxImageSizeMB MB mỗi file. Định dạng: @string.Join(", ", settings.AllowedImageExtensions)</small>
                        <div class="file-multi-preview mt-2" data-group="gsm"></div>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label"><i class="fas fa-image"></i> Hình ảnh bàn giao cho KH - multiple</label>
                        <input type="file" name="HinhAnhBanGiaoKHFiles" id="HinhAnhBanGiaoKHFiles" multiple accept="@string.Join(",", settings.AllowedImageExtensions.Select(e => "image/" + e.TrimStart('.')))" class="form-control file-upload-multi" data-max-size="@settings.MaxImageSizeMB" data-type="image" />
                        <small class="form-text text-muted">Tối đa @settings.MaxImageSizeMB MB mỗi file. Định dạng: @string.Join(", ", settings.AllowedImageExtensions)</small>
                        <div class="file-multi-preview mt-2" data-group="kh"></div>
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-md-6">
                        <label class="form-label"><i class="fas fa-film"></i> Video nhận bàn giao từ GSM - multiple</label>
                        <input type="file" name="VideoNhanBanGiaoFiles" id="VideoNhanBanGiaoFiles" multiple accept="@string.Join(",", settings.AllowedVideoExtensions.Select(e => "video/" + e.TrimStart('.')))" class="form-control file-upload-multi" data-max-size="@settings.MaxVideoSizeMB" data-type="video" />
                        <small class="form-text text-muted">Tối đa @settings.MaxVideoSizeMB MB mỗi file. Định dạng: @string.Join(", ", settings.AllowedVideoExtensions)</small>
                        <div class="file-multi-preview mt-2" data-group="gsm-video"></div>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label"><i class="fas fa-film"></i> Video bàn giao cho KH - multiple</label>
                        <input type="file" name="VideoBanGiaoKHFiles" id="VideoBanGiaoKHFiles" multiple accept="@string.Join(",", settings.AllowedVideoExtensions.Select(e => "video/" + e.TrimStart('.')))" class="form-control file-upload-multi" data-max-size="@settings.MaxVideoSizeMB" data-type="video" />
                        <small class="form-text text-muted">Tối đa @settings.MaxVideoSizeMB MB mỗi file. Định dạng: @string.Join(", ", settings.AllowedVideoExtensions)</small>
                        <div class="file-multi-preview mt-2" data-group="kh-video"></div>
                    </div>
                </div>

                <!-- Upload Progress -->
                <div id="uploadProgress" class="mb-3" style="display: none;">
                    <label class="form-label">Đang tải lên...</label>
                    <div class="progress">
                        <div class="progress-bar progress-bar-striped progress-bar-animated"
                             role="progressbar" style="width: 0%"></div>
                    </div>
                </div>

                <div class="form-group mt-4">
                    <button type="submit" class="btn btn-success" id="btnSubmit">
                        <i class="fas fa-save"></i> Lưu
                    </button>
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="fas fa-arrow-left"></i> Quay lại
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const form = document.getElementById('createCarForm');
            const btnSubmit = document.getElementById('btnSubmit');

            // Handle multi file inputs (images + videos) - only previews, no primary radios
            document.querySelectorAll('.file-upload-multi').forEach(function(input) {
                input.addEventListener('change', function() {
                    renderMultiPreview(this);
                });
            });

            function renderMultiPreview(input) {
                const files = Array.from(input.files || []);
                const maxSize = parseInt(input.dataset.maxSize) * 1024 * 1024;
                const type = input.dataset.type;
                const parent = input.parentElement;
                const previewContainer = parent.querySelector('.file-multi-preview');
                previewContainer.innerHTML = '';

                files.forEach((file) => {
                    if (file.size > maxSize) {
                        alert(`File ${file.name} quá lớn. Tối đa ${input.dataset.maxSize} MB.`);
                        input.value = '';
                        previewContainer.innerHTML = '';
                        return;
                    }

                    const wrapper = document.createElement('div');
                    wrapper.className = 'd-inline-block me-2 mb-2 text-center preview-item';
                    wrapper.style = 'width:120px;';

                    if (type === 'image') {
                        const reader = new FileReader();
                        reader.onload = function(e) {
                            const img = document.createElement('img');
                            img.src = e.target.result;
                            img.className = 'img-thumbnail';
                            img.style = 'max-height:80px; display:block; margin-bottom:6px;';
                            wrapper.appendChild(img);
                            const label = document.createElement('div');
                            label.style = 'font-size:12px;';
                            label.textContent = file.name;
                            wrapper.appendChild(label);
                        };
                        reader.readAsDataURL(file);
                    } else {
                        wrapper.innerHTML = `<div class="p-2 border rounded" style="height:80px; display:flex; align-items:center; justify-content:center;">
                                                <i class="fas fa-file-video"></i>
                                             </div>
                                             <div style="font-size:12px; max-width:120px; overflow:hidden; text-overflow:ellipsis;">${file.name}</div>`;
                    }

                    previewContainer.appendChild(wrapper);
                });
            }

            // Primary image upload (single file) - uploads immediately and stores returned URL into hidden PrimaryImageUrl
            const primaryFileInput = document.getElementById('PrimaryImageFile');
            const primaryStatus = document.getElementById('primaryUploadStatus');
            const primaryPreview = document.getElementById('primaryPreview');
            const hiddenPrimary = document.querySelector('input[name="PrimaryImageUrl"]');

            form.addEventListener('submit', function(e) {
                const invalidInputs = form.querySelectorAll('.is-invalid');
                if (invalidInputs.length > 0) {
                    e.preventDefault();
                    alert('Vui lòng kiểm tra lại các file đã chọn.');
                    return false;
                }

                const hasFiles = Array.from(form.querySelectorAll('.file-upload-multi'))
                    .some(input => input.files.length > 0);

                if (hasFiles) {
                    btnSubmit.disabled = true;
                    btnSubmit.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Đang tải lên...';
                    document.getElementById('uploadProgress').style.display = 'block';
                }
            });

            primaryFileInput.addEventListener('change', function () {
                const file = this.files && this.files[0];
                primaryPreview.innerHTML = '';
                primaryStatus.textContent = '';

                if (!file) return;

                // basic client-side size check (optional)
                const maxSize = parseInt('@settings.MaxImageSizeMB') * 1024 * 1024;
                if (file.size > maxSize) {
                    primaryStatus.textContent = `File quá lớn. Tối đa @settings.MaxImageSizeMB MB.`;
                    this.value = '';
                    return;
                }

                // show preview
                if (file.type.startsWith('image/')) {
                    const reader = new FileReader();
                    reader.onload = function (e) {
                        primaryPreview.innerHTML = `<img src="${e.target.result}" class="img-thumbnail" style="max-height:150px;">`;
                    };
                    reader.readAsDataURL(file);
                } else {
                    primaryPreview.innerHTML = `<div class="alert alert-info py-2"><i class="fas fa-file-image"></i> ${file.name}</div>`;
                }
            });
        });
    </script>

    <style>
        .file-upload-multi.is-valid { border-color: #198754; }
        .file-upload-multi.is-invalid { border-color: #dc3545; }
        .file-multi-preview img { max-width: 100%; border-radius: 8px; }
        .preview-item { text-align: center; }
        #primaryPreview img { border-radius: 8px; }
    </style>
}
