@inject IOptions<ChargePoint.CarManagement.Models.FileUploadSettings> FileUploadSettings
@using ChargePoint.CarManagement.Domain.Entities
@using ChargePoint.CarManagement.Domain.Enums
@using ChargePoint.CarManagement.Domain.Models
@using ChargePoint.CarManagement.Domain.ViewModels
@using Microsoft.Extensions.Options
@inject IOptions<FileUploadSettings> FileUploadSettings
@model CarViewModel

@{
    ViewData["Title"] = "Chỉnh sửa xe";
    var settings = FileUploadSettings.Value;
}

<div class="container">
    <h1 class="mb-4">
        <i class="fas fa-edit"></i> Chỉnh sửa xe
    </h1>

    <div class="card shadow">
        <div class="card-body">
            <form asp-action="Edit" enctype="multipart/form-data" id="editCarForm">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="NgayTao" />
                <input type="hidden" asp-for="NguoiTao" />
                <input type="hidden" asp-for="@Model.HinhAnhNhanBanGiao" />
                <input type="hidden" asp-for="@Model.HinhAnhBanGiaoKH" />

                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group mb-3">
                            <label asp-for="Stt" class="form-label"></label>
                            <input asp-for="Stt" class="form-control" />
                            <span asp-validation-for="Stt" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="form-group mb-3">
                            <label asp-for="TenXe" class="form-label"></label>
                            <input asp-for="TenXe" class="form-control" />
                            <span asp-validation-for="TenXe" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group mb-3">
                            <label asp-for="SoLuong" class="form-label"></label>
                            <input asp-for="SoLuong" class="form-control" type="number" />
                            <span asp-validation-for="SoLuong" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="form-group mb-3">
                            <label asp-for="MauXe" class="form-label"></label>
                            <input asp-for="MauXe" class="form-control" />
                            <span asp-validation-for="MauXe" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group mb-3">
                            <label asp-for="SoVIN" class="form-label"></label>
                            <input asp-for="SoVIN" class="form-control" maxlength="17" />
                            <span asp-validation-for="SoVIN" class="text-danger"></span>
                            <small class="form-text text-muted">Số VIN phải có 17 ký tự</small>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="form-group mb-3">
                            <label asp-for="BienSo" class="form-label"></label>
                            <input asp-for="BienSo" class="form-control" />
                            <span asp-validation-for="BienSo" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group mb-3">
                            <label asp-for="BienSoCu" class="form-label"></label>
                            <input asp-for="BienSoCu" class="form-control" />
                            <span asp-validation-for="BienSoCu" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="form-group mb-3">
                            <label asp-for="MauBienSo" class="form-label"></label>
                            <div class="d-flex gap-4 mt-2">
                                <div class="form-check">
                                    <input class="form-check-input" type="radio"
                                           name="MauBienSo" id="bienTrang"
                                           value="@((int)MauBienSo.Trang)"
                                           @(Model.MauBienSo == MauBienSo.Trang ? "checked" : "") />
                                    <label class="form-check-label" for="bienTrang">
                                        <span class="badge text-dark" style="background-color: #fff; border: 2px solid #333; padding: 8px 16px; font-size: 14px;">
                                            <i class="fas fa-car"></i> Biển trắng
                                        </span>
                                    </label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="radio"
                                           name="MauBienSo" id="bienVang"
                                           value="@((int)MauBienSo.Vang)"
                                           @(Model.MauBienSo == MauBienSo.Vang ? "checked" : "") />
                                    <label class="form-check-label" for="bienVang">
                                        <span class="badge text-dark" style="background-color: #ffc107; border: 2px solid #333; padding: 8px 16px; font-size: 14px;">
                                            <i class="fas fa-taxi"></i> Biển vàng
                                        </span>
                                    </label>
                                </div>
                            </div>
                            <span asp-validation-for="MauBienSo" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group mb-3">
                            <label asp-for="TenKhachHang" class="form-label"></label>
                            <input asp-for="TenKhachHang" class="form-control" />
                            <span asp-validation-for="TenKhachHang" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="form-group mb-3">
                            <label asp-for="OdoXe" class="form-label"></label>
                            <input asp-for="OdoXe" class="form-control" type="number" />
                            <span asp-validation-for="OdoXe" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group mb-3">
                            <label asp-for="NgayThue" class="form-label"></label>
                            <input asp-for="NgayThue" class="form-control" type="date" id="NgayThue" />
                            <span asp-validation-for="NgayThue" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group mb-3">
                            <label asp-for="NgayHetHan" class="form-label"></label>
                            <input asp-for="NgayHetHan" class="form-control" type="date" id="NgayHetHan" />
                            <span asp-validation-for="NgayHetHan" class="text-danger"></span>
                            <small class="text-muted">Mặc định được tự động cộng 1 năm từ Ngày thuê.</small>
                        </div>
                    </div>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="ThongTinChoThue" class="form-label"></label>
                    <textarea asp-for="ThongTinChoThue" class="form-control" rows="3"></textarea>
                    <span asp-validation-for="ThongTinChoThue" class="text-danger"></span>
                </div>

                <!-- Hình ảnh (multiple) -->
                <h5 class="mt-4 mb-3 text-primary">
                    <i class="fas fa-images"></i> Hình ảnh bàn giao
                </h5>

                <input type="hidden" id="PrimaryImageUrl" name="PrimaryImageUrl" value="@Model.PrimaryImageUrl" />

                @* Primary image input (upload alongside main form) *@
                <div class="card mb-4 border-warning">
                    <div class="card-header bg-warning text-dark">
                        <strong><i class="fas fa-star"></i> Ảnh chính (Đổi ảnh đại diện xe khác)</strong>
                    </div>
                    <div class="card-body p-3">
                        <div class="drop-zone d-flex align-items-center rounded shadow-sm border border-warning p-3" id="dropZone-PrimaryImage" onclick="document.getElementById('input-PrimaryImage').click()" tabindex="0" title="Click, Kéo thả hoặc Ctrl+V để tải ảnh chính mới" style="cursor: pointer;">
                            <!-- Icon Indicator -->
                            <div class="flex-shrink-0 d-flex justify-content-center align-items-center text-warning" style="width: 50px;">
                                <i class="fas fa-star fs-3"></i>
                            </div>

                            <!-- Text Information -->
                            <div class="flex-grow-1 overflow-hidden ms-3">
                                <div class="fw-bold text-dark mb-1">
                                    Tải lên ảnh kích thước tiêu chuẩn
                                </div>
                                <small class="text-muted d-block text-wrap">
                                    Kéo thả, Click, hoặc <kbd>Ctrl+V</kbd>. Nếu chọn ảnh ở đây, ảnh này sẽ ghi đè làm ảnh chính khi bấm Lưu.
                                </small>
                            </div>

                            <!-- Hidden Input -->
                            <input type="file" name="PrimaryImageFile" id="input-PrimaryImage" class="d-none image-upload-input" accept="@string.Join(",", settings.AllowedImageExtensions.Select(e => "image/" + e.TrimStart('.')))" />
                        </div>

                        <!-- Image Preview Thumbnail Side (Moved Below) -->
                        <div id="preview-PrimaryImage" class="image-preview-container d-flex flex-wrap mt-3 empty-hide">
                            <div class="d-flex w-100 justify-content-center">
                                <i class="fas fa-image text-muted" style="opacity: 0.2; font-size: 2rem; display: none;"></i>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Primary display + Gallery (match Details layout) -->
                <hr />

                <div class="mb-3">
                    <h6><i class="fas fa-star text-warning"></i> Ảnh chính hiện tại</h6>
                    <div class="card mb-3">
                        <div class="card-body text-center">
                            @if (!string.IsNullOrEmpty(Model.PrimaryImageUrl))
                            {
                                <a href="@Model.PrimaryImageUrl" target="_blank">
                                    <img src="@Model.PrimaryImageUrl" class="img-fluid rounded" style="max-height: 300px; cursor: pointer;" />
                                </a>
                            }
                            else
                            {
                                <p class="text-muted py-4"><i class="fas fa-image fa-3x"></i><br />Chưa có ảnh chính</p>
                            }
                        </div>
                    </div>

                    @{
                        // Lấy tất cả hình ảnh, loại trừ 2 nhóm folder Image_GSM và Image_KH (nếu có), sắp xếp để ảnh cùng bộ phận nằm cạnh nhau
                        var sliderMedia = Model.Media?
                            .Where(m => !string.IsNullOrEmpty(m.Url) && m.Type != MediaType.Image_GSM && m.Type != MediaType.Image_KH && m.Type != MediaType.Image_Primary)
                            .OrderBy(m => m.Type)
                            .ThenByDescending(m => m.CreatedAt)
                            .ToList();
                    }

                    @if (sliderMedia != null && sliderMedia.Any())
                    {
                        <h6 class="mt-4"><i class="fas fa-film text-primary"></i> Trình duyệt tất cả hình ảnh (Slider)</h6>
                        <div class="card mb-4 pb-2">
                            <div class="card-body bg-light">
                                <!-- Swiper CSS -->
                                <link rel="stylesheet" href="https://unpkg.com/swiper/swiper-bundle.min.css" />
                                <style>
                                    .edit-slider-wrapper { position: relative; padding: 0 50px; }
                                    .edit-slider-wrapper .swiper-button-next,
                                    .edit-slider-wrapper .swiper-button-prev { 
                                        top: 45%; transform: translateY(-50%); width: 40px; height: 40px; background: rgba(0,0,0,0.5); border-radius: 50%; color: white; border: 1px solid #fff;
                                    }
                                    .edit-slider-wrapper .swiper-button-next::after, 
                                    .edit-slider-wrapper .swiper-button-prev::after { font-size: 18px; }
                                </style>

                                <div class="edit-slider-wrapper">
                                    <div class="swiper-button-prev edit-prev"></div>
                                    <div class="swiper-button-next edit-next"></div>

                                    <div class="swiper-container edit-image-slider" style="overflow: hidden; border-radius: 8px;">
                                        <div class="swiper-wrapper">
                                            @foreach (var m in sliderMedia)
                                            {
                                                <div class="swiper-slide text-center position-relative">
                                                    <a href="@m.Url" target="_blank" title="Mở hình ảnh">
                                                        <img src="@m.Url" style="height: 400px; width: 100%; object-fit: contain; background: #e9ecef;" />
                                                    </a>
                                                    <!-- Hiển thị thông tin ảnh đè lên dưới cùng -->
                                                    <div class="position-absolute bottom-0 start-0 w-100 bg-dark bg-opacity-75 text-white py-2" style="z-index: 10;">
                                                        <h6 class="mb-1 text-warning fw-bold">@m.Type.GetDisplayName()</h6>
                                                        <small class="text-light">Tải lên: @m.CreatedAt.ToString("dd/MM/yyyy HH:mm")</small>
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                        <div class="swiper-pagination edit-pagination" style="position: relative; margin-top: 15px;"></div>
                                    </div>
                                </div>

                                <!-- Swiper JS -->
                                <script src="https://unpkg.com/swiper/swiper-bundle.min.js"></script>
                                <script>
                                    document.addEventListener('DOMContentLoaded', function () {
                                        new Swiper('.edit-image-slider', {
                                            loop: false,
                                            grabCursor: true,
                                            pagination: { el: '.edit-pagination', clickable: true },
                                            navigation: { nextEl: '.edit-next', prevEl: '.edit-prev' },
                                        });
                                    });
                                </script>
                            </div>
                        </div>
                    }

                    <h6 class="mt-4"><i class="fas fa-images"></i> Quản lý Hình ảnh hiện tại</h6>

                    @{
                        var gsmThanXeImages = Model.Media?.Where(m => m.Type.IsThanXe() && m.Type.IsGSM()).ToList();
                        var gsmGiayToImages = Model.Media?.Where(m => m.Type.IsGiayTo() && m.Type.IsGSM()).ToList();
                        var khThanXeImages = Model.Media?.Where(m => m.Type.IsThanXe() && m.Type.IsKH()).ToList();
                        var khGiayToImages = Model.Media?.Where(m => m.Type.IsGiayTo() && m.Type.IsKH()).ToList();
                    }

                    <!-- Hình ảnh thân xe GSM -->
                    @if (gsmThanXeImages != null && gsmThanXeImages.Any())
                    {
                        <div class="card mb-3">
                            <div class="card-header bg-success text-white">
                                <strong><i class="fas fa-camera-retro"></i> Hình ảnh thân xe - GSM</strong>
                            </div>
                            <div class="card-body">
                                <div class="row g-2">
                                    @foreach (var img in gsmThanXeImages.OrderByDescending(m => m.IsPrimary).ThenByDescending(m => m.CreatedAt))
                                    {
                                        <div class="col-6 col-sm-4 col-md-3 col-lg-2 mb-2" data-media-id="@img.Id" data-media-url="@img.Url">
                                            <div class="card h-100">
                                                <div class="card-body p-1 text-center">
                                                    <a href="@img.Url" target="_blank">
                                                        <img src="@img.Url" class="img-fluid rounded" style="max-height:100px; width:100%; object-fit:cover;" />
                                                    </a>
                                                </div>
                                                <div class="card-footer p-1">
                                                    <small class="d-block text-muted" style="font-size:10px;">@img.Type.GetDisplayName()</small>
                                                    <div class="d-flex justify-content-between align-items-center mt-1">
                                                        @if (img.IsPrimary)
                                                        {
                                                            <span class="badge bg-warning text-dark" style="font-size:9px;">Ảnh chính</span>
                                                        }
                                                        <div class="form-check form-check-inline mb-0">
                                                            <input class="form-check-input existing-primary-radio" type="radio" name="existingPrimary" value="@img.Url" @(img.IsPrimary ? "checked" : "") />
                                                        </div>
                                                        <button type="button" class="btn btn-sm btn-danger btn-delete-media p-0 px-1" data-media-id="@img.Id" style="font-size:10px;">X</button>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    }

                    <!-- Giấy tờ xe GSM -->
                    @if (gsmGiayToImages != null && gsmGiayToImages.Any())
                    {
                        <div class="card mb-3">
                            <div class="card-header bg-success text-white">
                                <strong><i class="fas fa-file-alt"></i> Giấy tờ xe - GSM</strong>
                            </div>
                            <div class="card-body">
                                <div class="row g-2">
                                    @foreach (var img in gsmGiayToImages.OrderByDescending(m => m.CreatedAt))
                                    {
                                        <div class="col-6 col-sm-4 col-md-3 col-lg-2 mb-2" data-media-id="@img.Id" data-media-url="@img.Url">
                                            <div class="card h-100">
                                                <div class="card-body p-1 text-center">
                                                    <a href="@img.Url" target="_blank">
                                                        <img src="@img.Url" class="img-fluid rounded" style="max-height:100px; width:100%; object-fit:cover;" />
                                                    </a>
                                                </div>
                                                <div class="card-footer p-1">
                                                    <small class="d-block text-muted" style="font-size:10px;">@img.Type.GetDisplayName()</small>
                                                    <button type="button" class="btn btn-sm btn-danger btn-delete-media mt-1 w-100 p-0" data-media-id="@img.Id" style="font-size:10px;">Xóa</button>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    }

                    <!-- Hình ảnh thân xe KH -->
                    @if (khThanXeImages != null && khThanXeImages.Any())
                    {
                        <div class="card mb-3">
                            <div class="card-header bg-info text-white">
                                <strong><i class="fas fa-camera-retro"></i> Hình ảnh thân xe - KH</strong>
                            </div>
                            <div class="card-body">
                                <div class="row g-2">
                                    @foreach (var img in khThanXeImages.OrderByDescending(m => m.IsPrimary).ThenByDescending(m => m.CreatedAt))
                                    {
                                        <div class="col-6 col-sm-4 col-md-3 col-lg-2 mb-2" data-media-id="@img.Id" data-media-url="@img.Url">
                                            <div class="card h-100">
                                                <div class="card-body p-1 text-center">
                                                    <a href="@img.Url" target="_blank">
                                                        <img src="@img.Url" class="img-fluid rounded" style="max-height:100px; width:100%; object-fit:cover;" />
                                                    </a>
                                                </div>
                                                <div class="card-footer p-1">
                                                    <small class="d-block text-muted" style="font-size:10px;">@img.Type.GetDisplayName()</small>
                                                    <div class="d-flex justify-content-between align-items-center mt-1">
                                                        @if (img.IsPrimary)
                                                        {
                                                            <span class="badge bg-warning text-dark" style="font-size:9px;">Ảnh chính</span>
                                                        }
                                                        <div class="form-check form-check-inline mb-0">
                                                            <input class="form-check-input existing-primary-radio" type="radio" name="existingPrimary" value="@img.Url" @(img.IsPrimary ? "checked" : "") />
                                                        </div>
                                                        <button type="button" class="btn btn-sm btn-danger btn-delete-media p-0 px-1" data-media-id="@img.Id" style="font-size:10px;">X</button>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    }

                    <!-- Giấy tờ xe KH -->
                    @if (khGiayToImages != null && khGiayToImages.Any())
                    {
                        <div class="card mb-3">
                            <div class="card-header bg-info text-white">
                                <strong><i class="fas fa-file-alt"></i> Giấy tờ xe - KH</strong>
                            </div>
                            <div class="card-body">
                                <div class="row g-2">
                                    @foreach (var img in khGiayToImages.OrderByDescending(m => m.CreatedAt))
                                    {
                                        <div class="col-6 col-sm-4 col-md-3 col-lg-2 mb-2" data-media-id="@img.Id" data-media-url="@img.Url">
                                            <div class="card h-100">
                                                <div class="card-body p-1 text-center">
                                                    <a href="@img.Url" target="_blank">
                                                        <img src="@img.Url" class="img-fluid rounded" style="max-height:100px; width:100%; object-fit:cover;" />
                                                    </a>
                                                </div>
                                                <div class="card-footer p-1">
                                                    <small class="d-block text-muted" style="font-size:10px;">@img.Type.GetDisplayName()</small>
                                                    <button type="button" class="btn btn-sm btn-danger btn-delete-media mt-1 w-100 p-0" data-media-id="@img.Id" style="font-size:10px;">Xóa</button>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <!-- Upload mới -->
                <hr />
                <h5 class="mt-4 mb-3 text-primary">
                    <i class="fas fa-upload"></i> Thêm hình ảnh mới
                </h5>

                <!-- Nhóm hình ảnh nhận xe từ GSM -->
                <div class="card mb-3">
                    <div class="card-header bg-success text-white">
                        <strong><i class="fas fa-download"></i> Hình ảnh nhận xe từ GSM</strong>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            @foreach (var type in MediaTypeHelper.GetGSMThanXeTypes())
                            {
                                <div class="col-md-6 col-lg-4 col-xl-3">
                                    @await Html.PartialAsync("~/Views/Shared/_DragAndDropImageUpload.cshtml", type, new ViewDataDictionary(ViewData) { { "Settings", settings } })
                                </div>
                            }
                        </div>
                        <hr/>
                        <h6 class="text-success mb-3 mt-2"><i class="fas fa-file-alt"></i> Hình ảnh giấy tờ xe từ GSM</h6>
                        <div class="row">
                            @foreach (var type in MediaTypeHelper.GetGSMGiayToTypes())
                            {
                                <div class="col-md-6 col-lg-4 col-xl-3">
                                    @await Html.PartialAsync("~/Views/Shared/_DragAndDropImageUpload.cshtml", type, new ViewDataDictionary(ViewData) { { "Settings", settings } })
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <!-- Nhóm hình ảnh giao xe cho KH -->
                <div class="card mb-3">
                    <div class="card-header bg-info text-white">
                        <strong><i class="fas fa-upload"></i> Hình ảnh giao xe cho Khách hàng</strong>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            @foreach (var type in MediaTypeHelper.GetKHThanXeTypes())
                            {
                                <div class="col-md-6 col-lg-4 col-xl-3">
                                    @await Html.PartialAsync("~/Views/Shared/_DragAndDropImageUpload.cshtml", type, new ViewDataDictionary(ViewData) { { "Settings", settings } })
                                </div>
                            }
                        </div>
                        <hr/>
                        <h6 class="text-info mb-3 mt-2"><i class="fas fa-file-alt"></i> Hình ảnh giấy tờ xe cho Khách hàng</h6>
                        <div class="row">
                            @foreach (var type in MediaTypeHelper.GetKHGiayToTypes())
                            {
                                <div class="col-md-6 col-lg-4 col-xl-3">
                                    @await Html.PartialAsync("~/Views/Shared/_DragAndDropImageUpload.cshtml", type, new ViewDataDictionary(ViewData) { { "Settings", settings } })
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <!-- Upload Progress -->
                <div id="uploadProgress" class="mb-3" style="display: none;">
                    <label class="form-label">Đang tải lên...</label>
                    <div class="progress">
                        <div class="progress-bar progress-bar-striped progress-bar-animated"
                             role="progressbar" style="width: 0%"></div>
                    </div>
                </div>

                <div class="form-group mt-4">
                    <button type="submit" class="btn btn-success" id="btnSubmit">
                        <i class="fas fa-save"></i> Lưu thay đổi
                    </button>
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="fas fa-arrow-left"></i> Quay lại
                    </a>
                    <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-info">
                        <i class="fas fa-eye"></i> Xem chi tiết
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    @await Html.PartialAsync("~/Views/Shared/_ImageUploadScript.cshtml")
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const ngayThueInput = document.getElementById('NgayThue');
            const ngayHetHanInput = document.getElementById('NgayHetHan');

            if (ngayThueInput && ngayHetHanInput) {
                ngayThueInput.addEventListener('change', function() {
                    const dateVal = this.value;
                    if (dateVal) {
                        const thueDate = new Date(dateVal);
                        thueDate.setFullYear(thueDate.getFullYear() + 1);

                        const year = thueDate.getFullYear();
                        const month = String(thueDate.getMonth() + 1).padStart(2, '0');
                        const day = String(thueDate.getDate()).padStart(2, '0');

                        ngayHetHanInput.value = `${year}-${month}-${day}`;
                    }
                });
            }
        });
    </script>
}
