@inject IOptions<ChargePoint.CarManagement.Models.FileUploadSettings> FileUploadSettings
@using ChargePoint.CarManagement.Models.ViewModels
@model CarViewModel
@using ChargePoint.CarManagement.Models

@{
    ViewData["Title"] = "Chỉnh sửa xe";
    var settings = FileUploadSettings.Value;
}

<div class="container">
    <h1 class="mb-4">
        <i class="fas fa-edit"></i> Chỉnh sửa xe
    </h1>

    <div class="card shadow">
        <div class="card-body">
            <form asp-action="Edit" enctype="multipart/form-data" id="editCarForm">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="NgayTao" />
                <input type="hidden" asp-for="@Model.HinhAnhNhanBanGiao" />
                <input type="hidden" asp-for="@Model.HinhAnhBanGiaoKH" />
                <input type="hidden" asp-for="@Model.VideoNhanBanGiao" />
                <input type="hidden" asp-for="@Model.VideoBanGiaoKH" />

                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group mb-3">
                            <label asp-for="Stt" class="form-label"></label>
                            <input asp-for="Stt" class="form-control" />
                            <span asp-validation-for="Stt" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="form-group mb-3">
                            <label asp-for="TenXe" class="form-label"></label>
                            <input asp-for="TenXe" class="form-control" />
                            <span asp-validation-for="TenXe" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group mb-3">
                            <label asp-for="SoLuong" class="form-label"></label>
                            <input asp-for="SoLuong" class="form-control" type="number" />
                            <span asp-validation-for="SoLuong" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="form-group mb-3">
                            <label asp-for="MauXe" class="form-label"></label>
                            <input asp-for="MauXe" class="form-control" />
                            <span asp-validation-for="MauXe" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group mb-3">
                            <label asp-for="SoVIN" class="form-label"></label>
                            <input asp-for="SoVIN" class="form-control" maxlength="17" />
                            <span asp-validation-for="SoVIN" class="text-danger"></span>
                            <small class="form-text text-muted">Số VIN phải có 17 ký tự</small>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="form-group mb-3">
                            <label asp-for="BienSo" class="form-label"></label>
                            <input asp-for="BienSo" class="form-control" />
                            <span asp-validation-for="BienSo" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group mb-3">
                            <label asp-for="MauBienSo" class="form-label"></label>
                            <div class="d-flex gap-4 mt-2">
                                <div class="form-check">
                                    <input class="form-check-input" type="radio"
                                           name="MauBienSo" id="bienTrang"
                                           value="@((int)MauBienSo.Trang)"
                                           @(Model.MauBienSo == MauBienSo.Trang ? "checked" : "") />
                                    <label class="form-check-label" for="bienTrang">
                                        <span class="badge text-dark" style="background-color: #fff; border: 2px solid #333; padding: 8px 16px; font-size: 14px;">
                                            <i class="fas fa-car"></i> Biển trắng
                                        </span>
                                    </label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="radio"
                                           name="MauBienSo" id="bienVang"
                                           value="@((int)MauBienSo.Vang)"
                                           @(Model.MauBienSo == MauBienSo.Vang ? "checked" : "") />
                                    <label class="form-check-label" for="bienVang">
                                        <span class="badge text-dark" style="background-color: #ffc107; border: 2px solid #333; padding: 8px 16px; font-size: 14px;">
                                            <i class="fas fa-taxi"></i> Biển vàng
                                        </span>
                                    </label>
                                </div>
                            </div>
                            <span asp-validation-for="MauBienSo" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="form-group mb-3">
                            <label asp-for="TenKhachHang" class="form-label"></label>
                            <input asp-for="TenKhachHang" class="form-control" />
                            <span asp-validation-for="TenKhachHang" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group mb-3">
                            <label asp-for="OdoXe" class="form-label"></label>
                            <input asp-for="OdoXe" class="form-control" type="number" />
                            <span asp-validation-for="OdoXe" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="ThongTinChoThue" class="form-label"></label>
                    <textarea asp-for="ThongTinChoThue" class="form-control" rows="3"></textarea>
                    <span asp-validation-for="ThongTinChoThue" class="text-danger"></span>
                </div>

                <!-- Hình ảnh & Video (multiple) -->
                <h5 class="mt-4 mb-3 text-primary">
                    <i class="fas fa-images"></i> Hình ảnh & Video bàn giao 
                </h5>

                <input type="hidden" id="PrimaryImageUrl" name="PrimaryImageUrl" value="@Model.PrimaryImageUrl" />

                @* Primary image input (upload alongside main form) *@
                <div class="row mb-3">
                    <div class="col-md-12">
                        <label class="form-label"><i class="fas fa-star"></i> Ảnh chính (chọn để upload khi lưu)</label>
                        <div class="d-flex gap-2 align-items-center">
                            <input type="file" name="PrimaryImageFile" id="PrimaryImageFile" accept="@string.Join(",", settings.AllowedImageExtensions.Select(e => "image/" + e.TrimStart('.')))" class="form-control" />
                            <span id="primaryUploadStatus" class="text-muted ms-2"></span>
                        </div>
                        <small class="form-text text-muted">Nếu chọn ảnh chính ở đây, file sẽ được upload khi bạn nhấn 'Lưu thay đổi'. Nếu không chọn, hệ thống dùng ảnh chính hiện tại hoặc tự chọn ảnh GSM đầu tiên.</small>
                        <div id="primaryPreview" class="mt-2">
                            @if (!string.IsNullOrEmpty(Model.PrimaryImageUrl))
                            {
                                <img src="@Model.PrimaryImageUrl" class="img-thumbnail" style="max-height:150px;" />
                            }
                        </div>
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-md-6">
                        <label class="form-label"><i class="fas fa-image"></i> Hình ảnh nhận bàn giao từ GSM (GF) - multiple</label>
                        <input type="file" name="HinhAnhNhanBanGiaoFiles" id="HinhAnhNhanBanGiaoFiles" multiple accept="@string.Join(",", settings.AllowedImageExtensions.Select(e => "image/" + e.TrimStart('.')))" class="form-control file-upload-multi" data-max-size="@settings.MaxImageSizeMB" data-type="image" />
                        <small class="form-text text-muted">Tối đa @settings.MaxImageSizeMB MB mỗi file. Định dạng: @string.Join(", ", settings.AllowedImageExtensions)</small>
                        <div class="file-multi-preview mt-2"></div>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label"><i class="fas fa-image"></i> Hình ảnh bàn giao cho KH - multiple</label>
                        <input type="file" name="HinhAnhBanGiaoKHFiles" id="HinhAnhBanGiaoKHFiles" multiple accept="@string.Join(",", settings.AllowedImageExtensions.Select(e => "image/" + e.TrimStart('.')))" class="form-control file-upload-multi" data-max-size="@settings.MaxImageSizeMB" data-type="image" />
                        <small class="form-text text-muted">Tối đa @settings.MaxImageSizeMB MB mỗi file. Định dạng: @string.Join(", ", settings.AllowedImageExtensions)</small>
                        <div class="file-multi-preview mt-2"></div>
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-md-6">
                        <label class="form-label"><i class="fas fa-film"></i> Video nhận bàn giao từ GSM - multiple</label>
                        <input type="file" name="VideoNhanBanGiaoFiles" id="VideoNhanBanGiaoFiles" multiple accept="@string.Join(",", settings.AllowedVideoExtensions.Select(e => "video/" + e.TrimStart('.')))" class="form-control file-upload-multi" data-max-size="@settings.MaxVideoSizeMB" data-type="video" />
                        <small class="form-text text-muted">Tối đa @settings.MaxVideoSizeMB MB mỗi file. Định dạng: @string.Join(", ", settings.AllowedVideoExtensions)</small>
                        <div class="file-multi-preview mt-2"></div>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label"><i class="fas fa-film"></i> Video bàn giao cho KH - multiple</label>
                        <input type="file" name="VideoBanGiaoKHFiles" id="VideoBanGiaoKHFiles" multiple accept="@string.Join(",", settings.AllowedVideoExtensions.Select(e => "video/" + e.TrimStart('.')))" class="form-control file-upload-multi" data-max-size="@settings.MaxVideoSizeMB" data-type="video" />
                        <small class="form-text text-muted">Tối đa @settings.MaxVideoSizeMB MB mỗi file. Định dạng: @string.Join(", ", settings.AllowedVideoExtensions)</small>
                        <div class="file-multi-preview mt-2"></div>
                    </div>
                </div>

                <!-- Existing media gallery -->
                @if (Model.Media != null && Model.Media.Any())
                {
                    <div class="existing-media mb-3">
                        <h6>Media hiện có</h6>
                        <div class="row">
                            @foreach (var m in Model.Media.OrderByDescending(x => x.IsPrimary).ThenBy(x => x.CreatedAt))
                            {
                                <div class="col-sm-6 col-md-3 mb-3" data-media-id="@m.Id" data-media-url="@m.Url">
                                    <div class="card h-100">
                                        <div class="card-body p-2 text-center">
                                            @if (m.Type == MediaType.Image_GSM || m.Type == MediaType.Image_KH)
                                            {
                                                <img src="@m.Url" class="img-fluid" style="max-height:150px;" />
                                            }
                                            else
                                            {
                                                <video src="@m.Url" controls style="max-height:150px; width:100%"></video>
                                            }
                                        </div>
                                        <div class="card-footer d-flex justify-content-between align-items-center py-2">
                                            <div class="form-check">
                                                <input class="form-check-input existing-primary-radio" type="radio" name="existingPrimary" value="@m.Url" @(m.IsPrimary ? "checked" : "") />
                                                <label class="form-check-label">Ảnh chính</label>
                                            </div>
                                            <button type="button" class="btn btn-sm btn-danger btn-delete-media" data-media-id="@m.Id">Xóa</button>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }

                <!-- Upload Progress -->
                <div id="uploadProgress" class="mb-3" style="display: none;">
                    <label class="form-label">Đang tải lên...</label>
                    <div class="progress">
                        <div class="progress-bar progress-bar-striped progress-bar-animated"
                             role="progressbar" style="width: 0%"></div>
                    </div>
                </div>

                <div class="form-group mt-4">
                    <button type="submit" class="btn btn-success" id="btnSubmit">
                        <i class="fas fa-save"></i> Lưu thay đổi
                    </button>
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="fas fa-arrow-left"></i> Quay lại
                    </a>
                    <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-info">
                        <i class="fas fa-eye"></i> Xem chi tiết
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const form = document.getElementById('editCarForm');
            const btnSubmit = document.getElementById('btnSubmit');

            // multi file previews and validation
            document.querySelectorAll('.file-upload-multi').forEach(function(input) {
                input.addEventListener('change', function() {
                    validateMultiFiles(this);
                });
            });

            function validateMultiFiles(input) {
                const files = Array.from(input.files || []);
                const maxSize = parseInt(input.dataset.maxSize) * 1024 * 1024;
                const type = input.dataset.type;
                const preview = input.parentElement.querySelector('.file-multi-preview');
                preview.innerHTML = '';

                for (const file of files) {
                    if (file.size > maxSize) {
                        alert(`File ${file.name} quá lớn. Tối đa ${input.dataset.maxSize} MB.`);
                        input.value = '';
                        preview.innerHTML = '';
                        return;
                    }

                    if (type === 'image') {
                        const reader = new FileReader();
                        reader.onload = function(e) {
                            const div = document.createElement('div');
                            div.className = 'd-inline-block me-2 mb-2';
                            div.innerHTML = `<img src="${e.target.result}" style="max-height:100px;" class="img-thumbnail"/>`;
                            preview.appendChild(div);
                        };
                        reader.readAsDataURL(file);
                    } else {
                        const div = document.createElement('div');
                        div.className = 'd-inline-block me-2 mb-2 p-2 border rounded';
                        div.innerHTML = `<i class="fas fa-file-video"></i> ${file.name}`;
                        preview.appendChild(div);
                    }
                }
            }

            // existing primary selection
            document.querySelectorAll('.existing-primary-radio').forEach(function(r) {
                r.addEventListener('change', function(e) {
                    document.getElementById('PrimaryImageUrl').value = e.target.value;
                });
            });

            // initialize primary input from checked radio
            const checked = document.querySelector('.existing-primary-radio:checked');
            if (checked) document.getElementById('PrimaryImageUrl').value = checked.value;

            // delete media via AJAX
            document.querySelectorAll('.btn-delete-media').forEach(function(btn) {
                btn.addEventListener('click', function() {
                    const mediaId = parseInt(btn.getAttribute('data-media-id'));
                    if (!confirm('Xác nhận xóa media?')) return;

                    const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';

                    fetch('@Url.Action("DeleteMedia", "Cars")', {
                        method: 'POST',
                        headers: {
                            'RequestVerificationToken': token,
                            'Content-Type': 'application/json'
                        },
                        body: JSON.stringify({ id: mediaId })
                    })
                    .then(r => r.json())
                    .then(data => {
                        if (data && data.success) {
                            // remove card
                            const card = btn.closest('[data-media-id]');
                            if (card) card.remove();
                            // if deleted was primary, clear hidden or set replacement handled server-side
                            const primaryInput = document.getElementById('PrimaryImageUrl');
                            if (primaryInput && primaryInput.value === data.deletedUrl) {
                                primaryInput.value = '';
                            }
                        } else {
                            alert('Xóa thất bại');
                        }
                    })
                    .catch(() => alert('Xóa thất bại'));
                });
            });

            // primary file preview (no immediate upload). If a new primary is chosen, clear hidden PrimaryImageUrl
            const primaryFileInput = document.getElementById('PrimaryImageFile');
            const primaryStatus = document.getElementById('primaryUploadStatus');
            const primaryPreview = document.getElementById('primaryPreview');
            const hiddenPrimary = document.getElementById('PrimaryImageUrl');

            if (primaryFileInput) {
                primaryFileInput.addEventListener('change', function () {
                    const file = this.files && this.files[0];
                    primaryPreview.innerHTML = '';
                    primaryStatus.textContent = '';

                    if (!file) return;

                    // basic client-side size check (optional)
                    const maxSize = parseInt('@settings.MaxImageSizeMB') * 1024 * 1024;
                    if (file.size > maxSize) {
                        primaryStatus.textContent = `File quá lớn. Tối đa @settings.MaxImageSizeMB MB.`;
                        this.value = '';
                        return;
                    }

                    // clear selection of existing primary (so server can detect the new file)
                    if (hiddenPrimary) hiddenPrimary.value = '';

                    // show preview
                    if (file.type.startsWith('image/')) {
                        const reader = new FileReader();
                        reader.onload = function (e) {
                            primaryPreview.innerHTML = `<img src="${e.target.result}" class="img-thumbnail" style="max-height:150px;">`;
                        };
                        reader.readAsDataURL(file);
                    } else {
                        primaryPreview.innerHTML = `<div class="alert alert-info py-2"><i class="fas fa-file-image"></i> ${file.name}</div>`;
                    }
                });
            }

            form.addEventListener('submit', function(e) {
                const hasInvalid = false; // client-side simple

                // include primaryFileInput in hasFiles check so UI shows progress when file(s) exist
                const hasFiles = Array.from(form.querySelectorAll('.file-upload-multi')).some(i => i.files.length > 0)
                                  || (primaryFileInput && primaryFileInput.files && primaryFileInput.files.length > 0);

                if (hasFiles) {
                    btnSubmit.disabled = true;
                    btnSubmit.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Đang tải lên...';
                    document.getElementById('uploadProgress').style.display = 'block';
                }
            });
        });
    </script>

    <style>
        .file-upload-multi.is-valid { border-color: #198754; }
        .file-upload-multi.is-invalid { border-color: #dc3545; }
        .file-multi-preview img { max-width: 100%; border-radius: 8px; }
        .current-file { padding: 10px; background-color: #f8f9fa; border-radius: 8px; border: 1px solid #dee2e6; }
        #primaryPreview img { border-radius: 8px; }
    </style>
}
