@using ChargePoint.CarManagement.Domain.Entities
@model ChargePoint.CarManagement.Domain.ViewModels.PagedResult<ChargePoint.CarManagement.Domain.Entities.Car>

@{
    ViewData["Title"] = "Quản lý xe";
    var searchQuery = Model.SearchQuery ?? "";
    var page = Model.PageNumber;
    var pageSize = Model.PageSize;
    var totalCount = Model.TotalCount;
    var totalPages = Model.TotalPages;
}

<div class="container-fluid">
    <h1 class="mb-4">
        <i class="fas fa-car"></i> Quản lý xe
    </h1>

    <div class="row mb-3">
        <div class="col-md-8">
            <form asp-action="Index" method="get" class="d-flex" role="search">
                <input name="q" value="@searchQuery" class="form-control me-2" placeholder="Tìm theo biển số, tên xe, VIN, khách hàng, màu..." aria-label="Search" />
                <button class="btn btn-outline-primary" type="submit">
                    <i class="fas fa-search"></i> Tìm
                </button>
                @if (!string.IsNullOrWhiteSpace(searchQuery))
                {
                    <a asp-action="Index" class="btn btn-outline-secondary ms-2">
                        <i class="fas fa-times"></i> Xóa
                    </a>
                }
            </form>
        </div>
        <div class="col-md-4 text-end">
            <!-- Nút Import File -->
            <button type="button" class="btn btn-outline-info shadow-sm" data-bs-toggle="modal" data-bs-target="#importModal">
                <i class="fas fa-file-excel me-1"></i> Import Excel
            </button>

            <a asp-action="Create" class="btn btn-success shadow-sm ms-2">
                <i class="fas fa-plus"></i> Thêm xe mới
            </a>
        </div>
    </div>

    <div class="card shadow">
        <div class="card-body">
            <div class="d-flex justify-content-between mb-2">
                <div>
                    @if (!string.IsNullOrWhiteSpace(searchQuery))
                    {
                        <small class="text-muted">Kết quả tìm kiếm cho: <strong>@searchQuery</strong> — @totalCount kết quả</small>
                    }
                    else
                    {
                        <small class="text-muted">@totalCount xe</small>
                    }
                </div>
                <div>
                    <form asp-action="Index" method="get" class="d-inline">
                        <input type="hidden" name="q" value="@searchQuery" />
                        <label class="me-2">Hiển thị</label>
                        <select name="pageSize" class="form-select d-inline-block" style="width: auto;"
                                onchange="this.form.submit()">
                            <option value="5" selected="@(pageSize == 5 ? "selected" : null)">5</option>
                            <option value="10" selected="@(pageSize == 10 ? "selected" : null)">10</option>
                            <option value="25" selected="@(pageSize == 25 ? "selected" : null)">25</option>
                            <option value="50" selected="@(pageSize == 50 ? "selected" : null)">50</option>
                        </select>
                    </form>
                </div>
            </div>
            <div class="table-responsive">
                <table class="table table-striped table-hover align-middle">
                    <thead class="table-dark">
                        <tr class="text-nowrap">
                            <th>@Html.DisplayNameFor(model => model.Items.First().Stt)</th>
                            <th>@Html.DisplayNameFor(model => model.Items.First().TenXe)</th>
                            <th>@Html.DisplayNameFor(model => model.Items.First().MauXe)</th>
                            <th>@Html.DisplayNameFor(model => model.Items.First().SoVIN)</th>
                            <th>@Html.DisplayNameFor(model => model.Items.First().BienSo)</th>
                            <th>@Html.DisplayNameFor(model => model.Items.First().TenKhachHang)</th>
                            <th>@Html.DisplayNameFor(model => model.Items.First().OdoXe)</th>
                            <th>Hình ảnh</th>
                            <th>Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Items)
                        {
                            <tr class="text-nowrap">
                                <td>@Html.DisplayFor(modelItem => item.Stt)</td>
                                <td>@Html.DisplayFor(modelItem => item.TenXe)</td>
                                <td>@Html.DisplayFor(modelItem => item.MauXe)</td>
                                <td>
                                    <small class="text-muted">@Html.DisplayFor(modelItem => item.SoVIN)</small>
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(item.BienSo))
                                    {
                                        @if (item.MauBienSo == MauBienSo.Vang)
                                        {
                                            <span class="license-plate license-plate-yellow">
                                                @item.BienSo
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="license-plate license-plate-white">
                                                @item.BienSo
                                            </span>
                                        }
                                    }
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(item.TenKhachHang))
                                    {
                                        @if (item.TenKhachHang.Length > 20)
                                        {
                                            <span title="@item.TenKhachHang" data-bs-toggle="tooltip">
                                                @item.TenKhachHang.Substring(0, 20)...
                                            </span>
                                        }
                                        else
                                        {
                                            @item.TenKhachHang
                                        }
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                <td>
                                    <strong class="text-primary">@item.OdoXe.ToString("N0")</strong>
                                </td>
                                <td>
                                    <div class="d-flex gap-2">
                                        @* Show only primary image if available *@
                                        @if (!string.IsNullOrEmpty(item.PrimaryImageUrl))
                                        {
                                            <a href="@item.PrimaryImageUrl" target="_blank">
                                                <img src="@item.PrimaryImageUrl" alt="Primary" class="img-thumbnail" style="width: 80px; height: 80px; object-fit: cover; cursor: pointer;" title="Ảnh chính - Click để xem" />
                                            </a>
                                        }
                                        else
                                        {
                                            <span class="text-muted"><i class="fas fa-image"></i> Chưa có ảnh chính</span>
                                        }
                                    </div>
                                </td>
                                <td>
                                    <div class="d-flex gap-2">
                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info" title="Chi tiết">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning" title="Chỉnh sửa">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger" title="Xóa">
                                            <i class="fas fa-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (!Model.Any())
            {
                <div class="alert alert-info text-center">
                    <i class="fas fa-info-circle"></i> Chưa có xe nào trong hệ thống. Vui lòng thêm xe mới.
                </div>
            }
            @if (!Model.Items.Any())
            {
                <div class="alert alert-info text-center">
                    <i class="fas fa-info-circle"></i> Không tìm thấy xe phù hợp. Vui lòng thử lại.
                </div>
            }

            @* Pagination *@
            @if (totalPages > 1)
            {
                <div class="card-footer bg-light">
                    <nav aria-label="Page navigation">
                        <ul class="pagination justify-content-center mb-0">
                            <!-- Previous -->
                            <li class="page-item @(page <= 1 ? "disabled" : "")">
                                <a class="page-link" asp-action="Index" asp-route-q="@searchQuery"
                                   asp-route-page="@(page - 1)" asp-route-pageSize="@pageSize"
                                   aria-label="Previous">
                                    <span aria-hidden="true">&laquo;</span> Trước
                                </a>
                            </li>

                            @{
                                var startPage = Math.Max(1, page - 2);
                                var endPage = Math.Min(totalPages, page + 2);

                                // Show first page if not in range
                                if (startPage > 1)
                                {
                                    <li class="page-item">
                                        <a class="page-link" asp-action="Index" asp-route-q="@searchQuery"
                                           asp-route-page="1" asp-route-pageSize="@pageSize">1</a>
                                    </li>
                                    if (startPage > 2)
                                    {
                                        <li class="page-item disabled">
                                            <span class="page-link">…</span>
                                        </li>
                                    }
                                }

                                // Page numbers
                                for (var p = startPage; p <= endPage; p++)
                                {
                                    <li class="page-item @(p == page ? "active" : "")">
                                        <a class="page-link" asp-action="Index" asp-route-q="@searchQuery"
                                           asp-route-page="@p" asp-route-pageSize="@pageSize">
                                            @p
                                            @if (p == page)
                                            {
                                                <span class="visually-hidden">(current)</span>
                                            }
                                        </a>
                                    </li>
                                }

                                // Show last page if not in range
                                if (endPage < totalPages)
                                {
                                    if (endPage < totalPages - 1)
                                    {
                                        <li class="page-item disabled">
                                            <span class="page-link">…</span>
                                        </li>
                                    }
                                    <li class="page-item">
                                        <a class="page-link" asp-action="Index" asp-route-q="@searchQuery"
                                           asp-route-page="@totalPages" asp-route-pageSize="@pageSize">@totalPages</a>
                                    </li>
                                }
                            }

                            <!-- Next -->
                            <li class="page-item @(page >= totalPages ? "disabled" : "")">
                                <a class="page-link" asp-action="Index" asp-route-q="@searchQuery"
                                   asp-route-page="@(page + 1)" asp-route-pageSize="@pageSize"
                                   aria-label="Next">
                                    Sau <span aria-hidden="true">&raquo;</span>
                                </a>
                            </li>
                        </ul>
                    </nav>

                    @* Page info *@
                    <div class="text-center mt-2">
                        <small class="text-muted">
                            @if (totalPages > 1)
                            {
                                <span>Trang <strong>@(page)</strong> / @totalPages</span>
                                <span class="mx-2">|</span>
                            }
                            <span>Hiển thị @((page - 1) * pageSize + 1) - @Math.Min(page * pageSize, totalCount) trong tổng số <strong>@(totalCount)</strong> xe</span>
                        </small>
                    </div>
                </div>
            }
            else if (totalCount > 0)
            {
                <div class="card-footer bg-light">
                    <div class="text-center">
                        <small class="text-muted">
                            <i class="fas fa-info-circle"></i>
                            Hiển thị tất cả <strong>@totalCount</strong> xe
                        </small>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<!-- Modal Import Bulk -->
<div class="modal fade" id="importModal" tabindex="-1" aria-labelledby="importModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <form asp-action="BulkImport" method="post" enctype="multipart/form-data">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="importModalLabel">
                        <i class="fas fa-file-import text-info me-2"></i> Import File Excel
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <label for="file" class="form-label text-muted mb-0">Chọn file (.xlsx)</label>
                            <a asp-action="DownloadTemplate" class="btn btn-sm btn-outline-success">
                                <i class="fas fa-download"></i> Tải file mẫu
                            </a>
                        </div>
                        <input class="form-control" type="file" id="file" name="file" accept=".xlsx" required />
                    </div>
                    <div class="alert alert-warning" role="alert" style="font-size: 13px;">
                        <i class="fas fa-lightbulb me-1"></i> <strong>Lưu ý cấu trúc file:</strong>
                        <ul class="mb-0 mt-1 ps-3">
                            <li>Dữ liệu sẽ được đọc từ <strong>Tab đầu tiên (Sheet 1)</strong>.</li>
                            <li>Dữ liệu thực tính từ <strong>dòng số 2</strong>.</li>
                            <li><strong>Cột B</strong> (Index 2): <code>Số Khung</code> (Bắt buộc 15 ký tự - Số VIN)</li>
                            <li><strong>Cột C</strong> (Index 3): <code>Tên xe</code></li>
                            <li><strong>Cột D</strong> (Index 4): <code>Biển Số</code></li>
                            <li><strong>Cột E</strong> (Index 5): <code>Biển số cũ</code></li>
                            <li><strong>Cột F</strong> (Index 6): <code>Màu xe</code></li>
                            <li><strong>Cột G</strong> (Index 7): <code>Loại biển</code> (Biển trắng / Biển vàng)</li>
                            <li><strong>Cột H</strong> (Index 8): <code>Khách hàng</code></li>
                            <li><strong>Cột I</strong> (Index 9): <code>Số ODO</code></li>
                            <li><strong>Cột J</strong> (Index 10): <code>Ngày thuê</code> (DD/MM/YYYY)</li>
                            <li><strong>Cột K</strong> (Index 11): <code>Ngày hết hạn hợp đồng</code> (DD/MM/YYYY)</li>
                        </ul>
                    </div>

                    <!-- Khu vực Hiển thị Tiến trình / Kết quả Import -->
                    <div id="importResultArea" style="display: none;">
                        <div id="importLoading" class="text-center py-4">
                            <div class="spinner-border text-primary" role="status">
                                <span class="visually-hidden">Loading...</span>
                            </div>
                            <p class="mt-2 text-muted">Đang xử lý dữ liệu, vui lòng chờ...</p>
                        </div>

                        <div id="importSuccess" style="display: none;">
                            <div class="alert alert-success mt-2">
                                <i class="fas fa-check-circle me-1"></i> <span id="importSuccessMessage"></span>
                            </div>

                            <h6 class="mt-3 text-danger fw-bold" id="skippedTitle" style="display:none;">
                                <i class="fas fa-exclamation-triangle"></i> Các dòng bị lỗi và bỏ qua:
                            </h6>
                            <div id="skippedTableContainer" class="table-responsive" style="max-height: 250px; display: none;">
                                <table class="table table-sm table-bordered table-striped" style="font-size: 13px;">
                                    <thead class="table-danger">
                                        <tr>
                                            <th>Lỗi chi tiết</th>
                                        </tr>
                                    </thead>
                                    <tbody id="skippedTableBody">
                                        <!-- Render rows per JS -->
                                    </tbody>
                                </table>
                            </div>
                        </div>

                        <div id="importError" class="alert alert-danger mt-2" style="display: none;">
                            <i class="fas fa-times-circle me-1"></i> <span id="importErrorMessage"></span>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" onclick="window.location.reload();" id="btnCloseModal" style="display:none;" data-bs-dismiss="modal">Đóng & Tải lại</button>
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal" id="btnCancelModal">Hủy</button>
                    <button type="submit" class="btn btn-primary" id="btnSubmitImport">
                        <i class="fas fa-upload me-1"></i> Bắt đầu Import
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <script>
        document.querySelector('#importModal form').addEventListener('submit', async function (e) {
            e.preventDefault();

            var form = this;
            var formData = new FormData(form);

            // Giao diện loading
            document.querySelector('.alert-warning').style.display = 'none';
            document.getElementById('importResultArea').style.display = 'block';
            document.getElementById('importLoading').style.display = 'block';
            document.getElementById('importSuccess').style.display = 'none';
            document.getElementById('importError').style.display = 'none';
            document.getElementById('btnSubmitImport').style.display = 'none';
            document.getElementById('btnCancelModal').style.display = 'none';

            try {
                let response = await fetch(form.action, {
                    method: 'POST',
                    body: formData,
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest'
                    }
                });

                let result = await response.json();
                document.getElementById('importLoading').style.display = 'none';
                document.getElementById('btnCloseModal').style.display = 'inline-block';

                if (result.success) {
                    document.getElementById('importSuccess').style.display = 'block';
                    const duplicateCount = (result.duplicateVins && result.duplicateVins.length) ? result.duplicateVins.length : 0;
                    document.getElementById('importSuccessMessage').innerText = `Đã xử lý file thành công: Thêm mới ${result.addedCount} xe, Cập nhật ${result.updatedCount} xe, VIN trùng ${duplicateCount}.`;

                    if (result.skippedRows && result.skippedRows.length > 0) {
                        document.getElementById('skippedTitle').style.display = 'block';
                        document.getElementById('skippedTableContainer').style.display = 'block';

                        let tbody = document.getElementById('skippedTableBody');
                        tbody.innerHTML = '';
                        result.skippedRows.forEach(err => {
                            let tr = document.createElement('tr');
                            let td = document.createElement('td');
                            td.innerText = err;
                            tr.appendChild(td);
                            tbody.appendChild(tr);
                        });
                    }
                } else {
                    document.getElementById('importError').style.display = 'block';
                    document.getElementById('importErrorMessage').innerText = result.message || "Có lỗi xảy ra khi upload file.";
                }

            } catch (error) {
                console.error(error);
                document.getElementById('importLoading').style.display = 'none';
                document.getElementById('importError').style.display = 'block';
                document.getElementById('importErrorMessage').innerText = "Lỗi kết nối hoặc máy chủ không phản hồi.";
                document.getElementById('btnCloseModal').style.display = 'inline-block';
            }
        });
    </script>
}
