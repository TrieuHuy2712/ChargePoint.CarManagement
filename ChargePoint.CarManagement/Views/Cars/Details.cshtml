@model CarViewModel
@using ChargePoint.CarManagement.Models.ViewModels
@using ChargePoint.CarManagement.Models
@inject Microsoft.Extensions.Options.IOptions<ChargePoint.CarManagement.Models.FileUploadSettings> FileUploadSettings

@{
    ViewData["Title"] = "Chi tiết xe";
    var settings = FileUploadSettings.Value;
}

<div class="container">
    <h1 class="mb-4">
        <i class="fas fa-info-circle"></i> Chi tiết xe
    </h1>

    <div class="card shadow">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0">
                <i class="fas fa-car"></i> @Model.TenXe
            </h5>
        </div>
        <div class="card-body">

            <!-- Primary image display -->
            <div class="row mb-3">
                <div class="col-12 text-center">
                    <h6 class="mb-2"><i class="fas fa-star text-warning"></i> Ảnh chính</h6>
                    @if (!string.IsNullOrEmpty(Model.PrimaryImageUrl))
                    {
                        <a href="@Model.PrimaryImageUrl" target="_blank">
                            <img src="@Model.PrimaryImageUrl" alt="Primary image" class="img-fluid rounded" style="max-height: 300px; cursor: pointer;" />
                        </a>
                        <div class="mt-2">
                            <a href="@Model.PrimaryImageUrl" target="_blank" class="btn btn-sm btn-outline-primary">
                                <i class="fas fa-external-link-alt"></i> Xem ảnh gốc
                            </a>
                        </div>
                    }
                    else
                    {
                        <p class="text-muted py-4"><i class="fas fa-image fa-3x"></i><br />Chưa có ảnh chính</p>
                    }
                </div>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <table class="table table-borderless">
                        <tr>
                            <th style="width: 40%;">@Html.DisplayNameFor(model => model.Stt)</th>
                            <td><span class="badge bg-secondary fs-6">@Model.Stt</span></td>
                        </tr>
                        <tr>
                            <th>@Html.DisplayNameFor(model => model.TenXe)</th>
                            <td><strong>@Model.TenXe</strong></td>
                        </tr>
                        <tr>
                            <th>@Html.DisplayNameFor(model => model.SoLuong)</th>
                            <td><span class="badge bg-primary">@Model.SoLuong</span></td>
                        </tr>
                        <tr>
                            <th>@Html.DisplayNameFor(model => model.MauXe)</th>
                            <td>@Model.MauXe</td>
                        </tr>
                        <tr>
                            <th>@Html.DisplayNameFor(model => model.SoVIN)</th>
                            <td><code>@Model.SoVIN</code></td>
                        </tr>
                        <tr>
                            <th>@Html.DisplayNameFor(model => model.BienSo)</th>
                            <td>
                                @if (!string.IsNullOrEmpty(Model.BienSo))
                                {
                                    @if (Model.MauBienSo == MauBienSo.Vang)
                                    {
                                        <span class="license-plate license-plate-yellow">@Model.BienSo</span>
                                    }
                                    else
                                    {
                                        <span class="license-plate license-plate-white">@Model.BienSo</span>
                                    }
                                }
                                else
                                {
                                    <span class="text-muted">Chưa có</span>
                                }
                            </td>
                        </tr>
                        <tr>
                            <th>@Html.DisplayNameFor(model => model.MauBienSo)</th>
                            <td>
                                @if (Model.MauBienSo == MauBienSo.Vang)
                                {
                                    <span class="badge" style="background-color: #ffc107; color: #000;">
                                        <i class="fas fa-taxi"></i> Biển vàng
                                    </span>
                                }
                                else
                                {
                                    <span class="badge" style="background-color: #fff; color: #000; border: 1px solid #333;">
                                        <i class="fas fa-car"></i> Biển trắng
                                    </span>
                                }
                            </td>
                        </tr>
                    </table>
                </div>
                <div class="col-md-6">
                    <table class="table table-borderless">
                        <tr>
                            <th style="width: 40%;">@Html.DisplayNameFor(model => model.TenKhachHang)</th>
                            <td>
                                @if (!string.IsNullOrEmpty(Model.TenKhachHang))
                                {
                                    <i class="fas fa-user text-primary"></i>
                                    @Model.TenKhachHang
                                }
                                else
                                {
                                    <span class="text-muted">Chưa có</span>
                                }
                            </td>
                        </tr>
                        <tr>
                            <th>@Html.DisplayNameFor(model => model.OdoXe)</th>
                            <td>
                                <strong class="text-success">
                                    <i class="fas fa-tachometer-alt"></i> @Model.OdoXe.ToString("N0") km
                                </strong>
                            </td>
                        </tr>
                        <tr>
                            <th>@Html.DisplayNameFor(model => model.NgayThue)</th>
                            <td>
                                @if (Model.NgayThue.HasValue)
                                {
                                    <i class="fas fa-calendar-alt text-primary"></i> @Model.NgayThue.Value.ToString("dd/MM/yyyy")
                                }
                                else
                                {
                                    <span class="text-muted">Chưa có</span>
                                }
                            </td>
                        </tr>
                        <tr>
                            <th>@Html.DisplayNameFor(model => model.NgayHetHan)</th>
                            <td>
                                @if (Model.NgayHetHan.HasValue)
                                {
                                    <i class="fas fa-calendar-times text-danger"></i> @Model.NgayHetHan.Value.ToString("dd/MM/yyyy")
                                }
                                else
                                {
                                    <span class="text-muted">Chưa có</span>
                                }
                            </td>
                        </tr>
                        <tr>
                            <th>@Html.DisplayNameFor(model => model.ThongTinChoThue)</th>
                            <td>
                                @if (!string.IsNullOrEmpty(Model.ThongTinChoThue))
                                {
                                    <div class="p-2 bg-light rounded">
                                        <i class="fas fa-info-circle text-info"></i> @Model.ThongTinChoThue
                                    </div>
                                }
                                else
                                {
                                    <span class="text-muted">Chưa có thông tin</span>
                                }
                            </td>
                        </tr>
                    </table>
                </div>
            </div>

            <!-- Management Links -->
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-primary bg-opacity-10">
                    <h6 class="mb-0 text-primary fw-bold"><i class="fas fa-cogs me-2"></i>Bảng điều khiển</h6>
                </div>
                <div class="card-body">
                    <div class="d-flex flex-wrap gap-2">
                        <a asp-controller="Maintenance" asp-action="History" asp-route-id="@Model.Id" class="btn btn-info">
                            <i class="fas fa-tools me-2"></i>Quản lý bảo dưỡng
                        </a>
                        <a asp-controller="Tire" asp-action="CarDetail" asp-route-id="@Model.Id" class="btn btn-warning">
                            <i class="fas fa-dot-circle me-2"></i>Quản lý lốp xe
                        </a>
                    </div>
                </div>
            </div>

            <hr />

            <partial name="_AuditInfoSidebar" model="Model" />

            @{
                // Lấy tất cả hình ảnh, loại trừ 2 nhóm folder Image_GSM và Image_KH (nếu có), sắp xếp để ảnh cùng bộ phận nằm cạnh nhau
                var sliderMedia = Model.Media?
                .Where(m => !string.IsNullOrEmpty(m.Url) && m.Type != MediaType.Image_GSM && m.Type != MediaType.Image_KH && m.Type != MediaType.Image_Primary)
                    .OrderBy(m => m.Type)
                    .ThenByDescending(m => m.CreatedAt)
                    .ToList();
            }

            @if (sliderMedia != null && sliderMedia.Any())
            {
                <h5 class="mb-3 mt-4 text-primary"><i class="fas fa-film"></i> Trình duyệt tất cả hình ảnh (Slider)</h5>
                <div class="card mb-4 pb-2 border-primary border-opacity-25">
                    <div class="card-body bg-light">
                        <!-- Swiper CSS -->
                        <link rel="stylesheet" href="https://unpkg.com/swiper/swiper-bundle.min.css" />
                        <style>
                            .detail-slider-wrapper { position: relative; padding: 0 50px; }
                            .detail-slider-wrapper .swiper-button-next,
                            .detail-slider-wrapper .swiper-button-prev { 
                                top: 45%; transform: translateY(-50%); width: 40px; height: 40px; background: rgba(0,0,0,0.5); border-radius: 50%; color: white; border: 1px solid #fff;
                            }
                            .detail-slider-wrapper .swiper-button-next::after, 
                            .detail-slider-wrapper .swiper-button-prev::after { font-size: 18px; }
                        </style>

                        <div class="detail-slider-wrapper">
                            <div class="swiper-button-prev detail-prev"></div>
                            <div class="swiper-button-next detail-next"></div>

                            <div class="swiper-container detail-image-slider" style="overflow: hidden; border-radius: 8px;">
                                <div class="swiper-wrapper">
                                    @foreach (var m in sliderMedia)
                                    {
                                        <div class="swiper-slide text-center position-relative">
                                            <a href="@m.Url" target="_blank" title="Mở hình ảnh">
                                                <img src="@m.Url" style="height: 500px; width: 100%; object-fit: contain; background: #e9ecef;" />
                                            </a>
                                            <!-- Hiển thị thông tin ảnh đè lên dưới cùng -->
                                            <div class="position-absolute bottom-0 start-0 w-100 bg-dark bg-opacity-75 text-white py-2" style="z-index: 10;">
                                                <h6 class="mb-1 text-warning fw-bold">@m.Type.GetDisplayName()</h6>
                                                <small class="text-light">Tải lên: @m.CreatedAt.ToString("dd/MM/yyyy HH:mm")</small>
                                            </div>
                                        </div>
                                    }
                                </div>
                                <div class="swiper-pagination detail-pagination" style="position: relative; margin-top: 15px;"></div>
                            </div>
                        </div>

                        <!-- Swiper JS -->
                        <script src="https://unpkg.com/swiper/swiper-bundle.min.js"></script>
                        <script>
                            document.addEventListener('DOMContentLoaded', function () {
                                new Swiper('.detail-image-slider', {
                                    loop: false,
                                    grabCursor: true,
                                    pagination: { el: '.detail-pagination', clickable: true },
                                    navigation: { nextEl: '.detail-next', prevEl: '.detail-prev' },
                                });
                            });
                        </script>
                    </div>
                </div>
            }

            <h5 class="mb-3 mt-4"><i class="fas fa-images"></i> Tất cả Quản lý Hình ảnh (Dạng lưới)</h5>

            @{
                var gsmThanXeImages = Model.Media?.Where(m => m.Type.IsThanXe() && m.Type.IsGSM()).ToList();
                var gsmGiayToImages = Model.Media?.Where(m => m.Type.IsGiayTo() && m.Type.IsGSM()).ToList();
                var khThanXeImages = Model.Media?.Where(m => m.Type.IsThanXe() && m.Type.IsKH()).ToList();
                var khGiayToImages = Model.Media?.Where(m => m.Type.IsGiayTo() && m.Type.IsKH()).ToList();
            }

            <div class="row g-3 mb-3">
                <!-- Hình ảnh thân xe GSM -->
                <div class="col-12 col-md-6">
                    <div class="card">
                        <div class="card-header bg-success text-white">
                            <strong><i class="fas fa-camera-retro"></i> Hình ảnh thân xe - GSM</strong>
                        </div>
                        <div class="card-body">
                            @if (gsmThanXeImages != null && gsmThanXeImages.Any())
                            {
                                <div class="row g-2">
                                    @foreach (var img in gsmThanXeImages.OrderByDescending(m => m.IsPrimary).ThenByDescending(m => m.CreatedAt))
                                    {
                                        <div class="col-6 col-sm-4 col-md-6 mb-2">
                                            <div class="card h-100">
                                                <div class="card-body p-2 text-center">
                                                    <a href="@img.Url" target="_blank">
                                                        <img src="@img.Url" class="img-fluid rounded" style="max-height:150px; width:100%; object-fit:cover;" />
                                                    </a>
                                                </div>
                                                <div class="card-footer py-1">
                                                    <small class="text-muted d-block" style="font-size:11px;">@img.Type.GetDisplayName()</small>
                                                    @if (img.IsPrimary)
                                                    {
                                                        <span class="badge bg-warning text-dark">Ảnh chính</span>
                                                    }
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                            else
                            {
                                <p class="text-muted mb-0"><i class="fas fa-image"></i> Chưa có ảnh thân xe GSM.</p>
                            }
                        </div>
                    </div>
                </div>

                <!-- Giấy tờ xe GSM -->
                <div class="col-12 col-md-6">
                    <div class="card">
                        <div class="card-header bg-success text-white">
                            <strong><i class="fas fa-file-alt"></i> Giấy tờ xe - GSM</strong>
                        </div>
                        <div class="card-body">
                            @if (gsmGiayToImages != null && gsmGiayToImages.Any())
                            {
                                <div class="row g-2">
                                    @foreach (var img in gsmGiayToImages.OrderByDescending(m => m.CreatedAt))
                                    {
                                        <div class="col-6 col-sm-4 col-md-6 mb-2">
                                            <div class="card h-100">
                                                <div class="card-body p-2 text-center">
                                                    <a href="@img.Url" target="_blank">
                                                        <img src="@img.Url" class="img-fluid rounded" style="max-height:150px; width:100%; object-fit:cover;" />
                                                    </a>
                                                </div>
                                                <div class="card-footer py-1">
                                                    <small class="text-muted" style="font-size:11px;">@img.Type.GetDisplayName()</small>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                            else
                            {
                                <p class="text-muted mb-0"><i class="fas fa-file"></i> Chưa có giấy tờ xe GSM.</p>
                            }
                        </div>
                    </div>
                </div>

                <!-- Hình ảnh thân xe KH -->
                <div class="col-12 col-md-6">
                    <div class="card">
                        <div class="card-header bg-info text-white">
                            <strong><i class="fas fa-camera-retro"></i> Hình ảnh thân xe - KH</strong>
                        </div>
                        <div class="card-body">
                            @if (khThanXeImages != null && khThanXeImages.Any())
                            {
                                <div class="row g-2">
                                    @foreach (var img in khThanXeImages.OrderByDescending(m => m.IsPrimary).ThenByDescending(m => m.CreatedAt))
                                    {
                                        <div class="col-6 col-sm-4 col-md-6 mb-2">
                                            <div class="card h-100">
                                                <div class="card-body p-2 text-center">
                                                    <a href="@img.Url" target="_blank">
                                                        <img src="@img.Url" class="img-fluid rounded" style="max-height:150px; width:100%; object-fit:cover;" />
                                                    </a>
                                                </div>
                                                <div class="card-footer py-1">
                                                    <small class="text-muted d-block" style="font-size:11px;">@img.Type.GetDisplayName()</small>
                                                    @if (img.IsPrimary)
                                                    {
                                                        <span class="badge bg-warning text-dark">Ảnh chính</span>
                                                    }
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                            else
                            {
                                <p class="text-muted mb-0"><i class="fas fa-image"></i> Chưa có ảnh thân xe KH.</p>
                            }
                        </div>
                    </div>
                </div>

                <!-- Giấy tờ xe KH -->
                <div class="col-12 col-md-6">
                    <div class="card">
                        <div class="card-header bg-info text-white">
                            <strong><i class="fas fa-file-alt"></i> Giấy tờ xe - KH</strong>
                        </div>
                        <div class="card-body">
                            @if (khGiayToImages != null && khGiayToImages.Any())
                            {
                                <div class="row g-2">
                                    @foreach (var img in khGiayToImages.OrderByDescending(m => m.CreatedAt))
                                    {
                                        <div class="col-6 col-sm-4 col-md-6 mb-2">
                                            <div class="card h-100">
                                                <div class="card-body p-2 text-center">
                                                    <a href="@img.Url" target="_blank">
                                                        <img src="@img.Url" class="img-fluid rounded" style="max-height:150px; width:100%; object-fit:cover;" />
                                                    </a>
                                                </div>
                                                <div class="card-footer py-1">
                                                    <small class="text-muted" style="font-size:11px;">@img.Type.GetDisplayName()</small>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                            else
                            {
                                <p class="text-muted mb-0"><i class="fas fa-file"></i> Chưa có giấy tờ xe KH.</p>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <div class="mt-4">
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">
                    <i class="fas fa-edit"></i> Chỉnh sửa
                </a>
                <a asp-action="Index" class="btn btn-secondary">
                    <i class="fas fa-arrow-left"></i> Quay lại
                </a>
                <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger">
                    <i class="fas fa-trash"></i> Xóa
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
}
