@model CarViewModel
@using ChargePoint.CarManagement.Models.ViewModels

@{
    ViewData["Title"] = "Chi tiết xe";
}

<div class="container">
    <h1 class="mb-4">
        <i class="fas fa-info-circle"></i> Chi tiết xe
    </h1>

    <div class="card shadow">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0">
                <i class="fas fa-car"></i> @Model.TenXe
            </h5>
        </div>
        <div class="card-body">

            <!-- Primary image display -->
            <div class="row mb-3">
                <div class="col-12 text-center">
                    <h6 class="mb-2"><i class="fas fa-star text-warning"></i> Ảnh chính</h6>
                    @if (!string.IsNullOrEmpty(Model.PrimaryImageUrl))
                    {
                        <a href="@Model.PrimaryImageUrl" target="_blank">
                            <img src="@Model.PrimaryImageUrl" alt="Primary image" class="img-fluid rounded" style="max-height: 300px; cursor: pointer;" />
                        </a>
                        <div class="mt-2">
                            <a href="@Model.PrimaryImageUrl" target="_blank" class="btn btn-sm btn-outline-primary">
                                <i class="fas fa-external-link-alt"></i> Xem ảnh gốc
                            </a>
                        </div>
                    }
                    else
                    {
                        <p class="text-muted py-4"><i class="fas fa-image fa-3x"></i><br />Chưa có ảnh chính</p>
                    }
                </div>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <table class="table table-borderless">
                        <tr>
                            <th style="width: 40%;">@Html.DisplayNameFor(model => model.Stt)</th>
                            <td><span class="badge bg-secondary fs-6">@Model.Stt</span></td>
                        </tr>
                        <tr>
                            <th>@Html.DisplayNameFor(model => model.TenXe)</th>
                            <td><strong>@Model.TenXe</strong></td>
                        </tr>
                        <tr>
                            <th>@Html.DisplayNameFor(model => model.SoLuong)</th>
                            <td><span class="badge bg-primary">@Model.SoLuong</span></td>
                        </tr>
                        <tr>
                            <th>@Html.DisplayNameFor(model => model.MauXe)</th>
                            <td>@Model.MauXe</td>
                        </tr>
                        <tr>
                            <th>@Html.DisplayNameFor(model => model.SoVIN)</th>
                            <td><code>@Model.SoVIN</code></td>
                        </tr>
                        <tr>
                            <th>@Html.DisplayNameFor(model => model.BienSo)</th>
                            <td>
                                @if (!string.IsNullOrEmpty(Model.BienSo))
                                {
                                    @if (Model.MauBienSo == MauBienSo.Vang)
                                    {
                                        <span class="license-plate license-plate-yellow">@Model.BienSo</span>
                                    }
                                    else
                                    {
                                        <span class="license-plate license-plate-white">@Model.BienSo</span>
                                    }
                                }
                                else
                                {
                                    <span class="text-muted">Chưa có</span>
                                }
                            </td>
                        </tr>
                        <tr>
                            <th>@Html.DisplayNameFor(model => model.MauBienSo)</th>
                            <td>
                                @if (Model.MauBienSo == MauBienSo.Vang)
                                {
                                    <span class="badge" style="background-color: #ffc107; color: #000;">
                                        <i class="fas fa-taxi"></i> Biển vàng (Kinh doanh)
                                    </span>
                                }
                                else
                                {
                                    <span class="badge" style="background-color: #fff; color: #000; border: 1px solid #333;">
                                        <i class="fas fa-car"></i> Biển trắng (Cá nhân)
                                    </span>
                                }
                            </td>
                        </tr>
                    </table>
                </div>
                <div class="col-md-6">
                    <table class="table table-borderless">
                        <tr>
                            <th style="width: 40%;">@Html.DisplayNameFor(model => model.TenKhachHang)</th>
                            <td>
                                @if (!string.IsNullOrEmpty(Model.TenKhachHang))
                                {
                                    <i class="fas fa-user text-primary"></i>
                                    @Model.TenKhachHang
                                }
                                else
                                {
                                    <span class="text-muted">Chưa có</span>
                                }
                            </td>
                        </tr>
                        <tr>
                            <th>@Html.DisplayNameFor(model => model.OdoXe)</th>
                            <td>
                                <strong class="text-success">
                                    <i class="fas fa-tachometer-alt"></i> @Model.OdoXe.ToString("N0") km
                                </strong>
                            </td>
                        </tr>
                        <tr>
                            <th>@Html.DisplayNameFor(model => model.ThongTinChoThue)</th>
                            <td>
                                @if (!string.IsNullOrEmpty(Model.ThongTinChoThue))
                                {
                                    <div class="p-2 bg-light rounded">
                                        <i class="fas fa-info-circle text-info"></i> @Model.ThongTinChoThue
                                    </div>
                                }
                                else
                                {
                                    <span class="text-muted">Chưa có thông tin</span>
                                }
                            </td>
                        </tr>
                        <tr>
                            <th>@Html.DisplayNameFor(model => model.NgayTao)</th>
                            <td>
                                <i class="fas fa-calendar-plus text-success"></i>
                                @Model.NgayTao.ToString("dd/MM/yyyy HH:mm")
                            </td>
                        </tr>
                        <tr>
                            <th>@Html.DisplayNameFor(model => model.NgayCapNhat)</th>
                            <td>
                                @if (Model.NgayCapNhat.HasValue)
                                {
                                    <i class="fas fa-calendar-check text-warning"></i>
                                    @Model.NgayCapNhat.Value.ToString("dd/MM/yyyy HH:mm")
                                }
                                else
                                {
                                    <span class="text-muted">Chưa cập nhật</span>
                                }
                            </td>
                        </tr>
                    </table>
                </div>
            </div>

            <hr />

            <!-- Images split: GSM / KH -->
            <h5 class="mb-3"><i class="fas fa-images"></i> Ảnh</h5>
            <div class="row g-3 mb-3">
                <div class="col-12 col-md-6">
                    <div class="card">
                        <div class="card-header bg-light">
                            <strong><i class="fas fa-camera-retro text-success"></i> Hình ảnh GSM</strong>
                        </div>
                        <div class="card-body">
                            @if (Model.Media != null && Model.Media.Any(m => m.Type == MediaType.Image_GSM))
                            {
                                <div class="row g-2">
                                    @foreach (var img in Model.Media.Where(m => m.Type == MediaType.Image_GSM).OrderByDescending(m => m.IsPrimary).ThenByDescending(m => m.CreatedAt))
                                    {
                                        <div class="col-6 col-sm-4 col-md-6 mb-2">
                                            <div class="card h-100">
                                                <div class="card-body p-2 text-center">
                                                    <a href="@img.Url" target="_blank">
                                                        <img src="@img.Url" class="img-fluid rounded" style="max-height:150px; width:100%; object-fit:cover;" />
                                                    </a>
                                                </div>
                                                <div class="card-footer py-1 d-flex justify-content-between align-items-center">
                                                    <small class="text-muted" style="font-size:12px;">@img.FileName</small>
                                                    <div>
                                                        @if (img.IsPrimary)
                                                        {
                                                            <span class="badge bg-warning text-dark">Ảnh chính</span>
                                                        }
                                                        <span class="badge bg-success ms-1">GSM</span>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                            else
                            {
                                <p class="text-muted mb-0"><i class="fas fa-image"></i> Chưa có ảnh GSM.</p>
                            }
                        </div>
                    </div>
                </div>

                <div class="col-12 col-md-6">
                    <div class="card">
                        <div class="card-header bg-light">
                            <strong><i class="fas fa-user-check text-info"></i> Hình ảnh KH</strong>
                        </div>
                        <div class="card-body">
                            @if (Model.Media != null && Model.Media.Any(m => m.Type == MediaType.Image_KH))
                            {
                                <div class="row g-2">
                                    @foreach (var img in Model.Media.Where(m => m.Type == MediaType.Image_KH).OrderByDescending(m => m.IsPrimary).ThenByDescending(m => m.CreatedAt))
                                    {
                                        <div class="col-6 col-sm-4 col-md-6 mb-2">
                                            <div class="card h-100">
                                                <div class="card-body p-2 text-center">
                                                    <a href="@img.Url" target="_blank">
                                                        <img src="@img.Url" class="img-fluid rounded" style="max-height:150px; width:100%; object-fit:cover;" />
                                                    </a>
                                                </div>
                                                <div class="card-footer py-1 d-flex justify-content-between align-items-center">
                                                    <small class="text-muted" style="font-size:12px;">@img.FileName</small>
                                                    <div>
                                                        @if (img.IsPrimary)
                                                        {
                                                            <span class="badge bg-warning text-dark">Ảnh chính</span>
                                                        }
                                                        <span class="badge bg-info text-dark ms-1">KH</span>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                            else
                            {
                                <p class="text-muted mb-0"><i class="fas fa-image"></i> Chưa có ảnh KH.</p>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <!-- Videos separated: GSM / KH -->
            <h5 class="mb-3 mt-4"><i class="fas fa-video"></i> Videos</h5>
            <div class="row g-3 mb-4">
                <div class="col-12 col-md-6">
                    <div class="card h-100">
                        <div class="card-header bg-success text-white">
                            <i class="fas fa-film"></i> Video nhận bàn giao từ GSM
                        </div>
                        <div class="card-body">
                            @if (Model.Media != null && Model.Media.Any(m => m.Type == MediaType.Video_GSM))
                            {
                                <div class="row g-3">
                                    @foreach (var v in Model.Media.Where(m => m.Type == MediaType.Video_GSM).OrderByDescending(m => m.CreatedAt))
                                    {
                                        <div class="col-12 mb-3">
                                            <div class="card">
                                                <div class="card-body p-2 text-center">
                                                    <video controls class="w-100 rounded" style="max-height: 300px;">
                                                        <source src="@v.Url" type="video/mp4" />
                                                        Trình duyệt không hỗ trợ video.
                                                    </video>
                                                </div>
                                                <div class="card-footer py-1 d-flex justify-content-between align-items-center">
                                                    <small class="text-muted">@v.FileName</small>
                                                    <small class="text-muted">@v.CreatedAt.ToString("dd/MM/yyyy HH:mm")</small>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                            else
                            {
                                <p class="text-muted"><i class="fas fa-video"></i> Chưa có video GSM.</p>
                            }
                        </div>
                    </div>
                </div>

                <div class="col-12 col-md-6">
                    <div class="card h-100">
                        <div class="card-header bg-info text-white">
                            <i class="fas fa-film"></i> Video bàn giao cho khách hàng
                        </div>
                        <div class="card-body">
                            @if (Model.Media != null && Model.Media.Any(m => m.Type == MediaType.Video_KH))
                            {
                                <div class="row g-3">
                                    @foreach (var v in Model.Media.Where(m => m.Type == MediaType.Video_KH).OrderByDescending(m => m.CreatedAt))
                                    {
                                        <div class="col-12 mb-3">
                                            <div class="card">
                                                <div class="card-body p-2 text-center">
                                                    <video controls class="w-100 rounded" style="max-height: 300px;">
                                                        <source src="@v.Url" type="video/mp4" />
                                                        Trình duyệt không hỗ trợ video.
                                                    </video>
                                                </div>
                                                <div class="card-footer py-1 d-flex justify-content-between align-items-center">
                                                    <small class="text-muted">@v.FileName</small>
                                                    <small class="text-muted">@v.CreatedAt.ToString("dd/MM/yyyy HH:mm")</small>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                            else
                            {
                                <p class="text-muted"><i class="fas fa-video"></i> Chưa có video KH.</p>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <div class="mt-4">
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">
                    <i class="fas fa-edit"></i> Chỉnh sửa
                </a>
                <a asp-action="Index" class="btn btn-secondary">
                    <i class="fas fa-arrow-left"></i> Quay lại
                </a>
                <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger">
                    <i class="fas fa-trash"></i> Xóa
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
}
