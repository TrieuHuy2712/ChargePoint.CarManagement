@using ChargePoint.CarManagement.Domain.ViewModels
@using System.Reflection
@using System.ComponentModel.DataAnnotations
@model CarViewModel

@{
    ViewData["Title"] = "Xóa xe";

    var carsEnumerable = Model as IEnumerable<CarViewModel>;
    var singleCar = Model as CarViewModel;
    var cars = carsEnumerable != null ? carsEnumerable.ToList() : (singleCar != null ? new List<CarViewModel> { singleCar } : new List<CarViewModel>());

    Func<string, string> DisplayName = (prop) =>
    {
        var pi = typeof(CarViewModel).GetProperty(prop);
        var disp = pi?.GetCustomAttribute<DisplayAttribute>();
        return disp?.GetName() ?? prop;
    };
}

<div class="container">
    <h1 class="mb-4 text-danger">
        <i class="fas fa-trash-alt"></i> Xóa xe
    </h1>

    @if (!cars.Any())
    {
        <div class="alert alert-info">Không có xe để xóa.</div>
    }
    else if (cars.Count == 1)
    {
        var car = cars[0];

        <div class="alert alert-warning">
            <i class="fas fa-exclamation-triangle"></i>
            <strong>Cảnh báo!</strong> Bạn có chắc chắn muốn xóa xe này?
        </div>

        <div class="card shadow">
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6">
                        <dl class="row">
                            <dt class="col-sm-4">@DisplayName("Stt")</dt>
                            <dd class="col-sm-8">@car.Stt</dd>

                            <dt class="col-sm-4">@DisplayName("TenXe")</dt>
                            <dd class="col-sm-8">@car.TenXe</dd>

                            <dt class="col-sm-4">@DisplayName("SoLuong")</dt>
                            <dd class="col-sm-8">@car.SoLuong</dd>

                            <dt class="col-sm-4">@DisplayName("MauXe")</dt>
                            <dd class="col-sm-8">@car.MauXe</dd>

                            <dt class="col-sm-4">@DisplayName("SoVIN")</dt>
                            <dd class="col-sm-8">@car.SoVIN</dd>
                        </dl>
                    </div>

                    <div class="col-md-6">
                        <dl class="row">
                            <dt class="col-sm-4">@DisplayName("BienSo")</dt>
                            <dd class="col-sm-8">@car.BienSo</dd>

                            <dt class="col-sm-4">@DisplayName("TenKhachHang")</dt>
                            <dd class="col-sm-8">@car.TenKhachHang</dd>

                            <dt class="col-sm-4">@DisplayName("ThongTinChoThue")</dt>
                            <dd class="col-sm-8">@car.ThongTinChoThue</dd>

                            <dt class="col-sm-4">@DisplayName("OdoXe")</dt>
                            <dd class="col-sm-8">@car.OdoXe km</dd>
                        </dl>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(car.HinhAnhNhanBanGiaoGSM) || !string.IsNullOrEmpty(car.HinhAnhBanGiaoKHThucTe))
                {
                    <hr />
                    <h5>Hình ảnh</h5>
                    <div class="row">
                        @if (!string.IsNullOrEmpty(car.HinhAnhNhanBanGiaoGSM))
                        {
                            <div class="col-md-6">
                                <img src="@car.HinhAnhNhanBanGiaoGSM" alt="GSM" class="img-thumbnail" style="max-width: 200px;" />
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(car.HinhAnhBanGiaoKHThucTe))
                        {
                            <div class="col-md-6">
                                <img src="@car.HinhAnhBanGiaoKHThucTe" alt="KH" class="img-thumbnail" style="max-width: 200px;" />
                            </div>
                        }
                    </div>
                }

                <form asp-action="Delete" method="post" class="mt-4" onsubmit="return confirm('Bạn có chắc chắn muốn xóa xe này?');">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@car.Id" />
                    <button type="submit" class="btn btn-danger">
                        <i class="fas fa-trash"></i> Xác nhận xóa
                    </button>
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="fas fa-times"></i> Hủy
                    </a>
                </form>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-warning">
            <i class="fas fa-exclamation-triangle"></i>
            <strong>Cảnh báo!</strong> Bạn đang chuẩn bị xóa nhiều xe. Hành động này không thể hoàn tác.
        </div>

        <form asp-action="DeleteMultiple" method="post" id="bulkDeleteForm">
            @Html.AntiForgeryToken()
            <div class="mb-3">
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" id="selectAll" />
                    <label class="form-check-label" for="selectAll">Chọn tất cả</label>
                </div>
            </div>

            <div class="card shadow">
                <div class="card-body p-0">
                    <table class="table table-striped mb-0">
                        <thead class="table-light">
                            <tr>
                                <th style="width:40px"></th>
                                <th>@DisplayName("Stt")</th>
                                <th>@DisplayName("TenXe")</th>
                                <th>@DisplayName("BienSo")</th>
                                <th>@DisplayName("SoVIN")</th>
                                <th>@DisplayName("OdoXe")</th>
                                <th>Hình ảnh</th>
                            </tr>
                        </thead>
                        <tbody>
                            @for (int i = 0; i < cars.Count; i++)
                            {
                                var c = cars[i];
                                <tr>
                                    <td>
                                        <input type="checkbox" name="ids" value="@c.Id" class="itemCheckbox" />
                                    </td>
                                    <td>@c.Stt</td>
                                    <td>@c.TenXe</td>
                                    <td>@c.BienSo</td>
                                    <td>@c.SoVIN</td>
                                    <td>@c.OdoXe km</td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(c.HinhAnhNhanBanGiaoGSM))
                                        {
                                            <img src="@c.HinhAnhNhanBanGiaoGSM" alt="GSM" class="img-thumbnail" style="max-width: 80px;" />
                                        }
                                        else if (!string.IsNullOrEmpty(c.HinhAnhBanGiaoKHThucTe))
                                        {
                                            <img src="@c.HinhAnhBanGiaoKHThucTe" alt="KH" class="img-thumbnail" style="max-width: 80px;" />
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="mt-3">
                <button type="submit" class="btn btn-danger" id="confirmBulkDelete">
                    <i class="fas fa-trash"></i> Xác nhận xóa đã chọn
                </button>
                <a asp-action="Index" class="btn btn-secondary">
                    <i class="fas fa-times"></i> Hủy
                </a>
            </div>
        </form>
    }
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

    <script>
        (function () {
            var selectAll = document.getElementById('selectAll');
            if (selectAll) {
                selectAll.addEventListener('change', function () {
                    var checkboxes = document.querySelectorAll('.itemCheckbox');
                    checkboxes.forEach(function (cb) { cb.checked = selectAll.checked; });
                });
            }

            var bulkForm = document.getElementById('bulkDeleteForm');
            if (bulkForm) {
                bulkForm.addEventListener('submit', function (e) {
                    var checked = document.querySelectorAll('.itemCheckbox:checked');
                    if (checked.length === 0) {
                        e.preventDefault();
                        alert('Vui lòng chọn ít nhất một xe để xóa.');
                        return false;
                    }

                    if (!confirm('Bạn có chắc chắn muốn xóa ' + checked.length + ' xe đã chọn?')) {
                        e.preventDefault();
                        return false;
                    }
                });
            }
        })();
    </script>
}
