@{
    ViewData["Title"] = "Truy cập bị từ chối";
}

<div class="container">
    <div class="row justify-content-center mt-5">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-body text-center p-5">
                    <i class="fas fa-exclamation-triangle fa-5x text-warning mb-4"></i>
                    <h1 class="display-4 mb-3">Truy cập bị từ chối</h1>
                    <p class="lead mb-4">Bạn không có quyền truy cập vào trang này.</p>
                    <p>Vui lòng liên hệ quản trị viên nếu bạn cho rằng đây là lỗi.</p>
                    <div class="mt-4">
                        <a asp-action="Login" asp-controller="Account" class="btn btn-primary btn-lg">
                            <i class="fas fa-sign-in-alt"></i> Đăng nhập
                        </a>
                        <a asp-action="Index" asp-controller="Home" class="btn btn-secondary btn-lg">
                            <i class="fas fa-home"></i> Trang chủ
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
}
